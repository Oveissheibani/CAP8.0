def color_to_root_index(value):
    """Translate a DrawSpec.color string into a ROOT color index.
    Accepts named colors from COLOR_BY_NAME, '#rrggbb' hex strings, or
    ROOT ints serialized as 'root:NNN' (which we use to remember
    custom colours allocated via TColor::GetColor)."""
    if not value:
        return 1
    if value in COLOR_BY_NAME:
        return COLOR_BY_NAME[value]
    if value.startswith("root:"):
        try: return int(value.split(":", 1)[1])
        except ValueError: return 1
    if value.startswith("#") and len(value) == 7 and ROOT is not None:
        try:
            r = int(value[1:3], 16) / 255.0
            g = int(value[3:5], 16) / 255.0
            b = int(value[5:7], 16) / 255.0
            return ROOT.TColor.GetColor(r, g, b)
        except Exception:
            return 1
    return 1

