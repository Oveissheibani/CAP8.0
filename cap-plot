    # ---- LaTeX report generator ---------------------------------------
    @staticmethod
    def _tex_escape(s: str) -> str:
        """Quick-and-dirty escape of TeX-special chars in user labels.
        Doesn't try to be a full LaTeX serializer — preserves $..$ math
        if you typed it deliberately, escapes backslashes, &, %, _, #,
        ~, ^, {, }."""
        if "$" in s:
            return s    # assume the user knows what they're doing
        repl = {
            "\\": r"\textbackslash{}", "&": r"\&", "%": r"\%",
            "_": r"\_", "#": r"\#", "~": r"\textasciitilde{}",
            "^": r"\textasciicircum{}", "{": r"\{", "}": r"\}",
        }
        out = []
        for ch in s:
            out.append(repl.get(ch, ch))
        return "".join(out)

    def _generate_latex_report(self):
        """Save the current selection as one PDF per histogram, then
        write a stand-alone .tex that embeds them as figures with
        captions.  If pdflatex is on PATH, compile the report.

        Two layout modes:
          - Same-overlay  → one combined figure (current canvas)
          - Separate grid → either one figure per pad (n_pads ≤ 6) OR
                            a single multi-pad figure for larger grids.
        We default to one figure per spec so each can be referenced /
        re-captioned individually."""
        if not self.specs:
            messagebox.showinfo("LaTeX report",
                "Tick at least one histogram before generating a report.")
            return

        out_dir = filedialog.askdirectory(
            title="Choose output folder for the LaTeX report",
            initialdir=str(self.start_dir))
        if not out_dir:
            return
        out_dir = Path(out_dir)
        out_dir.mkdir(parents=True, exist_ok=True)
        figs_dir = out_dir / "figures"
        figs_dir.mkdir(exist_ok=True)

        # Ask for the document metadata.
        meta = self._prompt_report_metadata()
        if meta is None:
            return
        title, author, intro = meta

        self.status_var.set("Generating figures (PDF)…")
        self.root.update_idletasks()

        # Strategy: write one PDF per spec by temporarily replacing
        # self.specs with a single-spec list and calling _render with
        # save_path.  Restore afterwards.
        original_specs = list(self.specs)
        original_mode = self.mode_var.get()
        try:
            # Force separate mode so each spec renders alone.
            self.mode_var.set(self.SEPARATE)
            old_cols, old_rows = self.cols_var.get(), self.rows_var.get()
            self.cols_var.set(1); self.rows_var.set(1)
            generated: list[tuple[DrawSpec, str]] = []
            for i, spec in enumerate(original_specs):
                self.specs = [spec]
                fname = f"fig_{i:03d}_{Path(spec.path).name}.pdf"
                # Sanitize filename — TeX dislikes most special chars.
                fname = "".join(c if c.isalnum() or c in "._-" else "_"
                                for c in fname)
                fpath = figs_dir / fname
                try:
                    self._render(save_path=str(fpath))
                    generated.append((spec, fname))
                except Exception as exc:
                    self.status_var.set(f"Skipped {spec.path}: {exc}")
            # Also render the combined-overlay (same mode) figure if
            # the user has more than one spec selected — useful as a
            # summary at the top of the report.
            combined_name = None
            if len(original_specs) > 1:
                self.specs = original_specs
                self.mode_var.set(self.SAME)
                combined_name = "fig_combined_overlay.pdf"
                try:
                    self._render(save_path=str(figs_dir / combined_name))
                except Exception:
                    combined_name = None
        finally:
            self.specs = original_specs
            self.mode_var.set(original_mode)
            self.cols_var.set(old_cols); self.rows_var.set(old_rows)

        # Write the .tex file.
        tex_path = out_dir / "report.tex"
        with tex_path.open("w") as f:
            f.write("\\documentclass[11pt]{article}\n")
            f.write("\\usepackage[a4paper,margin=2.5cm]{geometry}\n")
            f.write("\\usepackage{graphicx}\n")
            f.write("\\usepackage{caption}\n")
            f.write("\\usepackage{hyperref}\n")
            f.write("\\usepackage{amsmath, amssymb}\n")
            f.write(f"\\title{{{self._tex_escape(title)}}}\n")
            f.write(f"\\author{{{self._tex_escape(author)}}}\n")
            f.write("\\date{\\today}\n")
            f.write("\\begin{document}\n\\maketitle\n\n")
            if intro.strip():
                f.write(f"{intro}\n\n")
            f.write("\\section{Summary}\n")
            f.write(f"This report bundles {len(generated)} histogram"
                    f"{'s' if len(generated)!=1 else ''} extracted "
                    f"with cap-plot from the analysis output.\n\n")
            if combined_name:
                f.write("\\begin{figure}[h]\n  \\centering\n")
                f.write(f"  \\includegraphics[width=0.85\\linewidth]"
                        f"{{figures/{combined_name}}}\n")
                f.write("  \\caption{Overlay of all selected histograms.}\n")
                f.write("  \\label{fig:combined}\n\\end{figure}\n\n")
            f.write("\\section{Individual histograms}\n\n")
            for i, (spec, fname) in enumerate(generated, 1):
                pretty = self._tex_escape(
                    spec.legend_label or
                    f"{Path(spec.file).name} :: {spec.path}")
                cls = self._tex_escape(spec.classname)
                f.write(f"\\subsection*{{{i}.\\ {pretty}}}\n")
                f.write(f"\\begin{{figure}}[h]\n  \\centering\n")
                f.write(f"  \\includegraphics[width=0.78\\linewidth]"
                        f"{{figures/{fname}}}\n")
                f.write(f"  \\caption{{Histogram \\texttt{{{cls}}} "
                        f"loaded from \\texttt{{"
                        f"{self._tex_escape(Path(spec.file).name)}}}, "
                        f"path \\texttt{{"
                        f"{self._tex_escape(spec.path)}}}.}}\n")
                f.write(f"  \\label{{fig:hist{i:03d}}}\n")
                f.write("\\end{figure}\n\\clearpage\n\n")
            f.write("\\end{document}\n")

        # Try to compile.  Non-fatal — leave the .tex behind regardless.
        compiled = False
        if shutil.which("pdflatex"):
            self.status_var.set("Running pdflatex…")
            self.root.update_idletasks()
            try:
                # Run twice for cross-references (figure numbers).
                for _ in range(2):
                    rc = subprocess.run(
                        ["pdflatex", "-interaction=nonstopmode",
                         "-halt-on-error", "report.tex"],
                        cwd=str(out_dir),
                        capture_output=True, text=True, timeout=120)
                    if rc.returncode != 0:
                        break
                else:
                    compiled = True
            except Exception:
                pass

        msg = (f"Wrote {tex_path}\n"
               f"  + {len(generated)} figure(s) in figures/\n")
        if compiled:
            msg += f"  + compiled report.pdf"
        elif shutil.which("pdflatex"):
            msg += ("  · pdflatex was found but compilation failed.\n"
                    "    See report.log in the output folder.")
        else:
            msg += ("  · pdflatex not on PATH; .tex file ready, "
                    "compile it manually.")
        self.status_var.set(f"LaTeX report → {out_dir}")
        messagebox.showinfo("LaTeX report", msg)

    def _prompt_report_metadata(self):
        """Modal asking for title / author / intro paragraph.  Returns
        a (title, author, intro) tuple or None if user cancels."""
        top = tk.Toplevel(self.root)
        top.title("LaTeX report — metadata")
        top.transient(self.root)
        top.geometry("520x340")
        result = {}
        ttk.Label(top, text="Document title:").pack(anchor="w", padx=12, pady=(12, 0))
        title_var = tk.StringVar(value=f"Analysis report — "
                                       f"{self.start_dir.name}")
        ttk.Entry(top, textvariable=title_var, width=60
                  ).pack(padx=12, pady=2)
        ttk.Label(top, text="Author:").pack(anchor="w", padx=12, pady=(8, 0))
        author_var = tk.StringVar(value=os.environ.get("USER", "CAP user"))
        ttk.Entry(top, textvariable=author_var, width=60
                  ).pack(padx=12, pady=2)
        ttk.Label(top, text="Optional introduction (one paragraph; "
                  "TeX syntax allowed):").pack(anchor="w", padx=12, pady=(8, 0))
        intro_text = tk.Text(top, height=6, wrap="word")
        intro_text.pack(padx=12, pady=2, fill=tk.BOTH, expand=True)

        def commit():
            result["t"] = title_var.get()
            result["a"] = author_var.get()
            result["i"] = intro_text.get("1.0", "end").strip()
            top.destroy()
        bf = ttk.Frame(top); bf.pack(pady=8)
        ttk.Button(bf, text="OK", command=commit).pack(side=tk.LEFT, padx=4)
        ttk.Button(bf, text="Cancel",
                   command=top.destroy).pack(side=tk.LEFT, padx=4)
        top.grab_set()
        self.root.wait_window(top)
        if not result:
            return None
        return result["t"], result["a"], result["i"]

    def _save_plot_dropdown(self):
        """Save using the format chosen in the action-row dropdown.
        The dropdown label encodes the file extension; we look it up
        in SAVE_EXT_BY_LABEL."""
        label = self.save_format_var.get()
        ext = SAVE_EXT_BY_LABEL.get(label, ".png")
        self._save_plot(ext=ext)

    def _apply_pad_options(self, pad):
        if pad is None: return
        try:
            pad.SetLogx(1 if self.logx_var.get() else 0)
            pad.SetLogy(1 if self.logy_var.get() else 0)
            pad.SetLogz(1 if self.logz_var.get() else 0)
            pad.SetGrid(1 if self.grid_var.get() else 0,
                        1 if self.grid_var.get() else 0)
        except Exception:
            pass

    # -- save -------------------------------------------------------------

    def _save_plot(self, ext: str | None = None):
        if not self.specs:
            messagebox.showinfo("cap-plot", "Nothing to save — select histograms first.")
            return
        if ext is None:
            f = filedialog.asksaveasfilename(
                defaultextension=".png",
                filetypes=[("PNG", "*.png"), ("PDF", "*.pdf"),
                           ("SVG", "*.svg"), ("ROOT", "*.root")])
        else:
            f = filedialog.asksaveasfilename(defaultextension=ext,
                filetypes=[(ext.upper().lstrip("."), f"*{ext}")])
        if not f:
            return
        # Re-render directly into the chosen file — same code path as
        # the on-screen draw, but ROOT picks the format off the
        # extension (.pdf / .svg / .root all work).
        try:
            self._render(save_path=f)
            self.status_var.set(f"Saved {f}")
        except Exception as exc:
            messagebox.showerror("cap-plot", f"Save failed: {exc}")


def _self_test():
    """Headless smoke test of the data layer + render-control flow.
    Doesn't open Tk; mocks ROOT just enough to exercise _resolve_object
    and the same-mode max scan path.  Run via:  ./cap-plot --self-test"""
    failures = []
    def check(cond, msg):
        if not cond: failures.append(msg)

    # ----- 1) static lookup tables --------------------------------------
    check(default_draw_opt("TH1F") == "E1",   "TH1 default")
    check(default_draw_opt("TH2D") == "COLZ", "TH2 default")
    check(default_draw_opt("TH3D") == "BOX",  "TH3 default")
    check(default_draw_opt("TProfile") == "E0", "TProfile default")
    check(default_draw_opt("TProfile2D") == "COLZ", "TProfile2D default")
    check(default_draw_opt("TGraph") == "AP", "TGraph default")
    check(default_draw_opt("TF1") == "",      "TF1 default")
    check(default_draw_opt("TLeaf") == "E1",  "unknown class falls back to E1")
    check(set(COLOR_NAMES) == set(COLOR_BY_NAME), "COLOR table self-consistent")
    check(set(MARKER_LABELS) == set(MARKER_BY_LABEL), "MARKER table self-consistent")

    # ----- 2) DrawSpec picks default per class -------------------------
    s = DrawSpec("/tmp/x.root", "h", "x", classname="TH2F")
    check(s.draw_opt == "COLZ", "DrawSpec(TH2) draw_opt = COLZ")
    s = DrawSpec("/tmp/x.root", "h", "x", classname="TH1D")
    check(s.draw_opt == "E1",   "DrawSpec(TH1) draw_opt = E1")
    check(HAVE_PIL is False or LANCZOS is not None,
          "Pillow LANCZOS resolves when PIL is present")
    check(set(DrawSpec.__slots__) >= {"file", "path", "color", "marker",
                                       "draw_opt", "label", "classname"},
          "DrawSpec __slots__ covers all fields")

    # ----- 3) _resolve_object — defensive Get walk ----------------------
    # Build a fake TFile/TDirectory chain.
    class _FakeKey:
        def __init__(self, name): self._name = name
        def GetName(self): return self._name
    class _FakeObj:
        def __init__(self, label): self.label = label
        def GetMaximum(self): return 42.0
    class _FakeDir:
        def __init__(self, name, contents):
            self._name = name; self._c = contents
        def Get(self, p):
            # Support both bare-name and slash-walk lookups.
            if "/" in p:
                head, _, tail = p.partition("/")
                d = self._c.get(head)
                if d is None: return None
                return d.Get(tail) if hasattr(d, "Get") else None
            return self._c.get(p)
        def GetListOfKeys(self):
            return [_FakeKey(k) for k in self._c]
    leaf = _FakeObj("leaf!")
    sub = _FakeDir("sub", {"h": leaf})
    root = _FakeDir("/", {"dir": sub, "top_h": _FakeObj("top!")})

    # Build a stub gui object that owns _resolve_object.
    gui_stub = CapPlotGUI.__new__(CapPlotGUI)
    obj = gui_stub._resolve_object(root, "top_h")
    check(obj is leaf or (obj is not None and obj.label == "top!"),
          "_resolve_object resolves top-level histo")
    obj = gui_stub._resolve_object(root, "dir/h")
    check(obj is leaf, "_resolve_object resolves nested path")
    obj = gui_stub._resolve_object(root, "dir/h;1")
    check(obj is leaf, "_resolve_object strips cycle suffix")
    obj = gui_stub._resolve_object(root, "missing/path")
    check(obj is None, "_resolve_object returns None for missing key")

    # ----- 4) class_dim / drawopt_choices / line styles ----------------
    check(class_dim("TH1F") == 1,         "class_dim TH1=1")
    check(class_dim("TH2D") == 2,         "class_dim TH2=2")
    check(class_dim("TH3D") == 3,         "class_dim TH3=3")
    check(class_dim("TGraph") == 1,       "class_dim TGraph=1")
    check(class_dim("TProfile2D") == 2,   "class_dim TProfile2D=2")
    check(class_dim("TLeaf") == 0,        "class_dim unknown=0")
    check("COLZ" in drawopt_choices_for("TH2F"),
                                          "drawopt presets for TH2 contains COLZ")
    check("BOX" in drawopt_choices_for("TH3D"),
                                          "drawopt presets for TH3 contains BOX")
    check("E1" in drawopt_choices_for("TH1F"),
                                          "drawopt presets for TH1 contains E1")
    check("AP" in drawopt_choices_for("TGraphErrors"),
                                          "drawopt presets for TGraph contains AP")
    check(LINESTYLE_BY_LABEL["solid ──"] == 1,
                                          "line style 'solid' = ROOT 1")
    check(set(LINESTYLE_LABELS) == set(LINESTYLE_BY_LABEL),
                                          "LINE_STYLES table self-consistent")
    # SAVE_FORMATS round-trip
    check(SAVE_EXT_BY_LABEL[SAVE_FORMAT_LABELS[1]] == ".pdf",
                                          "save format dropdown round-trip")

    # ----- 5) DrawSpec gains line/marker/legend fields ----------------
    s = DrawSpec("/tmp/x.root", "h", "x", classname="TH1F")
    check(s.line_style == "solid ──",     "DrawSpec default line style")
    check(s.line_width == 2,              "DrawSpec default line width")
    check(s.marker_size == 0.9,           "DrawSpec default marker size")
    check(s.legend_label == "",           "DrawSpec default legend label")
    check(s.in_legend is True,            "DrawSpec default in_legend")
    check(set(DrawSpec.__slots__) >= {
        "marker_size", "legend_label", "in_legend"},
        "DrawSpec slots include new style/legend fields")

    # ----- 6) color_to_root_index lookup --------------------------------
    check(color_to_root_index("black") == 1,    "named color → index")
    check(color_to_root_index("root:42") == 42, "root:NN serialization")
    check(color_to_root_index("#xx") == 1,      "bad hex falls back to 1")
    check(color_to_root_index("") == 1,         "empty color → 1")
    check(color_to_root_index(None) == 1,       "None color → 1")
    check(CUSTOM_COLOR_LABEL.startswith("▶"),
          "custom color sentinel exists")

    # ----- 7) Legend position presets ----------------------------------
    check(len(CapPlotGUI._LEGEND_POS) == 6,
          "6 legend position presets (incl. custom)")
    check("top-right (default)" in CapPlotGUI._LEGEND_POS,
          "default legend position present")
    check("custom (use NDC entries)" in CapPlotGUI._LEGEND_POS,
          "custom legend NDC sentinel present")
    check(CapPlotGUI._LEGEND_POS["custom (use NDC entries)"] is None,
          "custom legend position maps to None (signals NDC fallback)")
    check(all(v is None or len(v) == 4
              for v in CapPlotGUI._LEGEND_POS.values()),
          "every fixed legend position is a 4-tuple")

    # ----- 8) Z-axis + wire-mesh state vars exist on the GUI class ----
    # (We can only inspect the class itself headlessly; the StringVars
    # are created in __init__ which we don't call.  Verify by source
    # introspection: the names appear in CapPlotGUI's source.)
    import inspect
    src = inspect.getsource(CapPlotGUI)
    check("ztitle_var"     in src, "GUI defines ztitle_var")
    check("ztitle_off_var" in src, "GUI defines ztitle_off_var")
    check("wire3d_var"     in src, "GUI defines wire3d_var (3D wire-mesh toggle)")
    check("SetLineWidth(0)" in src, "render path zeroes line width when wire mesh off")
    check("GetZaxis()"     in src, "render path applies Z axis title")

    # ----- TLatex palette table is well-formed ------------------------
    check(len(TLATEX_SYMBOLS) >= 5,
          "TLatex palette has at least 5 categories")
    check(all(isinstance(items, list) and items
              for items in TLATEX_SYMBOLS.values()),
          "every TLatex category has entries")
    check(all(len(it) == 2 and "#" in code
              for items in TLATEX_SYMBOLS.values()
              for it in items
              for (_, code) in [it]
              if code.startswith("#")),
          "TLatex codes use '#' escape (ROOT convention, not '\\')")
    # A couple of staple codes are present.
    flat = [code for items in TLATEX_SYMBOLS.values()
            for (_, code) in items]
    check("#pi"        in flat, "palette contains #pi")
    check("p_{T}"      in flat, "palette contains p_{T}")
    check("#sqrt{s}"   in flat, "palette contains #sqrt{s}")
    check("#bar{p}"    in flat, "palette contains #bar{p} (antiproton)")

    # ----- 10) LaTeX escape helper + report-method existence ----------
    check(CapPlotGUI._tex_escape("a_b") == "a\\_b",
          "_tex_escape escapes underscore")
    check(CapPlotGUI._tex_escape("a&b") == "a\\&b",
          "_tex_escape escapes ampersand")
    check(CapPlotGUI._tex_escape("a%b") == "a\\%b",
          "_tex_escape escapes percent")
    check(CapPlotGUI._tex_escape("$\\pi$") == "$\\pi$",
          "_tex_escape leaves $math$ alone")
    check("_generate_latex_report" in dir(CapPlotGUI),
          "GUI has _generate_latex_report method")
    check("_prompt_report_metadata" in dir(CapPlotGUI),
          "GUI has _prompt_report_metadata method")

    # ----- 11) Z range entries / wire ---------------------------------
    src2 = inspect.getsource(CapPlotGUI)
    check("zmin_var" in src2, "GUI defines zmin_var")
    check("zmax_var" in src2, "GUI defines zmax_var")
    check("GetZaxis().SetRangeUser" in src2,
          "render path applies Z range via SetRangeUser")
    check("SetMinimum" in src2 and "SetMaximum" in src2,
          "render path also clips Z via SetMinimum/SetMaximum (COLZ)")

    # ----- 9) summary --------------------------------------------------
    if failures:
        print("SELF-TEST FAILED:")
        for m in failures: print("  -", m)
        sys.exit(1)
    n_checks = 10 + 4 + 4 + 13 + 6 + 6 + 5 + 5 + 7 + 6 + 4
    print(f"SELF-TEST OK ({n_checks} checks)  · "
          f"PIL={HAVE_PIL}  · ROOT={'yes' if ROOT else 'no'}")
    sys.exit(0)


def main():
    if "--self-test" in sys.argv:
        _self_test()
    _import_tk()    # any actual GUI run needs tkinter
    start = REPO / "histos"
    if len(sys.argv) > 1 and sys.argv[1] != "--self-test":
        start = Path(sys.argv[1])
    gui = CapPlotGUI(start)
    gui.root.mainloop()


if __name__ == "__main__":
    main()
