def default_draw_opt(classname: str) -> str:
    """Pick a sensible default draw option per ROOT class.  E1 only works
    for TH1/profiles; TH2/TH3 need explicit COLZ/BOX-style options to
    show any output at all."""
    if classname.startswith("TH3"):    return "BOX"
    if classname.startswith("TH2"):    return "COLZ"
    if classname.startswith("TProfile2D"): return "COLZ"
    if classname.startswith("TProfile"):   return "E0"
    if classname.startswith("TGraph"): return "AP"
    if classname.startswith("TF1"):    return ""
    return "E1"                         # TH1 default: markers + errors


# A draw entry — one row in the selection table.
class DrawSpec:
    __slots__ = ("file", "path", "color", "marker", "draw_opt",
                 "label", "classname", "line_style", "line_width",
                 "marker_size", "legend_label", "in_legend")

    def __init__(self, file: str, path: str, label: str,
                 classname: str = "TH1"):
        self.file = file              # absolute path
        self.path = path              # /dir/dir/histname inside the file
        self.classname = classname
        self.color = "black"
        self.marker = "● circle"
        self.marker_size = 0.9
        self.line_style = "solid ──"
        self.line_width = 2
        self.draw_opt = default_draw_opt(classname)
        self.label = label
        # Per-spec legend entry — designer overrides legend_label and
        # uses in_legend to include / exclude this row.
        self.legend_label = ""             # blank → use file::path short
        self.in_legend = True


