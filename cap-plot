class CapPlotGUI:
    SEPARATE = "Separate (grid)"
    SAME = "Same (overlay)"

    def __init__(self, start_dir: Path):
        self.root = tk.Tk()
        self.root.title("CAP — plot browser")
        self.root.geometry("1280x820")
        self.start_dir = start_dir if start_dir.exists() else REPO

        self.files: dict[str, "ROOT.TFile"] = {}    # path -> open TFile
        self.specs: list[DrawSpec] = []
        self.tmpdir = Path(tempfile.mkdtemp(prefix="cap-plot-"))
        self.last_png: Path | None = None
        self._image_ref = None                       # keep PhotoImage alive
        # Remember (file, path) tuples that the user had ticked so reload
        # restores them.  Filled on every check-toggle, drained on reload.
        self._checked_memory: set[tuple[str, str]] = set()
        # Debounce token for the live search box.
        self._filter_after_id: str | None = None

        if ROOT is None:
            self._fatal_no_root()
            return

        self._build_ui()
        # Tk 8.5 can't display PNG natively.  Warn early so the user
        # isn't surprised when plots fail to render.
        try:
            tk_ver = float(self.root.tk.call("info", "patchlevel").rsplit(".", 1)[0])
            if tk_ver < 8.6:
                self.status_var.set(
                    f"Tk {tk_ver} is older than 8.6 — plot images may not "
                    f"render.  Install Pillow for a robust workaround.")
        except Exception:
            pass
        # Use the validated fallback so a non-existent CLI argument doesn't
        # leave the title stuck on a path nothing was loaded from.
        self._populate_initial(self.start_dir)
        self.root.protocol("WM_DELETE_WINDOW", self._on_close)

    # -- bootstrap helpers ------------------------------------------------

    def _fatal_no_root(self):
        f = ttk.Frame(self.root, padding=20)
        f.pack(fill=tk.BOTH, expand=True)
        ttk.Label(f, text="PyROOT not available", font=("TkDefaultFont", 16, "bold")
                  ).pack(pady=10)
        ttk.Label(f, justify="left", text=(
            "cap-plot needs ROOT's Python bindings.  Couldn't import ROOT.\n\n"
            "Try one of:\n"
            "  • source the ROOT thisroot.sh that ships with your install\n"
            "  • make sure root-config is on your $PATH\n"
            "  • pip install root_numpy as a fallback (limited)\n"
        )).pack()

    def _on_close(self):
        prev = getattr(self, "_last_canvas", None)
        if prev is not None:
            try: prev.Close()
            except Exception: pass
            self._last_canvas = None
        for f in self.files.values():
            try: f.Close()
            except Exception: pass
        try: shutil.rmtree(self.tmpdir, ignore_errors=True)
        except Exception: pass
        self.root.destroy()

    # -- UI construction --------------------------------------------------

    def _build_ui(self):
        # Top bar with logo + title + browse buttons.
        top = ttk.Frame(self.root)
        top.pack(fill=tk.X, padx=10, pady=8)
        logo_png = REPO / "logo" / "logo.png"
        if logo_png.is_file():
            try:
                img = tk.PhotoImage(file=str(logo_png))
                target_h = 40
                factor = max(1, max(img.width(), img.height()) // target_h)
                if factor > 1:
                    img = img.subsample(factor, factor)
                self._logo_img = img
                ttk.Label(top, image=self._logo_img).pack(side=tk.LEFT, padx=(0, 10))
            except Exception:
                pass
        ttk.Label(top, text="CAP — plot browser",
                  font=("TkDefaultFont", 14, "bold")).pack(side=tk.LEFT)
        ttk.Button(top, text="Browse folder…",
                   command=self._browse_folder).pack(side=tk.RIGHT, padx=4)
        ttk.Button(top, text="Add .root file…",
                   command=self._add_file_dialog).pack(side=tk.RIGHT, padx=4)
        ttk.Button(top, text="Reload all",
                   command=self._reload_all).pack(side=tk.RIGHT, padx=4)
        ttk.Button(top, text="Σ TLatex symbols…",
                   command=self._open_tlatex_palette
                   ).pack(side=tk.RIGHT, padx=4)
        # Track the last text-bearing widget that had focus so the
        # symbol palette knows where to insert.
        self._last_text_widget = None
        self.root.bind_all("<FocusIn>", self._track_focus, add="+")

        # Main paned: left tree, right plot+controls.
        main = ttk.PanedWindow(self.root, orient=tk.HORIZONTAL)
        main.pack(fill=tk.BOTH, expand=True, padx=10, pady=4)

        left = ttk.Frame(main)
        main.add(left, weight=1)
        right = ttk.Frame(main)
        main.add(right, weight=3)

        # ---- left: search box + file tree ------------------------------
        ttk.Label(left, text="Open ROOT files / histograms",
                  font=("TkDefaultFont", 10, "bold")).pack(anchor="w")
        srow = ttk.Frame(left); srow.pack(fill=tk.X, pady=(2, 4))
        ttk.Label(srow, text="🔍").pack(side=tk.LEFT)
        self.filter_var = tk.StringVar()
        # Debounce: re-run the filter only ~200 ms after the last
