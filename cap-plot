def class_dim(classname: str) -> int:
    """Histogram dimension — 1/2/3 for TH1/TH2/TH3, 1 for profiles &
    graphs, 0 if unrecognised.  Used by the Same-mode compatibility
    check: TH1 SAME TH2 makes no sense."""
    if classname.startswith("TH3") or classname.startswith("TProfile3D"):
        return 3
    if classname.startswith("TH2") or classname.startswith("TProfile2D"):
        return 2
    if classname.startswith(("TH1", "TProfile", "TGraph", "TF1")):
        return 1
    return 0


def drawopt_choices_for(classname: str) -> list[str]:
    """Return the draw-option preset list keyed off a class name.
    Falls back to TH1 presets for unknown classes."""
    # Most-specific match first so TProfile2D wins over TProfile.
    for k in ("TProfile2D", "TProfile", "TH3", "TH2", "TH1",
              "TGraph", "TF1"):
        if classname.startswith(k):
            return DRAWOPT_PRESETS[k]
    return DRAWOPT_PRESETS["TH1"]


