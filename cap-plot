    # -- file / tree population ------------------------------------------

    def _populate_initial(self, start_dir: Path):
        """Auto-add every .root in start_dir.  Updates the title regardless
        so the user can tell where they're looking."""
        roots = sorted(start_dir.glob("*.root")) if start_dir.is_dir() else []
        for f in roots:
            self._add_file(f)
        self.root.title(
            f"CAP — plot browser  ·  {start_dir}   "
            f"({len(roots)} file{'s' if len(roots) != 1 else ''})")
        if start_dir.is_dir() and not roots:
            self.status_var.set(f"No .root files in {start_dir}.")

    def _reset_state(self):
        """Wipe everything in the current view but keep window/process alive."""
        for f in self.files.values():
            try: f.Close()
            except Exception: pass
        self.files.clear()
        self.specs.clear()
        self.tree_state.clear()
        self._lazy_placeholders.clear()
        self._checked_memory.clear()
        for iid in self.tree.get_children(""):
            self.tree.delete(iid)
        for iid in self.spec_tree.get_children(""):
            self.spec_tree.delete(iid)
        # Drop any cached image so a <Configure> resize doesn't redraw
        # the previous folder's plot in the wiped state.
        self.last_png = None
        self._image_ref = None
        self.plot_label.configure(image="",
            text="Tick histograms on the left, then click Draw.")

    def _browse_folder(self):
        d = filedialog.askdirectory(title="Pick folder with .root files",
                                    initialdir=str(self.start_dir))
        if not d:
            return
        self.start_dir = Path(d)
        self._reset_state()
        self._populate_initial(self.start_dir)

    def _add_file_dialog(self):
        f = filedialog.askopenfilename(
            title="Open .root file", initialdir=str(self.start_dir),
            filetypes=[("ROOT files", "*.root"), ("All", "*.*")])
        if f:
            self._add_file(Path(f))

    def _add_file(self, path: Path):
        path_s = str(path.resolve())
        if path_s in self.files:
            return
        try:
            f = ROOT.TFile.Open(path_s, "READ")
            if not f or f.IsZombie():
                raise RuntimeError("could not open")
        except Exception as exc:
            messagebox.showerror("cap-plot", f"Could not open {path}: {exc}")
            return
        self.files[path_s] = f
        # Show: how many top-level keys are in there so the user has a hint
        # of what's behind the closed node.
        n_keys = len(f.GetListOfKeys())
        node = self.tree.insert(
            "", "end",
            text=f"📄 {path.name}   ({n_keys} entries)",
            open=False)
        # Track parent explicitly — Tk's tree.parent(iid) behavior for
        # detached items is documented but we don't want to depend on
        # it.  Storing here makes _apply_filter robust.
        self.tree_state[node] = {"kind": "file", "file": path_s,
                                  "path": "", "checked": False,
                                  "parent": ""}
        self._add_lazy_placeholder(node)
        self.status_var.set(f"Loaded {path.name} ({n_keys} entries).")
        # Auto-restore: if anything in this file was checked before,
        # walk the saved paths now so the user doesn't have to click
        # through directories before drawing.
        wanted_paths = {p for (fp, p) in self._checked_memory if fp == path_s}
        if wanted_paths:
            self._auto_expand_for(node, wanted_paths)

    def _add_lazy_placeholder(self, parent_iid: str):
        ph = self.tree.insert(parent_iid, "end", text="  …loading…")
        self._lazy_placeholders.add(ph)

    def _auto_expand_for(self, file_node: str, wanted_paths: set):
        """Walk every directory along the way to wanted_paths so the
        leaf histograms get inserted into the tree (and hence get their
        was_checked tick restored).  Called after _add_file when there
        are remembered selections in this file."""
        # Collect the set of directory prefixes we need to expand,
        # e.g. wanted_path "dir1/sub/h" → expand "dir1" and "dir1/sub".
        dir_prefixes: set[str] = set()
        for p in wanted_paths:
            parts = p.split("/")
            for k in range(1, len(parts)):
                dir_prefixes.add("/".join(parts[:k]))
        # Walk from file_node depth-first, expanding any dir whose path
        # is in dir_prefixes — also expand the file itself.
        def walk(parent: str):
            kids = list(self.tree.get_children(parent))
            # Force populate if the only child is a placeholder.
            if len(kids) == 1 and kids[0] in self._lazy_placeholders:
                ph = kids[0]
                try: self.tree.delete(ph)
                except tk.TclError: pass
                self._lazy_placeholders.discard(ph)
                self._populate_one_level(parent)
                kids = list(self.tree.get_children(parent))
            for k in kids:
                kst = self.tree_state.get(k)
                if not kst: continue
                if kst["kind"] == "dir" and kst["path"] in dir_prefixes:
                    walk(k)
        walk(file_node)

    def _on_tree_open(self, _ev):
        """Expand a node lazily — list one level deeper.  Called every time
        a node is opened; we only do real work the first time, when the
        sole child is the placeholder we inserted at insert-time."""
        iid = self.tree.focus()
        children = self.tree.get_children(iid)
        # If this node has the placeholder as its only child, populate.
        if len(children) == 1 and children[0] in self._lazy_placeholders:
            ph = children[0]
            self.tree.delete(ph); self._lazy_placeholders.discard(ph)
            self._populate_one_level(iid)

    def _populate_one_level(self, parent_iid: str):
        """Read keys for the directory `parent_iid` represents and add
        one Treeview row per child, without recursing."""
        st = self.tree_state.get(parent_iid)
        if not st: return
        tf = self.files.get(st["file"])
        if tf is None: return
        # Resolve the in-file directory.
        if st["path"]:
            tdir = tf.Get(st["path"])
        else:
            tdir = tf
        if tdir is None or not hasattr(tdir, "GetListOfKeys"):
            return
        self._defer_refresh = False

        # Collect all keys then sort: directories first, then by name.
        plot_classes = ("TH1", "TH2", "TH3", "TProfile",
                        "TProfile2D", "TGraph", "TF1")
        items = []
        for key in tdir.GetListOfKeys():
            name = key.GetName()
            cls  = key.GetClassName()
            if cls.startswith("TDirectory"):
                items.append((0, name, cls))
            elif any(cls.startswith(c) for c in plot_classes):
                items.append((1, name, cls))
            # everything else: skipped (TList, TParameter, etc.)
        items.sort(key=lambda t: (t[0], t[1].lower()))

        for kind_rank, name, classname in items:
            full_path = f"{st['path']}/{name}" if st["path"] else name
            if kind_rank == 0:
                node = self.tree.insert(parent_iid, "end",
                                         text=f"📁 {name}", open=False)
                self.tree_state[node] = {"kind": "dir",
                                          "file": st["file"],
                                          "path": full_path,
                                          "checked": False,
                                          "parent": parent_iid}
                self._add_lazy_placeholder(node)
            else:
                # If this histogram was ticked before a reload, restore.
                was_checked = (st["file"], full_path) in self._checked_memory
                mark = "☑" if was_checked else "☐"
                node = self.tree.insert(parent_iid, "end",
                                         text=f"{mark} {name}   [{classname}]")
                self.tree_state[node] = {"kind": "histo",
                                          "file": st["file"],
                                          "path": full_path,
                                          "checked": was_checked,
                                          "classname": classname,
                                          "name": name,
                                          "parent": parent_iid}
                if was_checked:
                    self._defer_refresh = True
        # Batch the refresh: many restores in one populate call →
        # one _refresh_specs at the end (was O(n²) before).
        if getattr(self, "_defer_refresh", False):
            self._defer_refresh = False
            self._refresh_specs()
        # If a search is active, re-apply so newly populated children
        # respect the current filter.
        if self.filter_var.get().strip():
            self._schedule_filter()

    def _reload_all(self):
        # Close & reopen every file from scratch — picks up freshly written histos.
        paths = list(self.files.keys())
        for f in self.files.values():
            try: f.Close()
            except Exception: pass
        self.files.clear()
        self.tree_state.clear()
        self._lazy_placeholders.clear()
        for iid in self.tree.get_children(""):
            self.tree.delete(iid)
        for p in paths:
            self._add_file(Path(p))

    # -- tree click handling ---------------------------------------------

    def _on_tree_click(self, ev):
        iid = self.tree.identify_row(ev.y)
        if not iid: return
        st = self.tree_state.get(iid)
        if not st: return
        # Only treat clicks on the indicator area (first ~20px) as toggles
        # for histograms.  Files/dirs toggle on click anywhere except text.
        if st["kind"] == "histo" and ev.x < 30:
            self._toggle_check(iid)

    def _on_tree_double(self, ev):
        iid = self.tree.identify_row(ev.y)
        if not iid: return
        st = self.tree_state.get(iid)
        if not st: return
        if st["kind"] == "histo":
            self._toggle_check(iid)

    def _toggle_check(self, iid: str):
        st = self.tree_state[iid]
        st["checked"] = not st["checked"]
        text = self.tree.item(iid, "text")
        if st["kind"] == "histo":
            new_text = text.replace("☐", "☑") if st["checked"] \
                       else text.replace("☑", "☐")
            self.tree.item(iid, text=new_text)
            # Remember choice across reloads.
            key = (st["file"], st["path"])
            if st["checked"]:
                self._checked_memory.add(key)
            else:
                self._checked_memory.discard(key)
            self._refresh_specs()

    def _refresh_specs(self):
        # Build the spec list from currently-checked tree items.
        # Keep style choices for entries that already existed.
        old_by_key = {(s.file, s.path): s for s in self.specs}
        self.specs.clear()
        for iid, st in self.tree_state.items():
            if st["kind"] != "histo" or not st["checked"]:
                continue
            label = f"{Path(st['file']).name} :: {st['path']}"
            spec = old_by_key.get((st["file"], st["path"]))
            if spec is None:
                spec = DrawSpec(st["file"], st["path"], label,
                                classname=st.get("classname", "TH1"))
                # auto-rotate color for variety
                spec.color = COLOR_NAMES[len(self.specs) % len(COLOR_NAMES)]
            self.specs.append(spec)

        for i in self.spec_tree.get_children(""):
            self.spec_tree.delete(i)
        for spec in self.specs:
            self.spec_tree.insert("", "end", values=(
                spec.label, spec.color, spec.marker, spec.marker_size,
                spec.line_style, spec.line_width, spec.draw_opt))

    def _schedule_filter(self):
        """Debounce: re-run _apply_filter ~200 ms after the last keystroke."""
        if self._filter_after_id:
            try: self.root.after_cancel(self._filter_after_id)
            except Exception: pass
        self._filter_after_id = self.root.after(200, self._apply_filter)

    def _apply_filter(self):
        """Show only rows that match the search query, plus their
        ancestors.  Strategy: stamp every iid with a `match` (this row
        matches) or `descend` (an ancestor of a match) tag, then walk
        parent→children recursively and detach the rest.  We never need
        to re-attach in a specific order because we don't move items —
        we only detach mismatches.  Placeholders stay attached so
        users can still expand directories."""
        self._filter_after_id = None
        q = self.filter_var.get().strip().lower()

        # When a query is active, force-expand any unexpanded files /
        # directories so the search reaches their contents.  Recurse
        # because expanding one dir may surface sub-dirs that also
        # carry placeholders.  Bounded by max_iters so a pathological
        # file structure can't lock the GUI.
        if q:
            for _ in range(8):     # 8 levels of nesting is plenty
                iids = [iid for iid, st in list(self.tree_state.items())
                        if st["kind"] in ("file", "dir")]
                expanded_any = False
                for iid in iids:
                    kids = self.tree.get_children(iid)
                    if len(kids) == 1 and kids[0] in self._lazy_placeholders:
                        ph = kids[0]
                        try: self.tree.delete(ph)
                        except tk.TclError: pass
                        self._lazy_placeholders.discard(ph)
                        self._populate_one_level(iid)
                        expanded_any = True
                if not expanded_any:
                    break

        # Decide which iids should stay visible.  Use the parent we
        # recorded in tree_state when each row was inserted — Tk's own
        # tree.parent(iid) is unreliable for currently-detached items,
        # so we keep our own copy.
        keep: set[str] = set()
        if not q:
            keep = set(self.tree_state.keys()) | self._lazy_placeholders
        else:
            for iid, st in self.tree_state.items():
                if st["kind"] != "histo":
                    continue
                text = self.tree.item(iid, "text").lower()
                if q in text or q in st.get("path", "").lower():
                    keep.add(iid)
                    # ancestors via recorded parent chain
                    p = st.get("parent", "")
                    while p:
                        keep.add(p)
                        p = self.tree_state.get(p, {}).get("parent", "")

        # Apply: walk our own state in insertion order so reattach
        # produces the original layout.  CPython 3.7+ guarantees dict
        # iteration is insertion order; we rely on that.
        for iid, st in list(self.tree_state.items()):
            parent = st.get("parent", "")
            try:
                if iid in keep:
                    self.tree.reattach(iid, parent, "end")
                else:
                    self.tree.detach(iid)
            except tk.TclError:
                pass

    def _dir_has_match(self, iid: str, q: str) -> bool:
        # Force-expand lazily so the search reaches inside.
        children = self.tree.get_children(iid)
        if len(children) == 1 and children[0] in self._lazy_placeholders:
            ph = children[0]
            self.tree.delete(ph); self._lazy_placeholders.discard(ph)
            self._populate_one_level(iid)
            children = self.tree.get_children(iid)
        for child in children:
            cst = self.tree_state.get(child, {})
            if cst.get("kind") == "histo" and \
               (q in self.tree.item(child, "text").lower()
                or q in cst.get("path", "").lower()):
                return True
            if cst.get("kind") == "dir" and self._dir_has_match(child, q):
                return True
        return False

    def _maybe_edit_on_click(self, ev):
        """Open the editor on a SINGLE click for any non-label column.
        That removes the 'is this clickable?' uncertainty.  Label
        column (#1) is selectable for highlighting only."""
        item = self.spec_tree.identify_row(ev.y)
        col  = self.spec_tree.identify_column(ev.x)
        if not item: return
        if col in ("#0", "#1", ""):  # label or tree column
            return
        self._edit_spec_cell(ev)

    def _edit_spec_cell(self, ev):
        item = self.spec_tree.identify_row(ev.y)
        col  = self.spec_tree.identify_column(ev.x)
        if not item: return
        # Hide the helper hint once the user has interacted with a cell.
        if getattr(self, "spec_hint", None) is not None:
            try:
                self.spec_hint.pack_forget()
                self.spec_hint = None
            except Exception:
                pass
        idx = self.spec_tree.index(item)
        if idx >= len(self.specs): return
        spec = self.specs[idx]
        col_id = int(col.replace("#", ""))    # 1-based
        if col_id == 2:    # color (named + custom RGB at the end)
            choices = COLOR_NAMES + [CUSTOM_COLOR_LABEL]
            self._popup_picker(item, "color", choices, spec, col_id,
                               on_commit=self._maybe_pick_custom_color)
        elif col_id == 3:  # marker
            self._popup_picker(item, "marker", MARKER_LABELS, spec, col_id)
        elif col_id == 4:  # marker size (0.0–10.0 free entry)
            self._popup_text(item, "marker_size", spec, col_id)
        elif col_id == 5:  # line style
            self._popup_picker(item, "line_style", LINESTYLE_LABELS,
                               spec, col_id)
        elif col_id == 6:  # line width
            self._popup_text(item, "line_width", spec, col_id)
        elif col_id == 7:  # draw opt — class-aware preset combobox,
                           # editable so power users can type combos
                           # like 'COLZ TEXT' or 'HIST E1'.
            self._popup_picker(item, "draw_opt",
                               drawopt_choices_for(spec.classname),
                               spec, col_id, readonly=False)

    def _maybe_pick_custom_color(self, spec):
        """Called by _popup_picker when the color cell commits.  If the
        user picked CUSTOM_COLOR_LABEL, open Tk's color wheel and store
        the resulting #rrggbb (color_to_root_index will turn it into
        a TColor index at render time)."""
        if spec.color != CUSTOM_COLOR_LABEL:
            return
        try:
            initial = "#000000"
            (_, hex_str) = colorchooser.askcolor(
                title="Pick custom color (RGB)", initialcolor=initial,
                parent=self.root)
            if hex_str:
                spec.color = hex_str
            else:
                spec.color = "black"
        except Exception:
            spec.color = "black"
        self._refresh_specs_table_only()

    def _popup_picker(self, item, attr, choices, spec, col_id,
                      readonly=True, on_commit=None):
        """Per-cell editor.  When readonly=False (used for draw_opt) the
        combobox accepts free-text too — a power user can type
        'COLZ TEXT' instead of being limited to single presets.
        on_commit, if given, is called with the spec after the new
        value has been written — used by the custom-RGB hook."""
        top = tk.Toplevel(self.root)
        top.title(f"{attr}…")
        top.transient(self.root)
        top.resizable(False, False)
        bbox = self.spec_tree.bbox(item, column=f"#{col_id}")
        if bbox:
            x, y, _, _ = bbox
            top.geometry(f"+{self.spec_tree.winfo_rootx()+x}"
                         f"+{self.spec_tree.winfo_rooty()+y+24}")
        var = tk.StringVar(value=getattr(spec, attr))
        ttk.Label(top, text=f"Choose {attr}:").pack(padx=8, pady=(8, 2))
        cb = ttk.Combobox(top, textvariable=var, values=choices,
                          state=("readonly" if readonly else "normal"),
                          width=24)
        cb.pack(padx=8, pady=4)
        cb.focus_set()
        if not readonly:
            cb.icursor(tk.END); cb.select_range(0, tk.END)
        def commit(_=None):
            setattr(spec, attr, var.get())
            top.destroy()
            self._refresh_specs_table_only()
            if on_commit is not None:
                try: on_commit(spec)
                except Exception: pass
        bf = ttk.Frame(top); bf.pack(pady=6)
        ttk.Button(bf, text="OK", command=commit).pack(side=tk.LEFT, padx=4)
        ttk.Button(bf, text="Cancel",
                   command=top.destroy).pack(side=tk.LEFT, padx=4)
        top.bind("<Return>", commit)
        top.bind("<Escape>", lambda e: top.destroy())
        cb.bind("<<ComboboxSelected>>", commit)
        top.grab_set()      # modal — keeps Tk happy on macOS

    def _popup_text(self, item, attr, spec, col_id):
        top = tk.Toplevel(self.root)
        top.title(f"{attr}…")
        top.transient(self.root)
        top.resizable(False, False)
        bbox = self.spec_tree.bbox(item, column=f"#{col_id}")
        if bbox:
            x, y, _, _ = bbox
            top.geometry(f"+{self.spec_tree.winfo_rootx()+x}"
                         f"+{self.spec_tree.winfo_rooty()+y+24}")
        var = tk.StringVar(value=getattr(spec, attr))
        ttk.Label(top, text=f"Edit {attr}:").pack(padx=8, pady=(8, 2))
        e = ttk.Entry(top, textvariable=var, width=24)
        e.pack(padx=8, pady=4)
        e.focus_set(); e.icursor(tk.END); e.select_range(0, tk.END)
        def commit(_=None):
            setattr(spec, attr, var.get())
            top.destroy()
            self._refresh_specs_table_only()
        bf = ttk.Frame(top); bf.pack(pady=6)
        ttk.Button(bf, text="OK", command=commit).pack(side=tk.LEFT, padx=4)
        ttk.Button(bf, text="Cancel",
                   command=top.destroy).pack(side=tk.LEFT, padx=4)
        top.bind("<Return>", commit)
        top.bind("<Escape>", lambda e: top.destroy())
        top.grab_set()

    def _refresh_specs_table_only(self):
        for i, spec in enumerate(self.specs):
            iids = self.spec_tree.get_children("")
            if i < len(iids):
                self.spec_tree.item(iids[i], values=(
                    spec.label, spec.color, spec.marker, spec.marker_size,
                    spec.line_style, spec.line_width, spec.draw_opt))

    def _clear_selection(self):
        for iid, st in self.tree_state.items():
            if st["kind"] == "histo" and st["checked"]:
                st["checked"] = False
                txt = self.tree.item(iid, "text").replace("☑", "☐")
                self.tree.item(iid, text=txt)
        self.specs.clear()
        for iid in self.spec_tree.get_children(""):
            self.spec_tree.delete(iid)

    # -- drawing ---------------------------------------------------------

    def _draw(self):
        if not self.specs:
            self.status_var.set("Nothing selected.")
            return
        try:
            drawn = self._render()
        except Exception as exc:
            import traceback
            tb = traceback.format_exc()
            traceback.print_exc()
            # Show the user a more useful dialog — they can copy/paste
            # the full trace if reporting back.
            messagebox.showerror(
                "cap-plot — draw failed",
                f"{type(exc).__name__}: {exc}\n\n"
                f"--- traceback ---\n{tb}")
            self.status_var.set(f"Draw failed: {type(exc).__name__}")
            return
        if self.last_png and self.last_png.is_file():
            self._show_png(self.last_png)
        n = len(self.specs)
        same = (self.mode_var.get() == self.SAME)
        if not same:
            n_pads = max(1, int(self.cols_var.get())) \
                     * max(1, int(self.rows_var.get()))
            extra = max(0, n - n_pads)
            self.status_var.set(
                f"Drew {drawn} of {n} (grid {n_pads} pads)" +
                (f" — {extra} skipped, increase rows/cols." if extra else "."))
        else:
            missing = n - drawn
            self.status_var.set(
                f"Drew {drawn} of {n} overlaid" +
                (f" — {missing} could not be loaded." if missing else "."))

    def _show_png(self, png: Path, retries: int = 5):
        """Render the PNG into the plot label, scaled to fit the panel.
        On the first draw the panel hasn't been laid out yet, so we
        defer to after_idle so winfo_width()/height() are usable.
        Cap the retry count so a minimized / hidden window doesn't
        spin forever."""
        self.plot_label.update_idletasks()
        if (self.plot_label.winfo_width() <= 1 or
            self.plot_label.winfo_height() <= 1) and retries > 0:
            self.root.after(50,
                lambda: self._show_png(png, retries - 1))
            return
        try:
            box_w = max(200, self.plot_label.winfo_width() - 8)
            box_h = max(200, self.plot_label.winfo_height() - 8)
            if HAVE_PIL:
                im = Image.open(str(png))
                iw, ih = im.size
                scale = min(box_w / iw, box_h / ih, 1.0)
                if scale < 1.0:
                    im = im.resize((int(iw * scale), int(ih * scale)),
                                    LANCZOS)
                tkimg = ImageTk.PhotoImage(im)
            else:
                # Some macOS Tk 8.6 builds choke on certain PNG variants
                # (interlaced, grayscale, alpha).  If PhotoImage fails,
                # fall back to re-rendering the canvas as a GIF — Tk's
                # GIF reader is rock solid on every platform.
                try:
                    tkimg = tk.PhotoImage(file=str(png))
                except tk.TclError:
                    gif = png.with_suffix(".gif")
                    self._save_canvas_as(gif)
                    tkimg = tk.PhotoImage(file=str(gif))
                # Fall back to subsample (integer-only) if the image is
                # bigger than the panel.
                iw, ih = tkimg.width(), tkimg.height()
                f = max(1, max(iw // box_w, ih // box_h, 1))
                if f > 1:
                    tkimg = tkimg.subsample(f, f)
            self._image_ref = tkimg
            self.plot_label.configure(image=tkimg, text="")
        except Exception as exc:
            self.plot_label.configure(image="", text=f"PNG load failed: {exc}")

    def _save_canvas_as(self, target: Path):
        """Re-emit the most recent canvas in a different format
        (.gif/.eps/.svg).  Used by the GIF fallback path when Tk
        rejects the original PNG."""
        c = getattr(self, "_last_canvas", None)
        if c is None: return
        try: c.SaveAs(str(target))
        except Exception: pass

    def _on_plot_resize(self, _ev):
        """Re-fit the cached PNG when the user resizes the window.
        Debounced so a drag doesn't re-render on every motion event."""
        if not self.last_png or not self.last_png.is_file():
            return
        if self._resize_after_id:
            try: self.root.after_cancel(self._resize_after_id)
            except Exception: pass
        self._resize_after_id = self.root.after(
            120, lambda: self._show_png(self.last_png))

    def _next_canvas_name(self):
        """Each draw makes a fresh TCanvas — same name across calls makes
        ROOT replace and warn.  Keep a counter."""
        self._canvas_counter = getattr(self, "_canvas_counter", 0) + 1
        return f"capplot_{self._canvas_counter}"

    def _resolve_object(self, tf, path: str):
        """Robust replacement for `tf.Get(path)`.  PyROOT's Get is happy
        with `dir/sub/h` on most ROOT versions but failures fall back
        to walking the directory chain by hand, which never depends on
        slash-aware lookups."""
        # Strip any cycle suffix (e.g. "h;1") that crept into the path.
        clean = path.split(";")[0]
        try:
            obj = tf.Get(clean)
            if obj:
                return obj
        except Exception:
            pass
        # Walk the chain manually.
        parts = [p for p in clean.split("/") if p]
        node = tf
        for p in parts[:-1]:
            try:
                nxt = node.Get(p)
            except Exception:
                return None
            if nxt is None or not hasattr(nxt, "GetListOfKeys"):
                return None
            node = nxt
        if not parts:
            return None
        try:
            return node.Get(parts[-1])
        except Exception:
            return None

    def _render(self, save_path: str | None = None):
        """Render specs into a TCanvas.  If save_path is given, write the
        canvas there directly instead of the temp PNG.  Returns the
        number of histograms that actually drew (some Get() calls can
        return null if the file changed underneath us)."""
        # Close the previous canvas if any — keeps long sessions from
        # accumulating canvases in ROOT's global registry.  We only
        # keep the most recent one so the GIF fallback can re-emit it.
        prev = getattr(self, "_last_canvas", None)
        if prev is not None:
            try: prev.Close()
            except Exception: pass
            self._last_canvas = None
        same = (self.mode_var.get() == self.SAME)
        cols = max(1, int(self.cols_var.get()))
        rows = max(1, int(self.rows_var.get()))
        if same:
            cols = rows = 1
        # Same-mode dimensional sanity: refuse to overlay TH1 with
        # TH2/TH3 unless the user explicitly opts in via the
        # "force overlay" check.  ROOT will silently produce nonsense
        # otherwise (the SAME pad inherits the first hist's geometry).
        if same and not self.force_overlay_var.get():
            dims = {class_dim(s.classname) for s in self.specs}
            dims.discard(0)
            if len(dims) > 1:
                raise ValueError(
                    f"Cannot overlay histograms of different dimensions "
                    f"({sorted(dims)}).  Either switch to Separate mode "
                    f"or tick 'force overlay (mixed dims)' to override.")
        # Higher-quality preview — match the save resolution (was 540×420).
        per_w, per_h = 800, 600
        cw, ch = per_w * cols, per_h * rows
        c = ROOT.TCanvas(self._next_canvas_name(), "cap-plot", cw, ch)
        self._last_canvas = c
        if not same:
            c.Divide(cols, rows)

        legend = None
        if self.legend_var.get():
            pos_label = getattr(self, "_legend_pos_label",
                                self._LEGEND_POS_LABELS[0])
            preset = self._LEGEND_POS.get(pos_label)
            if preset is None:
                # "custom" — fall back to the four NDC entries; reject
                # malformed values and revert to the default preset.
                def _f(v, dflt):
                    try:
                        f = float(v)
                        if 0.0 <= f <= 1.0: return f
                    except (TypeError, ValueError): pass
                    return dflt
                x1 = _f(self.legend_x1_var.get(), 0.62)
                y1 = _f(self.legend_y1_var.get(), 0.74)
                x2 = _f(self.legend_x2_var.get(), 0.94)
                y2 = _f(self.legend_y2_var.get(), 0.92)
                # Sanity: x2 must be > x1 and y2 > y1.
                if x2 <= x1 or y2 <= y1:
                    x1, y1, x2, y2 = 0.62, 0.74, 0.94, 0.92
            else:
                x1, y1, x2, y2 = preset
            legend = ROOT.TLegend(x1, y1, x2, y2)
            legend.SetBorderSize(1 if self.legend_border_var.get() else 0)
            # Transparent background regardless of border so the data
            # behind it remains readable.
            legend.SetFillStyle(0)
            try: ts = max(0.005, min(0.2, float(self.legend_textsize_var.get())))
            except (TypeError, ValueError): ts = 0.03
            legend.SetTextSize(ts)

        n_pads = cols * rows
        held = []        # keep TH refs alive across the loop
        drawn = 0        # actually-rendered count
        # In Same-mode, ROOT keeps the y-range of whichever histo we
        # drew first.  Pre-scan to find the global max and apply it
        # before SAME draws so subsequent histos aren't visually clipped.
        # Skip TGraph/TF1 — those don't have a meaningful "max" the
        # same way TH1 does, and calling GetMaximum on them via
        # PyROOT can raise.
        global_max = None
        if same:
            for spec in self.specs:
                if spec.classname.startswith(("TGraph", "TF1",
                                               "TH2", "TH3",
                                               "TProfile2D")):
                    continue
                tf = self.files.get(spec.file)
                if tf is None:
                    continue
                obj = self._resolve_object(tf, spec.path)
                if obj is None or not hasattr(obj, "GetMaximum"):
                    continue
                try:
                    m = obj.GetMaximum()
                    if global_max is None or m > global_max:
                        global_max = m
                except Exception:
                    pass

        for i, spec in enumerate(self.specs):
            tf = self.files.get(spec.file)
            if tf is None:
                continue
            obj = self._resolve_object(tf, spec.path)
            if obj is None:
                continue
            try:
                obj = obj.Clone(f"capplot_obj_{self._canvas_counter}_{i}")
            except Exception:
                # Some ROOT objects may not be cloneable (e.g. exotic
                # TF1 setups).  Use the original — it'll mutate state
                # in the file but that's a recoverable downside.
                pass
            held.append(obj)
            color = color_to_root_index(spec.color)
            marker = MARKER_BY_LABEL.get(spec.marker, 20)
            line_style = LINESTYLE_BY_LABEL.get(spec.line_style, 1)
            try: line_w = max(1, min(20, int(spec.line_width)))
            except (TypeError, ValueError): line_w = 2
            try: msize = float(spec.marker_size)
            except (TypeError, ValueError): msize = 0.9
            try:
                obj.SetLineColor(color)
                obj.SetLineStyle(line_style)
                obj.SetLineWidth(line_w)
                obj.SetMarkerColor(color)
                obj.SetMarkerStyle(marker)
                obj.SetMarkerSize(msize)
                obj.SetStats(0)
            except Exception:
                pass
            # Plot (top-of-pad) title — applied per object so SAME
            # mode picks up the first hist's title.
            if self.plot_title_var.get():
                try: obj.SetTitle(self.plot_title_var.get())
                except Exception: pass
            if self.xtitle_var.get():
                try: obj.GetXaxis().SetTitle(self.xtitle_var.get())
                except Exception: pass
            if self.ytitle_var.get():
                try: obj.GetYaxis().SetTitle(self.ytitle_var.get())
                except Exception: pass
            # Z axis only exists on TH2/TH3-family classes — guard.
            if self.ztitle_var.get() and hasattr(obj, "GetZaxis"):
                try: obj.GetZaxis().SetTitle(self.ztitle_var.get())
                except Exception: pass
            # Axis title offsets — accept blank/garbage gracefully.
            def _f(v):
                try: return float(v)
                except (TypeError, ValueError): return None
            xoff = _f(self.xtitle_off_var.get())
            yoff = _f(self.ytitle_off_var.get())
            zoff = _f(self.ztitle_off_var.get())
            if xoff is not None:
                try: obj.GetXaxis().SetTitleOffset(xoff)
                except Exception: pass
            if yoff is not None:
                try: obj.GetYaxis().SetTitleOffset(yoff)
                except Exception: pass
            if zoff is not None and hasattr(obj, "GetZaxis"):
                try: obj.GetZaxis().SetTitleOffset(zoff)
                except Exception: pass
            # Apply user-set axis ranges via SetRangeUser (requires
            # numeric input; blank = leave as is).
            self._apply_user_range(obj)
            # Decide on the actual draw option, honouring the global
            # error-bars toggle.  If unticked: strip leading "E*" tokens
            # and use HIST instead — applies only to TH1-family classes
            # where errors make sense.
            opt = spec.draw_opt or default_draw_opt(spec.classname)
            if class_dim(spec.classname) == 1 and \
               not spec.classname.startswith(("TGraph", "TF1")):
                if not self.errbars_var.get():
                    # Drop standalone "E", "E0".."E9", "EX0", keep HIST/L/P
                    parts = [p for p in opt.split()
                             if not (p.upper().startswith("E") and len(p) <= 3)]
                    if "HIST" not in [p.upper() for p in parts]:
                        parts.insert(0, "HIST")
                    opt = " ".join(parts)
            # 3D wire mesh suppression — for TH2/TH3 plots drawn in
            # SURF/LEGO/BOX modes the histogram's line attributes
            # produce the wire frame.  When the toggle is off, set
            # line width to 0 so the surface stays smooth (and respect
            # the user's chosen line color anyway, in case ROOT still
            # sketches an outline).
            if not self.wire3d_var.get():
                up = opt.upper()
                if any(t in up for t in ("SURF", "LEGO", "BOX", "GLBOX",
                                          "ISO", "CONT")):
                    try: obj.SetLineWidth(0)
                    except Exception: pass
            if same:
                # Bump y-max for the FIRST hist before draw; subsequent
                # SAME draws inherit the axis limits.  Add 10% headroom.
                if i == 0 and global_max is not None and \
                   hasattr(obj, "SetMaximum"):
                    try: obj.SetMaximum(global_max * 1.1)
                    except Exception: pass
                c.cd()
                obj.Draw(opt + (" SAME" if i else ""))
                pad = c
            else:
                if i >= n_pads:
                    break
                pad = c.cd(i + 1)
                obj.Draw(opt)
            self._apply_pad_options(pad)
            if legend is not None and getattr(spec, "in_legend", True):
                # Per-spec custom label takes precedence; default = short
                # 'file_stem::leaf' label.
                short = (spec.legend_label.strip()
                         if getattr(spec, "legend_label", "")
                         else f"{Path(spec.file).stem}::"
                              f"{Path(spec.path).name}")
                legend.AddEntry(obj, short, "lp")
            drawn += 1

        if legend is not None and same and drawn > 0:
            c.cd()
            # Legend title comes from the designer's plot_legend_title_var.
            ttl = getattr(self, "legend_title_var", None)
            if ttl is not None and ttl.get().strip():
                legend.SetHeader(ttl.get().strip(), "C")
            legend.Draw()

        out = save_path if save_path else \
              str(self.tmpdir / f"plot_{self._canvas_counter}.png")
        c.SaveAs(out)
        if not save_path:
            self.last_png = Path(out)
        del held
        return drawn

    def _apply_user_range(self, obj):
        """Apply X/Y/Z ranges from the entry boxes if non-empty.  Empty
        or non-numeric fields leave the corresponding axis at auto."""
        def _f(v):
            try: return float(v)
            except (TypeError, ValueError): return None
        xmin, xmax = _f(self.xmin_var.get()), _f(self.xmax_var.get())
        ymin, ymax = _f(self.ymin_var.get()), _f(self.ymax_var.get())
        zmin, zmax = _f(self.zmin_var.get()), _f(self.zmax_var.get())
        if xmin is not None and xmax is not None and xmax > xmin:
            try: obj.GetXaxis().SetRangeUser(xmin, xmax)
            except Exception: pass
        if ymin is not None and ymax is not None and ymax > ymin:
            try:
                if hasattr(obj, "GetYaxis"):
                    obj.GetYaxis().SetRangeUser(ymin, ymax)
            except Exception: pass
        # Z range — TH2/TH3 use it for COLZ scale and 3D height; TH1
        # has no Z axis so we just skip via hasattr.
        if zmin is not None and zmax is not None and zmax > zmin \
           and hasattr(obj, "GetZaxis"):
            try:
                obj.GetZaxis().SetRangeUser(zmin, zmax)
                # For 2D color plots SetMinimum/Maximum is what
                # actually clips the colour scale; set both to be sure.
                if hasattr(obj, "SetMinimum"): obj.SetMinimum(zmin)
                if hasattr(obj, "SetMaximum"): obj.SetMaximum(zmax)
            except Exception: pass

    def _reset_ranges(self):
        """Clear all six range entries — restores auto axis ranges."""
        for v in (self.xmin_var, self.xmax_var,
                  self.ymin_var, self.ymax_var,
                  self.zmin_var, self.zmax_var):
            v.set("")
        self.status_var.set("Axis ranges reset to auto.")

    # Legend positions — NDC corners (x1, y1, x2, y2).
    # The "custom (use NDC entries)" sentinel switches the renderer to
    # using the four legend_x1/x2/y1/y2 entry boxes from the designer.
    _LEGEND_POS = {
        "top-right (default)":   (0.62, 0.74, 0.94, 0.92),
        "top-left":              (0.12, 0.74, 0.45, 0.92),
        "bottom-right":          (0.62, 0.12, 0.94, 0.30),
        "bottom-left":           (0.12, 0.12, 0.45, 0.30),
        "centre-right":          (0.65, 0.45, 0.95, 0.65),
        "custom (use NDC entries)": None,
    }
    _LEGEND_POS_LABELS = list(_LEGEND_POS.keys())

    # ---- TLatex symbol palette ----------------------------------------
    def _track_focus(self, ev):
        """Remember the most recent Entry / Combobox so the symbol
        palette knows which widget to insert into.  Trees, buttons,
        labels are filtered out — they don't accept text input."""
        try:
            cls = ev.widget.winfo_class()
        except Exception:
            return
        if cls in ("TEntry", "Entry", "TCombobox", "Text"):
            self._last_text_widget = ev.widget

    def _insert_at_focus(self, code: str):
        """Insert `code` into the last-focused entry at the cursor.
        If the code includes braces (`{}`), place the cursor between
        them so the user can type the argument right away."""
        w = getattr(self, "_last_text_widget", None)
        if w is None:
            messagebox.showinfo(
                "TLatex symbols",
                f"Click into a title or legend field first, then "
                f"open this palette and click a symbol.\n\n"
                f"Code: {code}")
            return
        try:
            # Tk Entry / TEntry / Text all support the same insert API.
            w.focus_set()
            try: pos = w.index("insert")
            except Exception: pos = "end"
            w.insert(pos, code)
            # If the code ends with "{}" or "{}{}", reposition the
            # cursor inside the first empty pair for fluent typing.
            if code.endswith("{}"):
                # Place between the last "{" and "}" we just inserted.
                cursor = w.index("insert")
                # Move one character back so the user types inside {}.
                try: w.icursor(int(str(cursor)) - 1)
                except Exception: pass
            self.status_var.set(f"Inserted: {code}")
        except Exception as exc:
            self.status_var.set(f"Insert failed: {exc}")

    def _open_tlatex_palette(self):
        """Modal symbol palette grouped by category.  Click a button
        → its TLatex code is inserted at the cursor of the last-
        focused text entry."""
        top = tk.Toplevel(self.root)
        top.title("ROOT TLatex symbols")
        top.transient(self.root)
        top.geometry("780x520")
        ttk.Label(top, justify="left",
                  text=("Click any symbol to insert its TLatex code "
                        "into whichever title / legend entry was "
                        "focused last.  Tip: in ROOT TLatex the "
                        "escape character is '#' (not '\\')."),
                  foreground="#444"
                  ).pack(padx=10, pady=(8, 0), anchor="w")
        nb = ttk.Notebook(top); nb.pack(fill=tk.BOTH, expand=True,
                                          padx=10, pady=10)
        for category, items in TLATEX_SYMBOLS.items():
            tab = ttk.Frame(nb); nb.add(tab, text=category)
            # Lay out a grid of buttons with 6 columns.
            for k, (glyph, code) in enumerate(items):
                r, c = divmod(k, 6)
                btn = ttk.Button(tab,
                                 text=f"{glyph}\n{code}",
