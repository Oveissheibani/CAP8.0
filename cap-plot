# ---------------------------------------------------------------------------
#  PyROOT bootstrap — works whether ROOT was installed via brew, conda,
#  CVMFS or built from source.  We trust root-config to point us at the
#  python bindings if `import ROOT` doesn't work out of the box.
# ---------------------------------------------------------------------------

def _bootstrap_pyroot():
    try:
        import ROOT  # noqa: F401
        return ROOT
    except Exception:
        pass
    try:
        libdir = subprocess.check_output(
            ["root-config", "--libdir"], text=True, stderr=subprocess.DEVNULL,
        ).strip()
        if libdir:
            sys.path.insert(0, libdir)
            sys.path.insert(0, str(Path(libdir).parent / "bindings" / "pyroot"))
        import ROOT  # noqa: F401
        return ROOT
    except Exception as exc:
        print(f"cap-plot: cannot import ROOT — {exc}", file=sys.stderr)
        return None


ROOT = _bootstrap_pyroot()
if ROOT is not None:
    ROOT.gROOT.SetBatch(True)
    ROOT.gErrorIgnoreLevel = 1001  # silence ROOT::Info noise

