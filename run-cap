    def _validate_pythia_strings(self, preset, panels, numeric, custom, stable=None, *, ctau_max_mm=None):
        """Spawn a tiny Pythia in dry-init mode to check that all the
        readString() calls succeed.  Uses the Pythia python binding if
        importable; otherwise a no-op return.  For now we just report
        whether the lines parse cleanly."""
        lines = collect_pythia_strings(preset, panels, numeric, custom, stable,
                                       ctau_max_mm=ctau_max_mm)
        if not lines:
            return True, "No strings to validate."
        # Light-weight static check — Pythia readString accepts almost
        # anything textually; we look for obvious malformed lines.
        bad = []
        for ln in lines:
            if "=" not in ln and "(" not in ln and "@" not in ln:
                # Some Pythia commands have no `=` (e.g., "Random:setSeed").
                # Allow those, but reject lines with no recognisable
                # token boundary.
                if ":" not in ln:
                    bad.append(ln)
        if bad:
            return False, ("Possibly malformed:\n  - " +
                           "\n  - ".join(bad[:5]))
        # Actual Pythia dry-init via subprocess would require Pythia
        # CLI — our wrapper doesn't bundle that.  For now we rely on
        # the run-time CAP error message if a string is rejected.
        return True, (f"OK — {len(lines)} strings ready for Pythia.\n"
                      f"They'll be passed via PythiaEventGenerator:Option<n>.")

    def _validate_herwig_lines(self, preset, panels, numeric, custom, stable=None, *, ctau_max_mm=None):
        """Run `Herwig read` on a temp .in containing PPCollider.in +
        the user's lines, capture stderr, return a clean-or-not verdict."""
        import tempfile, subprocess, shutil
        lines = collect_herwig_lines(preset, panels, numeric, custom, stable,
                                     ctau_max_mm=ctau_max_mm)
        if not lines:
            return True, "No lines to validate."
        hw_prefix = os.environ.get(
            "HW_PREFIX", "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        herwig_bin = Path(hw_prefix) / "bin" / "Herwig"
        if not herwig_bin.is_file():
            return False, (f"Herwig binary not found at {herwig_bin} — "
                           f"set HW_PREFIX to enable validation.")
        # Build a minimal .in: pulls in PPCollider, applies our extras,
        # then saverun to /dev/null-ish.  Use a real path because Herwig
        # writes the .run alongside.
        tmp = Path(tempfile.mkdtemp(prefix="cap-validate-"))
        in_path = tmp / "Validate.in"
        try:
            in_path.write_text(
                "read snippets/PPCollider.in\n" +
                "\n".join(lines) + "\n" +
                "saverun Validate EventGenerator\n")
            env_script = Path(hw_prefix) / "herwig-env.sh"
            cmd = (f'source "{env_script}" && cd "{tmp}" && '
                   f'Herwig read "Validate.in"')
            res = subprocess.run(["bash", "-lc", cmd],
                                 capture_output=True, text=True, timeout=60)
            if res.returncode == 0:
                return True, (f"OK — Herwig accepted all "
                              f"{len(lines)} lines.")
            else:
                err = (res.stderr or res.stdout or "").strip()
                tail = err.splitlines()[-15:]
                return False, ("Herwig read failed (rc=%d).  Last lines:\n  "
                               % res.returncode + "\n  ".join(tail))
        except subprocess.TimeoutExpired:
            return False, "Herwig read timed out (>60s)."
        except Exception as exc:
            return False, f"Validation error: {exc}"
        finally:
            try: shutil.rmtree(tmp)
            except OSError: pass

