# ---------------------------------------------------------------------------
#  Logging — same format the bash logger uses, so logs/ is unified
# ---------------------------------------------------------------------------
class RunLogger:
    def __init__(self) -> None:
        ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        self.path = LOGS / f"run-{ts}.log"
        self.lock = threading.Lock()
        self._fh = open(self.path, "w", encoding="utf-8", buffering=1)
        self._fh.write(f"# CAP run log\n")
        self._fh.write(f"# Started   : {datetime.now(timezone.utc).isoformat()}\n")
        self._fh.write(f"# CWD       : {os.getcwd()}\n")
        self._fh.write(f"# Platform  : {sys.platform} {os.uname().machine if hasattr(os, 'uname') else ''}\n")
        self._fh.write("#" + "=" * 68 + "\n\n")
        last = LOGS / "last-run.log"
        try:
            if last.is_symlink() or last.exists():
                last.unlink()
            last.symlink_to(self.path.name)
        except OSError:
            pass

    def line(self, level: str, message: str) -> None:
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")[:-3] + "Z"
        with self.lock:
            self._fh.write(f"[{ts}] [{level}] {message}\n")

    def close(self, exit_code: int = 0) -> None:
        with self.lock:
            self._fh.write("\n#" + "=" * 68 + "\n")
            self._fh.write(f"# Finished  : {datetime.now(timezone.utc).isoformat()}\n")
            self._fh.write(f"# Exit code : {exit_code}\n")
            self._fh.close()


# ---------------------------------------------------------------------------
#  .ini parsing — find the top-level tasks
# ---------------------------------------------------------------------------
def list_projects() -> list[Path]:
    """Return every directory containing at least one .ini, looking in
    both the canonical projects/ tree and the user-built
    analyses/projects/ tree (output of build-ini-gui)."""
    out: list[Path] = []
    for base in (REPO / "projects", REPO / "analyses" / "projects"):
        if not base.is_dir():
            continue
        for path in sorted(base.rglob("*.ini")):
            d = path.parent
            if d not in out:
                out.append(d)
    return out


_LEGACY_RE = re.compile(r"^\s*[A-Za-z_]\w*\s*:\s*SubTaskName[0-9]+\s*=", re.MULTILINE)
_MODERN_RE = re.compile(r"^\s*[A-Za-z_]\w*\s*:\s*Subtask[0-9]+\s*:\s*TaskName\s*=", re.MULTILINE)


def classify_ini(ini_path: Path) -> str:
    """Return 'modern', 'legacy', or 'unknown' based on subtask syntax used.
    Files using the old `Foo:SubTaskName0 = …` format are flagged as legacy
    because the current CAP loader expects `Foo:Subtask0:TaskName = …`."""
    try:
        text = ini_path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return "unknown"
    has_modern = bool(_MODERN_RE.search(text))
    has_legacy = bool(_LEGACY_RE.search(text))
    if has_modern and not has_legacy:
        return "modern"
    if has_legacy and not has_modern:
        return "legacy"
    if has_modern and has_legacy:
        return "modern"            # mixed — give it the benefit of the doubt
    return "unknown"                # no subtasks at all (still valid for some)


def list_inis_for_project(project_dir: Path) -> list[tuple[str, str]]:
    """Return [(display_name, raw_filename), ...] for the project's .ini files.
    Modern files come first, sorted alphabetically with a slight bias toward
    'RunAna*' so the canonical workflow is picked first. Legacy files are
    suffixed with ' (legacy format)' so users can see they exist but expect
    them to fail with the current loader."""
    if not project_dir or not project_dir.is_dir():
        return []

    rows: list[tuple[int, int, str, str]] = []
    for p in project_dir.glob("*.ini"):
        kind = classify_ini(p)
        # Sort key: (kind_rank, name_rank, name)
        # kind_rank:   modern/unknown=0, legacy=1
        # name_rank:   RunAna*=0, others=1
        kind_rank = 1 if kind == "legacy" else 0
        name_rank = 0 if p.name.startswith("RunAna") else 1
        display = p.name + (" (legacy format)" if kind == "legacy" else "")
        rows.append((kind_rank, name_rank, p.name, display))
    rows.sort()
    return [(display, raw) for (_k, _n, raw, display) in rows]


def list_tasks_in_ini(ini_path: Path) -> list[str]:
    """
    Top-level tasks are entries like:
        RunAnalysis:TaskName       = RunAnalysis
        RunAnalysis:TaskClassName  = CAP::RunAnalysis
    Subtask entries look like:
        RunAnalysis:Subtask3:TaskName = ...
    We pick names that have a `<Name>:TaskClassName` line and DON'T contain
    ':Subtask' anywhere before the TaskClassName key.
    """
    if not ini_path.is_file():
        return []
    pat = re.compile(r"^\s*([A-Za-z_][A-Za-z0-9_]*)\s*:\s*TaskClassName\s*=\s*CAP::",
                     re.MULTILINE)
    text = ini_path.read_text(encoding="utf-8", errors="replace")
    found = []
    seen = set()
    for m in pat.finditer(text):
        name = m.group(1)
        # Skip composite keys that include Subtask
        # (the regex above already excludes them — `[A-Za-z_]\w*` won't match `Subtask3`),
        # but double-check by ensuring this is a left-most key.
        line_start = text.rfind("\n", 0, m.start()) + 1
        line = text[line_start:m.end()]
        if "Subtask" in line:
            continue
        if name not in seen:
            seen.add(name)
            found.append(name)
    return found


def project_relpath(project_dir: Path) -> str:
    """Path that bin/CAP can use as the second argument. For directories
    under projects/ this is relative to projects/. For directories under
    analyses/projects/ we return an absolute path (CAP.cxx accepts an
    absolute path that begins with /)."""
    repo_projects = REPO / "projects"
    try:
        return str(project_dir.relative_to(repo_projects))
    except ValueError:
        return str(project_dir.resolve())


