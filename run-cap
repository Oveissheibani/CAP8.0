        #  3-column grid: spacer | centred-stack | toolbar.  The spacer
        #  and toolbar weights are equal (1) so the centred-stack ends
        #  up exactly in the middle even when the toolbar is wider than
        #  empty space on the left.
        # ============================================================
        header = ttk.Frame(self.root, style="Header.TFrame",
                           padding=(14, 12, 14, 8))
        header.pack(fill=tk.X)
        header.columnconfigure(0, weight=1, uniform="hdr")
        header.columnconfigure(1, weight=0)
        header.columnconfigure(2, weight=1, uniform="hdr")

        # Right-side toolbar — placed first because Tk render order
        # doesn't change layout, but it's where it logically belongs.
        right_tools = ttk.Frame(header, style="Header.TFrame")
        right_tools.grid(row=0, column=2, sticky="ne")
        ttk.Button(right_tools, text="💾 Save preset",
                   style="Accent.TButton",
                   command=self._save_preset
                   ).pack(side=tk.TOP, anchor="e", pady=(0, 2))
        ttk.Button(right_tools, text="📂 Load preset",
                   command=self._load_preset
                   ).pack(side=tk.TOP, anchor="e", pady=(0, 2))
        ttk.Button(right_tools, text="⚙ Theme",
                   command=self._open_theme_settings
