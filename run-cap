def _inject_extra_lines_into_in(in_path: Path, lines: list,
                                marker: str = "CAP-injected Herwig extras") -> None:
    """Splice user-supplied .in lines into in_path, BEFORE the saverun
    line so they're baked into the .run binary.  Idempotent via marker."""
    if not lines:
        return
    text = in_path.read_text(errors="ignore")
    if marker in text:
        return        # already injected — caller can re-write the .in if it wants fresh
    block = ["", f"# ----- {marker} ----------------"]
    for ln in lines:
        if not ln: continue
        block.append(ln)
    block.append("# ---------------------------------------------------")
    block.append("")
    src_lines = text.splitlines(keepends=True)
    out_lines = []
    inserted = False
    block_text = "\n".join(block) + "\n"
    for ln in src_lines:
        if not inserted and ln.lstrip().startswith("saverun "):
            out_lines.append(block_text)
            inserted = True
        out_lines.append(ln)
    if not inserted:
        out_lines.append(block_text)
    in_path.write_text("".join(out_lines))


def _inject_hepmc_into_in(in_path: Path, run_stem: str = "LHC") -> bool:
    """Insert CAP's HepMC-output block into a Herwig .in deck so a
    subsequent `Herwig run` produces a .hepmc file.

    CRITICAL CORRECTNESS POINT: the block MUST go *before* the
    `saverun NAME EventGenerator` line.  Anything after `saverun` is
    read but not stored in the .run binary, so `Herwig run` would
    load a generator without the HepMC handler.

    Approach: use Herwig's shipped snippets/HepMC.in (the same one
    the official tutorials say to use) and only set Filename +
    PrintEvent — those two parameters are documented as part of the
    HepMCFile class.  We deliberately do NOT set 'Format' because
    that property name varies between Herwig versions and setting
    an unknown property aborts the read silently.

    Idempotent: only inserts if the v4 marker isn't already there.
    Returns True if the file was modified.
    """
    text = in_path.read_text(errors="ignore")
    marker = "CAP-injected HepMC output v4 (snippet, minimal)"
    if marker in text:
        return False

    # Use the shipped snippet — it loads the right library and creates
    # /Herwig/Analysis/HepMC for us.  Set only the parameters that are
    # universally supported.  Filename is enough to get a hepmc file
    # written next to the .run during `Herwig run`.
    block = (
        "\n"
        f"# ----- {marker} ----------------\n"
        "# Use Herwig's shipped HepMC snippet — loads the analysis\n"
        "# library and creates /Herwig/Analysis/HepMC.  Only Filename\n"
        "# + PrintEvent are guaranteed safe to set.\n"
        "read snippets/HepMC.in\n"
        f"set /Herwig/Analysis/HepMC:Filename {run_stem}.hepmc\n"
        "set /Herwig/Analysis/HepMC:PrintEvent 100000000\n"
        "# ---------------------------------------------------\n\n"
    )

    lines = text.splitlines(keepends=True)
    new_lines = []
    inserted = False
    for ln in lines:
        # Match `saverun <name> <generator>` — possibly indented.
        stripped = ln.lstrip()
        if (not inserted) and stripped.startswith("saverun "):
            new_lines.append(block)
            inserted = True
        new_lines.append(ln)
    if not inserted:
        # No saverun in the file — append at the end (still better than
        # silently failing; the user's deck is non-standard).
        new_lines.append(block)

    in_path.write_text("".join(new_lines))
    return True


def _generator_folder(kind) -> str:
    """Return the histos/ subfolder name for a given GeneratorKind.
    All output goes under histos/<GeneratorName>/<KeepProfile>/<user_outdir>/
    so each event generator + each particle-keep selection has an
    isolated tree.  Falls back to 'Misc' for kinds we don't have a
    canonical folder for."""
    name = getattr(kind, "value", str(kind))
    return {
        "Pythia":      "Pythia",
        "Herwig":      "Herwig",
        "HepMC3":      "HepMC3",
        "Therminator": "Therminator",
        "Glauber":     "Glauber",
        "Basic":       "Basic",
        "EposReader":  "EPOS",
        "PhsdReader":  "PHSD",
    }.get(name, "Misc")


def _keep_profile_folder(*, final_only: bool, quarks: bool, neutrinos: bool,
                          photons: bool, gauge_bosons: bool) -> str:
    """Encode the particle-keep selection as a short, stable folder
    name so different selections don't trample each other's outputs.

    Convention:
      - "final"             = status==1 only, hadrons + leptons (default)
      - "all_status"        = no status filter (everything that flew)
      - prefix "+" suffixes mark extras kept beyond the hadron set:
          +q   keep quarks/gluons
          +n   keep neutrinos
          +g   keep photons
          +b   keep gauge bosons (W/Z/H/...)

    Examples:
      default                              → "final"
      final + photons                      → "final+g"
      final + quarks + photons             → "final+q+g"
      no final filter                      → "all_status"
      no final filter + photons + nu       → "all_status+n+g"
    """
    base = "final" if final_only else "all_status"
    extras = []
    if quarks:       extras.append("q")
    if neutrinos:    extras.append("n")
    if photons:      extras.append("g")
    if gauge_bosons: extras.append("b")
    if extras:
        return base + "+" + "+".join(extras)
    return base

