    def _dispatch_run(self) -> None:
        """Run button — always dispatches to Compose & Run since the
        legacy 'Run existing .ini' tab has been retired (its
        functionality lives in build-ini-gui's 'Load existing .ini')."""
        if _BUILDER_OK:
            self._compose_and_run()
        else:
            messagebox.showerror("run-cap",
                "Compose & Run unavailable: builder failed to import "
                f"({_BUILDER_ERR}).")

    def _run(self) -> None:
        cap_bin = REPO / "bin" / "CAP"
        if not cap_bin.is_file():
            messagebox.showerror(
                "run-cap",
                "bin/CAP not found. Build CAP first via ./install --gui.")
            return

        rel = self.project_var.get()
        if not rel:
            messagebox.showerror("run-cap", "Pick a project.")
            return
        display = self.ini_var.get()
        ini = getattr(self, "_ini_display_to_raw", {}).get(display, display)
        if not ini:
            messagebox.showerror("run-cap", "Pick an .ini file.")
            return
        task = self.task_var.get()
        if not task:
            messagebox.showerror("run-cap", "Pick a task.")
            return
        out = self.output_var.get().strip() or "test"

        # Optional .ini in-place edits for events / seed via a temp copy.
        ini_to_run = self._make_runtime_ini(rel, ini)

        env = os.environ.copy()
        env.setdefault("CAP_ROOT_PATH", str(REPO))
        env["CAP_PROJECTS_PATH"] = str(REPO / "projects")
        env.setdefault("CAP_HISTOS_IMPORT_PATH", str(REPO / "histos"))
        env.setdefault("CAP_HISTOS_EXPORT_PATH", str(REPO / "histos"))

        # Make sure DYLD/LD finds our libs.
        for k in ("DYLD_LIBRARY_PATH", "LD_LIBRARY_PATH"):
            v = env.get(k, "")
            our = str(REPO / "lib")
            if our not in v.split(":"):
                env[k] = our + (":" + v if v else "")

        cmd = [str(cap_bin), task, rel, Path(ini_to_run).name, out]
        self._append(f"$ {' '.join(shlex.quote(c) for c in cmd)}\n", "info")
        self.log.line("INFO", f"running: {' '.join(cmd)}")
        self.run_btn.config(state=tk.DISABLED)
        self.stop_btn.config(state=tk.NORMAL)
        self.status_var.set(f"Running {task} on {rel}/{ini} …")

        # Initialise the Run-stats panel for the legacy single-task path.
        import time as _time
        self._stats_start_time   = _time.time()
        self._stats_stage_start  = _time.time()
        self._current_outdir     = REPO / "histos" / out
        self._current_stage_name = task
        self.stats_ini_var.set(Path(ini_to_run).name)
        self.stats_files_var.set("0")

        threading.Thread(target=self._run_worker,
                         args=(cmd, env, ini_to_run), daemon=True).start()

    def _make_runtime_ini(self, project_rel: str, ini_name: str) -> str:
        """Return the .ini path the binary should read. If event/seed overrides
        are set, write a copy with those values into the project dir."""
        src = REPO / "projects" / project_rel / ini_name
        try:
            ev = int(self.events_var.get())
        except ValueError:
            ev = 0
        try:
            sd = int(self.seed_var.get())
        except ValueError:
            sd = 0

        if ev <= 0 and sd <= 0:
            return str(src)

        text = src.read_text(encoding="utf-8")
        if ev > 0:
            text = re.sub(
                r"^(EventIterator:nEventsRequested\s*=\s*).*$",
                rf"\g<1>{ev}",
                text,
                count=1,
                flags=re.MULTILINE,
            )
        if sd > 0:
            text = re.sub(
                r"^(PythiaEventGenerator:SeedValue\s*=\s*).*$",
                rf"\g<1>{sd}",
                text,
                count=1,
                flags=re.MULTILINE,
            )
        out = src.with_suffix(".runcap.ini")
        out.write_text(text, encoding="utf-8")
        self._append(
            f"Wrote per-run .ini with overrides events={ev} seed={sd}: {out}\n",
            "info")
        return str(out)

    def _run_chain_worker(self, chain: list[tuple[list[str], str]],
                           env: dict, ini_path: str) -> None:
        """Run multiple bin/CAP invocations in sequence (the
        RunAnalysis → RunDerived → RunBf workflow).  Stops on the
        first non-zero exit code or when self._chain_cancel is set
        (Stop button / window close).  Streams every stage's output
        to BOTH the GUI panel and the log file via a pty so progress
        appears in real time (a plain pipe block-buffers C++ stdio
        and the GUI looks frozen between progress prints)."""
        import time
        self._chain_cancel = False
        rc = 0
        chain_start = time.time()
        for stage_idx, (cmd, label) in enumerate(chain, 1):
            if self._chain_cancel:
                self.log.line("WARN", f"chain cancelled before stage {stage_idx}")
                break
            stage_start = time.time()
            self._stats_stage_start  = stage_start
            self._current_stage_name = f"{stage_idx}/{len(chain)}  {cmd[1]}"
            # Drop a stage marker on the perf chart so the colored
            # regions / vertical lines match what bin/CAP is doing.
            try:
                if self._stats_t0 is None:
                    self._stats_t0 = stage_start
                self._stage_markers.append(
                    (stage_start - self._stats_t0, cmd[1], "begin"))
            except Exception:
                pass
            banner = (f"\n=== stage {stage_idx}/{len(chain)} : "
                      f"{cmd[1]} — {label} ===\n")
            self.log.line("INFO", banner.strip())
            self.root.after(0, lambda b=banner: self._append(b, "ok"))
            self.root.after(0, lambda i=stage_idx, n=len(chain), c=cmd[1]:
                            self.status_var.set(
                                f"Running stage {i}/{n}: {c} …"))
            try:
                rc = self._spawn_streaming(cmd, env, stage_start)
            except Exception as exc:
                self.log.line("ERROR",
                    f"chain worker exception in stage {stage_idx}: {exc}")
                self.root.after(0, lambda e=exc: self._append(
                    f"\n!!! chain worker exception: {e}\n", "error"))
                rc = 1
            finally:
                with self.proc_lock:
                    self.proc = None
            elapsed = time.time() - stage_start
            try:
                if self._stats_t0 is not None:
                    self._stage_markers.append(
                        (time.time() - self._stats_t0, cmd[1], "end"))
            except Exception:
                pass
            stage_msg = (f"stage {stage_idx}/{len(chain)} ({cmd[1]}) "
                         f"exit={rc}  ({elapsed:.1f}s)")
            self.log.line("INFO" if rc == 0 else "ERROR", stage_msg)
            if rc != 0:
                self.root.after(0, lambda r=rc, l=label: self._append(
                    f"\n!!! stage '{l}' exited with code {r} — "
                    f"stopping chain ===\n", "error"))
                break
        if ini_path.endswith(".runcap.ini"):
            try: Path(ini_path).unlink()
            except OSError: pass
        total = time.time() - chain_start
        self.log.line("INFO", f"chain finished, final rc={rc}  ({total:.1f}s)")
        self.root.after(0, lambda: self._on_run_done(rc))

    def _spawn_streaming(self, cmd: list[str], env: dict,
                          start_t: float) -> int:
        """Run `cmd`, stream output line-by-line to GUI + log file.

        We *intentionally* use a regular pipe rather than a pty.  The
        pty path made ROOT's isatty() return true, exercising a code
        path inside ROOT that triggered a heap-corruption SIGABRT on
        the first event with our analyzer set.  Pipe is slightly
        chunkier (the C++ stdio block-buffers output to a non-tty)
        but rock-solid.  Heartbeat below keeps the GUI visibly alive
        between buffered chunks."""
        import threading, time
        with self.proc_lock:
            self.proc = subprocess.Popen(
                cmd, env=env, cwd=str(REPO),
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, bufsize=1)
        # Heartbeat: a one-shot Tk timer that re-arms itself until
        # self.proc finishes.  Keeps the status bar updated with
        # elapsed seconds even when bin/CAP is silent (Pythia event
        # generation produces a progress line only every 100 events).
        def heartbeat():
            if self.proc is None or self.proc.poll() is not None:
                return
            elapsed = int(time.time() - start_t)
            self.status_var.set(
                f"Running … {elapsed}s elapsed (output may chunk between "
                f"Pythia progress prints — this is normal)")
            self.root.after(2000, heartbeat)
        self.root.after(2000, heartbeat)

        assert self.proc.stdout is not None
        for line in self.proc.stdout:
            if self._chain_cancel:
                try: self.proc.terminate()
                except OSError: pass
                break
            line = line.rstrip()
            self.log.line("DEBUG", line)
            self.root.after(0, lambda l=line: self._append(l + "\n"))
        self.proc.wait()
        return self.proc.returncode

    def _run_worker(self, cmd: list[str], env: dict, ini_path: str) -> None:
        try:
            with self.proc_lock:
                self.proc = subprocess.Popen(
                    cmd, env=env, cwd=str(REPO),
                    stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                    text=True, bufsize=1,
                )
            assert self.proc.stdout is not None
            for line in self.proc.stdout:
                line = line.rstrip()
                self.log.line("DEBUG", line)
                self.root.after(0, lambda l=line: self._append(l + "\n"))
            self.proc.wait()
            rc = self.proc.returncode
        finally:
            with self.proc_lock:
                self.proc = None

        # Clean up the temp ini if we wrote one.
        if ini_path.endswith(".runcap.ini"):
            try:
                Path(ini_path).unlink()
            except OSError:
                pass

        self.root.after(0, lambda: self._on_run_done(rc))

    def _on_run_done(self, rc: int) -> None:
        self.run_btn.config(state=tk.NORMAL)
        self.stop_btn.config(state=tk.DISABLED)
        # Freeze the Run-stats panel where it landed (last total / stage
        # runtime stays visible) but flag that no live process is running.
        self._stats_start_time  = None
        self._stats_stage_start = None
        self._current_stage_name = (
            "✓ done" if rc == 0 else f"✗ exit {rc}"
        )
        self.stats_pid_var.set("—")
        if rc == 0:
            self.status_var.set("✅ CAP completed successfully.")
            self._append("\n=== run finished, exit code 0 ===\n", "ok")
        else:
            self.status_var.set(f"❌ CAP exited with code {rc}.")
            self._append(f"\n=== run finished, exit code {rc} ===\n", "error")

    def _stop(self) -> None:
        # Cancel the chain (covers both single and multi-stage runs).
        # Without this flag, the chain worker would just SIGTERM the
        # current stage and then start the next one.
        self._chain_cancel = True
        with self.proc_lock:
            if not self.proc:
                return
            self._append("--- stop requested, sending SIGTERM ---\n", "warn")
            self.log.line("INFO", "User requested stop (cancels chain)")
            try:
                self.proc.send_signal(signal.SIGTERM)
            except OSError as exc:
                self._append(f"send_signal failed: {exc}\n", "error")
            # Give it 3 seconds, then escalate.
            self.root.after(3000, self._stop_force)

    def _stop_force(self) -> None:
        with self.proc_lock:
            if not self.proc:
                return
            try:
                self.proc.kill()
                self._append("--- escalated to SIGKILL ---\n", "warn")
            except OSError:
                pass

