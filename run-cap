                   ).pack(side=tk.TOP, anchor="e", pady=(0, 2))
        ttk.Button(right_tools, text="Refresh projects",
                   command=self._refresh_projects
                   ).pack(side=tk.TOP, anchor="e")

        # Centred logo + title stack — column 1 (the middle column).
        center_stack = ttk.Frame(header, style="Header.TFrame")
        center_stack.grid(row=0, column=1, sticky="n")

        # Logo: 50 % larger (90 → 135 px tall) with PIL antialiased
        # resize when available, else PhotoImage subsample.
        logo_png = REPO / "logo" / "logo.png"
        target_h = 135
        if logo_png.is_file():
            try:
                try:
                    from PIL import Image, ImageTk  # type: ignore
                    pil = Image.open(str(logo_png)).convert("RGBA")
                    w0, h0 = pil.size
                    new_w = max(1, int(w0 * target_h / h0))
                    pil = pil.resize((new_w, target_h), Image.LANCZOS)
                    self._logo_img = ImageTk.PhotoImage(pil)
                except Exception:
                    img = tk.PhotoImage(file=str(logo_png))
                    factor = max(1, max(img.width(), img.height()) // target_h)
                    if factor > 1:
                        img = img.subsample(factor, factor)
                    self._logo_img = img
                ttk.Label(center_stack, image=self._logo_img
                          ).pack(anchor="center")
            except Exception as exc:
                self.log.line("WARN", f"could not load logo: {exc}")

