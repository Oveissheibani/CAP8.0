            time_install=self.wsu_time_install.get().strip() or "04:00:00",
            mem_install=self.wsu_mem_install.get().strip() or "16G",
            time_workflow=self.wsu_time_workflow.get().strip() or "08:00:00",
            mem_workflow=self.wsu_mem_workflow.get().strip() or "8G",
            time_subsample=self.wsu_time_subsample.get().strip() or "01:00:00",
