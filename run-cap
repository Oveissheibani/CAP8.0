    # =================================================================
    #  Generator=Herwig → HepMC3 transparent bridge
    # =================================================================
    def _run_streaming(self, shell_cmd: str, label: str = "subprocess") -> int:
        """Run a shell command, stream its stdout/stderr to the GUI
        terminal pane in real time, and keep the Tk main loop pumped
        the whole time.

        Why a thread: subprocess.PIPE.readline() blocks waiting for
        the next byte.  If Herwig is silent for 5–10 s during phase-
        space integration, the whole UI freezes.  We move the read
        loop to a daemon thread that pushes lines into a queue, and
        the main thread just drains the queue + pumps Tk.

        Returns the subprocess exit code, or -1 if launch failed.
        """
        import queue
        try:
            proc = subprocess.Popen(
                ["bash", "-lc", shell_cmd],
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                bufsize=1, text=True)
        except Exception as exc:
            self._append(f"!!! {label} launch failed: {exc}\n", "error")
            return -1

        q: "queue.Queue[str]" = queue.Queue()

        def reader():
            try:
                if proc.stdout is None:
                    return
                for line in iter(proc.stdout.readline, ""):
                    q.put(line)
            finally:
                q.put("")  # sentinel

        threading.Thread(target=reader, daemon=True).start()

        # Main loop: drain queue + pump Tk.  Tk handles its own UI
        # events (redraw, button clicks, scroll) on every iteration.
        done = False
        while not done:
            try:
                while True:
                    line = q.get_nowait()
                    if line == "":
                        done = True
                        break
                    self._append(line, "info")
            except queue.Empty:
                pass
            try:
                self.root.update_idletasks()
                self.root.update()
            except Exception:
                pass
            # Tiny sleep so we don't burn CPU spinning when the
            # subprocess is silent.  The next iteration pumps Tk again.
            if not done:
                import time as _t
                _t.sleep(0.04)

        rc = proc.wait()
        return rc

    def _herwig_inject_hepmc_and_read(self, run_path, in_sibling) -> bool:
        """Make sure run_path's sibling .in has CAP's HepMC3 config
        injected, then run `Herwig read` so a fresh .run is built
        with the HepMC analysis handler baked in.  Returns True on
        success.

        Called automatically by _herwig_to_hepmc when it detects an
        old .run (no HepMC3 output configured).

        Strategy: always overwrite the .in from the shipped template
        before patching.  Reason: previous attempts may have left
        stale CAP-injected blocks (v1, v2) in the file that conflict
        with the current injection scheme.  Wiping and re-patching
        is simpler and avoids accumulated cruft.
        """
        import shutil
        hw_prefix = os.environ.get(
            "HW_PREFIX",
            "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        shipped = Path(hw_prefix) / "share" / "Herwig" / "LHC.in"
        if not shipped.is_file():
            messagebox.showerror("run-cap",
                f"Shipped Herwig deck not found at {shipped}.\n"
                "Set HW_PREFIX so we can locate share/Herwig/LHC.in.")
            return False
        try:
            shutil.copyfile(shipped, in_sibling)
            in_sibling.chmod(0o644)
        except OSError as exc:
            messagebox.showerror("run-cap",
                f"Could not write {in_sibling}: {exc}")
            return False

        # Now insert the HepMC3 config block before the saverun line.
        try:
            _inject_hepmc_into_in(in_sibling, run_stem=run_path.stem)
        except OSError as exc:
            messagebox.showerror("run-cap",
                f"Could not patch {in_sibling}: {exc}")
            return False

        # Inject user's preset+custom Herwig lines (also before saverun).
        # These come from the Herwig config window — preset selection +
        # specialized panel checkboxes + custom string text area.
        try:
            extra_lines = list(getattr(self, "_herwig_extra_lines", []))
            if extra_lines:
                _inject_extra_lines_into_in(
                    in_sibling, extra_lines,
                    marker="CAP-injected Herwig user extras")
                self._append(
                    f"=== Injected {len(extra_lines)} user-supplied Herwig "
                    f"lines into {in_sibling.name} ===\n", "info")
        except OSError as exc:
            messagebox.showerror("run-cap",
                f"Could not patch user extras into {in_sibling}: {exc}")
            return False

        # Run `Herwig read` to rebuild the .run with the HepMC handler.
        hw_prefix = os.environ.get(
            "HW_PREFIX",
            "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        env_script = Path(hw_prefix) / "herwig-env.sh"
        cmd = (
            f'source "{env_script}" && '
            f'cd "{in_sibling.parent}" && '
            f'Herwig read "{in_sibling.name}"'
        )
        self._append(f"\n=== Herwig read (rebuilding .run with HepMC3) ===\n", "ok")
        # Capture the .run mtime BEFORE so we can detect a no-op read.
        run_mtime_before = (
            run_path.stat().st_mtime if run_path.is_file() else 0.0
        )
        rc = self._run_streaming(cmd, label="Herwig read")
        if rc != 0:
            messagebox.showerror("run-cap",
                f"Herwig read failed with exit code {rc}.")
            return False
        if not run_path.is_file():
            messagebox.showerror("run-cap",
                f"Herwig read succeeded but {run_path} not produced.")
            return False
        run_mtime_after = run_path.stat().st_mtime
        if run_mtime_after <= run_mtime_before + 0.5:
            # The read returned 0 but didn't actually rewrite the .run.
            # Means our injected block triggered an error in Herwig that
            # aborted before reaching `saverun`, but Herwig still exits
            # 0 because it caught the exception.  Tell the user with
            # clear diagnostic instead of letting them silently hit the
            # next failure ("no .hepmc file produced").
            messagebox.showerror("run-cap",
                f"Herwig read returned 0 but {run_path.name} was not "
                f"rewritten.\n\nThe HepMC injection likely triggered "
                f"a parse error before `saverun`. Inspect "
                f"{in_sibling.parent}/LHC.out and LHC.log for the "
                f"actual Herwig error message.")
            return False
        self._append(f"=== ✓ .run rebuilt with HepMC handler ===\n", "ok")
        return True

    def _herwig_to_hepmc(self, n_evt: int):
        """Ensure a .hepmc file exists for the currently-selected .run
        file.  Returns Path on success, None on cancel/failure.

        Strategy:
          - Get the .run file from compose_herwig_run_var (auto-filled
            from histos/_herwig_scratch/LHC.run if the user clicked
            ⚡ Use default LHC.in, else hand-picked).
          - If a .hepmc next to it has >= n_evt events and is newer
            than the .run, reuse it.
          - Otherwise spawn `Herwig run <run> --numevents N` synchronously
            (blocks the GUI for a few seconds — user sees a progress
            line in the terminal pane).

        This sidesteps the embedded ThePEG SEGV entirely; `Herwig run`
        is the production-tested binary with no in-process flakiness.
        """
        run_file = self.compose_herwig_run_var.get().strip()
        if not run_file:
            scratch = REPO / "histos" / "_herwig_scratch" / "LHC.run"
            if scratch.is_file():
                run_file = str(scratch)
            else:
                messagebox.showerror("run-cap",
                    "Generator = Herwig but no .run file is set.\n\n"
                    "In the Compose tab, click ⚡ Use default LHC.in (no setup), "
                    "or Browse to a .run produced by `Herwig read input.in`.")
                return None
        run_path = Path(run_file)
        if not run_path.is_file():
            messagebox.showerror("run-cap",
                f"Run file does not exist:\n{run_path}")
            return None

        # The .run file is the binary serialised repository.  HepMC3
        # output has to be configured in the .in file BEFORE
        # `Herwig read` — once .run exists, the HepMC analysis is
        # baked in (or absent) for good.  Detect: if the sibling .in
        # doesn't contain our CAP-injected HepMC block, regenerate
        # both .in (with injection) and .run.  This catches two cases:
        # (a) user had a pre-existing .run from before this fix, or
        # (b) user pointed Browse at a .run that wasn't built for CAP.
        in_sibling = run_path.with_suffix(".in")
        needs_regen = (
            not in_sibling.is_file() or
            "CAP-injected HepMC output v4 (snippet, minimal)" not in in_sibling.read_text(errors="ignore")
        )
        if needs_regen:
            self._append(
                f"\n=== .run file lacks HepMC3 output, regenerating .in+.run ===\n"
                f"   .run    : {run_path}\n"
                f"   .in     : {in_sibling}\n", "info")
            if not self._herwig_inject_hepmc_and_read(run_path, in_sibling):
                return None

        # Output sits next to the .run, named after it + event count so
        # changing N produces a fresh file.
        hepmc_path = run_path.parent / f"{run_path.stem}_{n_evt}.hepmc"

        # Cache: if it already exists and is newer than the .run, reuse.
        if hepmc_path.is_file() and \
           hepmc_path.stat().st_mtime >= run_path.stat().st_mtime:
            self._append(
                f"\n=== Reusing cached HepMC3 file: {hepmc_path}\n"
                f"   ({n_evt} events; delete the file to force regeneration)\n",
                "info")
            return hepmc_path

        # Need to generate.  Locate Herwig binary via HW_PREFIX (env or
        # local default).
        hw_prefix = os.environ.get(
            "HW_PREFIX",
            "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        herwig_bin = Path(hw_prefix) / "bin" / "Herwig"
        if not herwig_bin.is_file():
            messagebox.showerror("run-cap",
                f"Herwig binary not found at {herwig_bin}.\n"
                "Set HW_PREFIX in your environment.")
            return None

        env_script = Path(hw_prefix) / "herwig-env.sh"
        # `Herwig run` writes <stem>.hepmc next to the .run by default.
        # We rename it to our event-count-tagged name on success.
        cmd = (
            f'source "{env_script}" && '
            f'cd "{run_path.parent}" && '
            f'Herwig run "{run_path.name}" --numevents {n_evt}'
        )

        self._append(
            f"\n=== Generating Herwig events (file-based path) ===\n"
            f"  run file : {run_path}\n"
            f"  events   : {n_evt}\n"
            f"  output   : {hepmc_path}\n"
            f"  (Herwig progress streaming below — GUI stays responsive)\n",
            "ok")

        rc = self._run_streaming(cmd, label="Herwig run")
        if rc != 0:
            messagebox.showerror("run-cap",
                f"Herwig run failed with exit code {rc}.\n"
                "Check the terminal pane above for details.")
            return None

        # Default Herwig outputs go to <stem>.hepmc.  Find whichever
        # appeared and rename to our tagged name.
        produced = (
            sorted(run_path.parent.glob(f"{run_path.stem}*.hepmc")) +
            sorted(run_path.parent.glob(f"{run_path.stem}*.hepmc3"))
        )
        if not produced:
            messagebox.showerror("run-cap",
                "Herwig finished without errors but no .hepmc file appeared "
                f"in {run_path.parent}. Check the terminal pane.")
            return None
        # Rename the produced file to our tagged name (idempotent).
        if produced[0] != hepmc_path:
            try:
                produced[0].rename(hepmc_path)
            except OSError:
                # Fall back to using whatever was produced.
                hepmc_path = produced[0]

        self._append(
            f"\n=== ✓ HepMC3 file ready: {hepmc_path}\n"
            f"   Now running CAP analysis on it.\n", "ok")
        return hepmc_path

    def _compose_run_herwig_default(self) -> None:
        """Zero-config Herwig run: copy the install's shipped LHC.in
        (pp@13 TeV minimum-bias by default), call `Herwig read` on it,
        auto-fill the .run input field.  No user .in deck required.

        Workflow when the user clicks ⚡ Use default LHC.in:
          1. Locate $HW_PREFIX/share/Herwig/LHC.in
          2. Copy it to histos/_herwig_scratch/LHC.in (so we don't
             touch the install dir, and the .run lands somewhere
             writable)
          3. Run `Herwig read LHC.in`  →  produces LHC.run
          4. Set self.compose_herwig_run_var to the .run path
          5. Done — user can click Run.
        """
        import shutil
        hw_prefix = os.environ.get(
            "HW_PREFIX",
            "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        src_in = Path(hw_prefix) / "share" / "Herwig" / "LHC.in"
        if not src_in.is_file():
            messagebox.showerror("run-cap",
                f"Default deck not found: {src_in}\n"
                "Either set HW_PREFIX in your environment or use the "
                "Browse button to point at your own .in / .run.")
            return

        # Scratch dir lives under histos/ so we don't pollute the
        # install + the user can inspect the generated files later.
        scratch = REPO / "histos" / "_herwig_scratch"
        scratch.mkdir(parents=True, exist_ok=True)
        dst_in = scratch / "LHC.in"
        shutil.copyfile(src_in, dst_in)
        # Ensure writable in case the source file is r-x only.
        try: dst_in.chmod(0o644)
        except OSError: pass

        # Inject HepMC3 output config — required for the file-based path
        # we now use by default.  CRITICAL: must be inserted *before*
        # the `saverun ... EventGenerator` line, because `saverun`
        # serialises the generator to .run at that point — anything
        # after it is executed at read-time but NOT saved.
        try:
            _inject_hepmc_into_in(dst_in, run_stem="LHC")
        except OSError as exc:
            messagebox.showerror("run-cap",
                f"Could not patch {dst_in}: {exc}")
            return

        self._append(
            f"\n=== Auto-running Herwig read on default LHC.in ===\n"
            f"  source: {src_in}\n"
            f"  scratch: {scratch}\n", "ok")

        env_script = Path(hw_prefix) / "herwig-env.sh"
        cmd = (f'source "{env_script}" && cd "{scratch}" && '
               f'Herwig read "LHC.in"')

        def worker():
            try:
                rc = subprocess.call(["bash", "-lc", cmd])
                if rc == 0:
                    run_path = scratch / "LHC.run"
                    if run_path.is_file():
                        self.root.after(0, lambda p=run_path: (
                            self.compose_herwig_run_var.set(str(p)),
                            self._append(
                                f"\n=== ✓ default .run file produced: {p}\n"
                                f"   Click ▶ Run to start generating.\n",
                                "ok")))
                    else:
                        self.root.after(0, lambda: self._append(
                            "\n!!! Herwig read finished but LHC.run not found\n",
                            "error"))
                else:
                    self.root.after(0, lambda r=rc: self._append(
                        f"\n!!! Herwig read exited with code {r} — "
                        f"is HW_PREFIX correct?  ({hw_prefix})\n", "error"))
            except Exception as exc:
                self.root.after(0, lambda e=exc: self._append(
                    f"\n!!! Default Herwig launch failed: {e}\n", "error"))
        threading.Thread(target=worker, daemon=True).start()

    def _compose_run_herwig_read(self) -> None:
        """Run `Herwig read input.in` to produce the .run file CAP needs.
        Auto-fills the .run picker on success."""
        from tkinter import filedialog
        in_file = filedialog.askopenfilename(
            title="Select Herwig .in input deck",
            initialdir="/Users/oveissheibani/LocalHerwig/LocalHerwig/opt/share/Herwig",
            filetypes=[("Herwig input", "*.in"), ("All files", "*")])
        if not in_file:
            return
        in_path = Path(in_file)
        hw_prefix = os.environ.get(
            "HW_PREFIX",
            "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        env_script = Path(hw_prefix) / "herwig-env.sh"
        out_dir = in_path.parent
        cmd = (f'source "{env_script}" && cd "{out_dir}" && '
               f'Herwig read "{in_path.name}"')

        self._append(f"\n=== Herwig read {in_path.name} ===\n", "ok")

        def worker():
            try:
                rc = subprocess.call(["bash", "-lc", cmd])
                if rc == 0:
                    run_path = out_dir / f"{in_path.stem}.run"
                    if run_path.is_file():
                        self.root.after(0, lambda p=run_path: (
                            self.compose_herwig_run_var.set(str(p)),
                            self._append(f"\n=== .run file produced: {p} ===\n",
                                         "ok")))
                    else:
                        self.root.after(0, lambda: self._append(
                            "\n!!! Herwig read finished but .run not found\n",
                            "error"))
                else:
                    self.root.after(0, lambda r=rc: self._append(
                        f"\n!!! Herwig read exited with code {r}\n", "error"))
            except Exception as exc:
                self.root.after(0, lambda e=exc: self._append(
                    f"\n!!! Herwig read launch failed: {e}\n", "error"))
        threading.Thread(target=worker, daemon=True).start()

