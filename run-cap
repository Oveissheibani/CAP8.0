    def _apply_runcap_state(self, state: dict) -> int:
        """Inverse of _collect_runcap_state.  Returns the number of
        fields successfully restored.  Tolerant of missing keys."""
        try:
            import cap_preset as _cp
        except Exception:
            return 0
        n = 0

        def _s(var, payload, key):
            nonlocal n
            if isinstance(payload, dict) and key in payload and var is not None:
                try: var.set(payload[key]); n += 1
                except Exception: pass

        rc = state.get("run_cap", {}) if isinstance(state, dict) else {}
        cmp = rc.get("compose", {}) or {}
        ss  = rc.get("subsample", {}) or {}
        ws  = rc.get("wsu", {}) or {}

        # ---- Compose tab ----
        _s(self.compose_name_var,    cmp, "name")
        _s(self.compose_outdir_var,  cmp, "outdir")
        _s(self.compose_nevents_var, cmp, "nevents")
        _s(self.compose_grid_n_var,  cmp, "grid_n")
        _s(self.compose_grid_m_var,  cmp, "grid_m")
        _s(self.compose_gen_var,     cmp, "gen")
        _s(self.compose_energy_var,  cmp, "energy")
        _s(self.compose_idA_var,     cmp, "idA")
        _s(self.compose_idB_var,     cmp, "idB")
        _s(self.compose_seed_var,    cmp, "seed")
        _s(self.compose_hepmc3_file_var,  cmp, "hepmc3_input_file")
        _s(self.compose_herwig_run_var,    cmp, "herwig_run_file")
        _s(self.compose_herwig_lhapdf_var, cmp, "herwig_lhapdf_data")
        _s(self.compose_herwig_plugin_var, cmp, "herwig_plugin_path")
        _s(self.compose_keep_final_only_var,   cmp, "keep_final_only")
        _s(self.compose_keep_quarks_var,       cmp, "keep_quarks")
        _s(self.compose_keep_neutrinos_var,    cmp, "keep_neutrinos")
        _s(self.compose_keep_photons_var,      cmp, "keep_photons")
        _s(self.compose_keep_gauge_bosons_var, cmp, "keep_gauge_bosons")
        _s(self.compose_stage_var,         cmp, "stage")
        _s(self.compose_run_derived_var,   cmp, "run_derived")
        _s(self.compose_run_bf_var,        cmp, "run_bf")
        # Analyses (dict)
        _cp.dict_to_vars(cmp.get("analyses", {}), self.compose_choice_vars)
        if isinstance(cmp.get("analyses"), dict):
            n += sum(1 for k in cmp["analyses"] if k in self.compose_choice_vars)

        # ---- Subsample tab ----
        _s(self.subsample_source_var,  ss, "source")
        _s(self.subsample_detect_var,  ss, "detect")
        _s(self.subsample_mode_var,    ss, "mode")
        _s(self.subsample_outname_var, ss, "outname")

        # ---- Wayne State tab ----
        _s(self.wsu_name_var,      ws, "name")
        _s(self.wsu_home_var,      ws, "user_home")
        _s(self.wsu_partition_var, ws, "partition")
        _s(self.wsu_mail_var,      ws, "mail")
        _s(self.wsu_enable_pythia, ws, "enable_pythia")
        _s(self.wsu_enable_herwig, ws, "enable_herwig")
        _s(self.wsu_enable_hepmc3, ws, "enable_hepmc3")
        _s(self.wsu_enable_epos,   ws, "enable_epos")
        _s(self.wsu_im_pythia,     ws, "install_mode_pythia")
        _s(self.wsu_im_herwig,     ws, "install_mode_herwig")
        _s(self.wsu_im_lhapdf,     ws, "install_mode_lhapdf")
        _s(self.wsu_n_tasks,       ws, "n_tasks")
        _s(self.wsu_evt_per_task,  ws, "events_per_task")
        _s(self.wsu_seed_offset,   ws, "seed_offset")
        _s(self.wsu_time_install,   ws, "time_install")
        _s(self.wsu_mem_install,    ws, "mem_install")
        _s(self.wsu_time_workflow,  ws, "time_workflow")
        _s(self.wsu_mem_workflow,   ws, "mem_workflow")
        _s(self.wsu_time_subsample, ws, "time_subsample")
        _s(self.wsu_mem_subsample,  ws, "mem_subsample")
        # Backward-compat: load older presets that still used time_gen / time_ana
        if "time_gen"  in ws: _s(self.wsu_time_workflow,  ws, "time_gen")
        if "mem_gen"   in ws: _s(self.wsu_mem_workflow,   ws, "mem_gen")
        if "time_ana"  in ws: _s(self.wsu_time_subsample, ws, "time_ana")
        if "mem_ana"   in ws: _s(self.wsu_mem_subsample,  ws, "mem_ana")
        _s(self.wsu_remote_outdir, ws, "remote_outdir")
        _s(self.wsu_local_outdir,  ws, "local_outdir")
        _cp.dict_to_vars(ws.get("paths", {}), self.wsu_path_vars)

        # ---- Common: Pythia + Herwig generator config dicts ----
        common = state.get("common", {}) if isinstance(state, dict) else {}
        if "pythia_cfg" in common:
            _cp.cfg_from_json(common["pythia_cfg"], self._pythia_cfg_state)
        if "herwig_cfg" in common:
            _cp.cfg_from_json(common["herwig_cfg"], self._herwig_cfg_state)
        return n

    def _save_preset(self) -> None:
        try:
            import cap_preset as _cp
        except Exception as exc:
            messagebox.showerror("Preset", f"cap_preset module missing: {exc}")
            return
        from tkinter import filedialog
        path = filedialog.asksaveasfilename(
            initialdir=str(REPO),
            initialfile="my_preset.json",
            defaultextension=".json",
            filetypes=[("CAP preset (JSON)", "*.json"),
                       ("All files", "*.*")],
            title="Save GUI state as preset")
        if not path:
            return
        state = self._collect_runcap_state()
        try:
            _cp.save_preset(state, path)
        except Exception as exc:
            messagebox.showerror("Preset", f"Save failed: {exc}")
            return
        self._append(f"✓ Preset saved: {path}\n", "ok")
        self.log.line("INFO", f"preset saved {path}")

    def _load_preset(self) -> None:
        try:
            import cap_preset as _cp
        except Exception as exc:
            messagebox.showerror("Preset", f"cap_preset module missing: {exc}")
            return
        from tkinter import filedialog
        path = filedialog.askopenfilename(
            initialdir=str(REPO),
            filetypes=[("CAP preset (JSON)", "*.json"),
                       ("All files", "*.*")],
            title="Load preset")
        if not path:
            return
        try:
            state = _cp.load_preset(path)
        except Exception as exc:
            messagebox.showerror("Preset", f"Load failed: {exc}")
            return
        n = self._apply_runcap_state(state)
        self._append(f"✓ Preset loaded ({n} fields restored from "
                     f"{Path(path).name})\n", "ok")
        self.log.line("INFO", f"preset loaded {path} ({n} fields)")

    def _open_ini_in_editor(self) -> None:
        rel = self.project_var.get()
        d = getattr(self, "_project_paths", {}).get(rel)
        display = self.ini_var.get()
        ini = getattr(self, "_ini_display_to_raw", {}).get(display, display)
        if not d or not ini:
            return
        path = d / ini
        editor = os.environ.get("VISUAL") or os.environ.get("EDITOR")
        if editor:
            subprocess.Popen([editor, str(path)])
        else:
            self._open_path(path)

    def _append(self, text: str, tag: str = "") -> None:
        if tag:
            self.log_widget.insert(tk.END, text, tag)
        else:
            self.log_widget.insert(tk.END, text)
        self.log_widget.see(tk.END)
        # Side-channel: scrape "iEvent............................................ : N"
        # lines so the perf chart can show throughput in events/sec.
        # Cheap regex check first to avoid the expense on non-event lines.
        if "iEvent" in text:
            try:
                import re as _re
                m = _re.search(r"iEvent[\.\s]*:\s*(\d+)", text)
                if m:
                    self._last_ievent = int(m.group(1))
            except Exception:
                pass

    def _poll_proc(self) -> None:
        """Periodic UI sync — currently a no-op slot in case we want a heartbeat."""
        self.root.after(500, self._poll_proc)

    # -- Live run-stats sampler (1 Hz) ------------------------------------
    def _update_stats(self) -> None:
        """Refresh the Run-stats panel: runtime / CPU / RAM / files
        produced.  Uses `ps` for CPU/RSS to avoid a psutil dependency.
        Stops sampling when no process is alive (last values stay
        visible)."""
        import time
        try:
            now = time.time()

            # Total runtime (whole chain) and stage runtime.
            if self._stats_start_time is not None:
                tot = int(now - self._stats_start_time)
                self.stats_runtime_var.set(f"{tot//60:02d}:{tot%60:02d}")
            if self._stats_stage_start is not None:
                st = int(now - self._stats_stage_start)
                self.stats_stage_dt_var.set(f"{st//60:02d}:{st%60:02d}")

            # Current stage label.
            self.stats_stage_var.set(self._current_stage_name or "—")

            # Sample subprocess CPU / RSS via `ps`.
            pid = None
            with self.proc_lock:
                if self.proc and self.proc.poll() is None:
                    pid = self.proc.pid
            cpu_pct = None
            rss_mib = None
            if pid:
                self.stats_pid_var.set(str(pid))
                try:
                    out = subprocess.check_output(
                        ["ps", "-o", "%cpu=,rss=", "-p", str(pid)],
                        text=True, stderr=subprocess.DEVNULL, timeout=1.0)
                    cpu_s, rss_s = (out.strip().split() + ["", ""])[:2]
                    if cpu_s:
                        cpu_pct = float(cpu_s)
                        self.stats_cpu_var.set(f"{cpu_pct:.1f} %")
                    if rss_s:
                        # ps reports RSS in KiB on macOS / Linux.
                        rss_mib = float(rss_s) / 1024.0
                        if rss_mib >= 1024:
                            self.stats_mem_var.set(
                                f"{rss_mib/1024:.2f} GiB")
                        else:
                            self.stats_mem_var.set(f"{rss_mib:.0f} MiB")
                except (subprocess.SubprocessError, ValueError, OSError):
                    pass
            else:
                # No live process — leave last values (so the user can
                # see what the run consumed).  Just blank the PID.
                self.stats_pid_var.set("—")

            # ----------------------------------------------------------
            # Output dir + file count — measure FIRST so we can append
            # to the chart history with the latest count.
            outdir = self._current_outdir
            n_files = 0
            if outdir is not None:
                self.stats_outdir_var.set(str(outdir.relative_to(REPO))
                                          if outdir.is_relative_to(REPO)
                                          else str(outdir))
                if outdir.is_dir():
                    n_files = len(list(outdir.glob("*.root")))
                    self.stats_files_var.set(str(n_files))

            # ----------------------------------------------------------
            # Throughput estimate: events / sec.  Read from the last
            # iEvent: N line in the live log file (we tail it for the
            # output panel anyway).  Tolerant — if the log isn't
            # available or no iEvent line yet, throughput is 0.
            evps = 0.0
            try:
                hist = list(self._stats_history)[-15:]  # last 15 s
                # We re-compute throughput by polling the largest iEvent
                # we've seen via _last_ievent (set in the log scanner).
                cur_ievent = getattr(self, "_last_ievent", 0)
                last_ievent_ts = getattr(self, "_last_ievent_ts", None)
                last_ievent_n  = getattr(self, "_last_ievent_n",  None)
                if last_ievent_ts is not None and last_ievent_n is not None:
                    dt = now - last_ievent_ts
                    if dt > 0.01:
                        evps = max(0.0, (cur_ievent - last_ievent_n) / dt)
                self._last_ievent_ts = now
                self._last_ievent_n  = cur_ievent
            except Exception:
                evps = 0.0

            # ----------------------------------------------------------
            # Append to the live-chart history.  We log a sample EVERY
            # tick (even when no process is running we record 0,0) so
            # the chart x-axis advances continuously and idle gaps are
            # visible as flat lines at zero.
            if self._stats_t0 is None:
                self._stats_t0 = now
            if not self._stats_paused:
                self._stats_history.append((
                    now - self._stats_t0,
                    cpu_pct if cpu_pct is not None else 0.0,
                    rss_mib if rss_mib is not None else 0.0,
                    float(n_files),
                    float(evps),
                ))
            self._redraw_chart()
        except Exception:
            # Stats panel must never crash the GUI.
            pass
        finally:
            self.root.after(1000, self._update_stats)

    # -- Scrollable-frame helper ------------------------------------------
    def _make_scrollable(self, parent, height: int = 0):
        """Wrap *parent* in a Canvas + V/H Scrollbars and return the
        inner ttk.Frame to hold actual content.  The inner frame
        auto-resizes its scrollregion when children are packed/grid'd
        into it.  Mouse-wheel scrolls vertical; Shift+wheel scrolls
        horizontal.  Cross-platform (macOS, Linux, Windows).
        Pass height=0 to let the canvas size itself; pass a positive
        value to give it a min height."""
        outer = ttk.Frame(parent)
        outer.pack(fill=tk.BOTH, expand=True)
        # 2x2 grid: canvas | vbar  /  hbar | corner
        outer.rowconfigure(0, weight=1)
        outer.columnconfigure(0, weight=1)

        canvas = tk.Canvas(outer, highlightthickness=0,
                           **({"height": height} if height else {}))
        _theme.register(canvas, "canvas")
        vbar = ttk.Scrollbar(outer, orient=tk.VERTICAL,
                             command=canvas.yview)
        hbar = ttk.Scrollbar(outer, orient=tk.HORIZONTAL,
                             command=canvas.xview)
        canvas.configure(yscrollcommand=vbar.set,
                         xscrollcommand=hbar.set)
        canvas.grid(row=0, column=0, sticky="nsew")
        vbar.grid(row=0, column=1, sticky="ns")
        hbar.grid(row=1, column=0, sticky="ew")

        inner = ttk.Frame(canvas)
        win   = canvas.create_window((0, 0), window=inner, anchor="nw")

        def _on_inner(_evt):
            canvas.configure(scrollregion=canvas.bbox("all"))
        def _on_canvas(evt):
            # Stretch the inner frame to canvas width ONLY if the
            # inner is narrower than the canvas — that keeps fill=X
            # children looking right while still allowing horizontal
            # scrolling when the content is wider than the viewport.
            inner.update_idletasks()
            inner_w = inner.winfo_reqwidth()
            if evt.width > inner_w:
                canvas.itemconfigure(win, width=evt.width)
            else:
                canvas.itemconfigure(win, width=inner_w)
        inner.bind("<Configure>", _on_inner)
        canvas.bind("<Configure>", _on_canvas)

        # Mouse-wheel scrolling.  Wheel = vertical, Shift+wheel = horizontal.
        def _on_wheel(evt):
            shift = bool(getattr(evt, "state", 0) & 0x0001)
            target_view = canvas.xview_scroll if shift else canvas.yview_scroll
            if evt.num == 4:                       # Linux scroll up
                target_view(-3, "units")
            elif evt.num == 5:                     # Linux scroll down
                target_view( 3, "units")
            elif hasattr(evt, "delta") and evt.delta:
                # macOS gives small deltas (1, -1); Windows gives
                # multiples of 120.  Normalise.
                step = -evt.delta // (120 if abs(evt.delta) >= 120 else 1)
                target_view(step, "units")

        def _bind(_evt):
            canvas.bind_all("<MouseWheel>",       _on_wheel)
            canvas.bind_all("<Shift-MouseWheel>", _on_wheel)
            canvas.bind_all("<Button-4>",         _on_wheel)
            canvas.bind_all("<Button-5>",         _on_wheel)
        def _unbind(_evt):
            canvas.unbind_all("<MouseWheel>")
            canvas.unbind_all("<Shift-MouseWheel>")
            canvas.unbind_all("<Button-4>")
            canvas.unbind_all("<Button-5>")
        canvas.bind("<Enter>", _bind)
        canvas.bind("<Leave>", _unbind)

        return inner

