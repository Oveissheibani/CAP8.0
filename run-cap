        """Optional convenience: run HERWIG as a subprocess to produce a
        .hepmc3 file, then auto-fill the input-file field.  Loose-coupled:
        we never link against Herwig; we just spawn it.

        The command sequence (per INSTALL_REPORT_HERWIG.md §6) is:
            source $HW_PREFIX/herwig-env.sh
            Herwig read   <input.in>
            Herwig run    <input.run>  --numevents N
        """
        from tkinter import filedialog, simpledialog
        # 1. Pick the .in file (Herwig input deck).
        in_file = filedialog.askopenfilename(
            title="Select Herwig input .in file",
            initialdir="/Users/oveissheibani/LocalHerwig/LocalHerwig/opt/share/Herwig",
            filetypes=[("Herwig input", "*.in"), ("All files", "*")])
        if not in_file:
            return
        in_path = Path(in_file)
        # 2. Ask how many events.
        try:
            n_evt = simpledialog.askinteger(
                "Generate Herwig events",
                f"Number of events for {in_path.name}?",
                initialvalue=1000, minvalue=1, maxvalue=10_000_000)
        except Exception:
            n_evt = None
        if not n_evt:
            return
        # 3. Resolve HW_PREFIX (env or fall back to known local install).
        hw_prefix = os.environ.get(
            "HW_PREFIX",
            "/Users/oveissheibani/LocalHerwig/LocalHerwig/opt")
        if not (Path(hw_prefix) / "bin" / "Herwig").is_file():
            messagebox.showerror("run-cap",
                f"Herwig binary not found at {hw_prefix}/bin/Herwig.\n"
                "Set HW_PREFIX in your environment, or edit "
                "_compose_run_herwig in run-cap to point at your install.")
            return

        out_dir = in_path.parent / f"{in_path.stem}_run"
        out_dir.mkdir(exist_ok=True)
        out_hepmc = out_dir / f"{in_path.stem}.hepmc"

        self._append(f"\n=== Running Herwig ({hw_prefix}) ===\n", "ok")
        self._append(f"  input deck : {in_path}\n", "info")
        self._append(f"  events     : {n_evt}\n", "info")
        self._append(f"  output dir : {out_dir}\n", "info")

        env_script = Path(hw_prefix) / "herwig-env.sh"
        cmd = (
            f'source "{env_script}" && '
            f'cd "{out_dir}" && '
            f'cp "{in_path}" . && '
            f'Herwig read "{in_path.name}" && '
            f'Herwig run  "{in_path.stem}.run" --numevents {n_evt}'
        )

        def worker():
            try:
                rc = subprocess.call(["bash", "-lc", cmd])
                if rc == 0:
                    candidates = sorted(out_dir.glob("*.hepmc")) + \
                                 sorted(out_dir.glob("*.hepmc3"))
                    found = candidates[0] if candidates else out_hepmc
                    self.root.after(0, lambda p=found: (
                        self.compose_hepmc3_file_var.set(str(p)),
                        self._append(f"\n=== Herwig done — file: {p} ===\n", "ok")))
                else:
                    self.root.after(0, lambda r=rc: self._append(
                        f"\n!!! Herwig exited with code {r} ===\n", "error"))
            except Exception as exc:
                self.root.after(0, lambda e=exc: self._append(
                    f"\n!!! Herwig launch failed: {e}\n", "error"))

        threading.Thread(target=worker, daemon=True).start()

