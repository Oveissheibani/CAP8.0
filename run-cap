    def _row(self, parent: ttk.Frame, row: int, label: str,
             var: tk.StringVar, *, readonly: bool, on_change=None,
             width: int = 60) -> tk.Widget:
        ttk.Label(parent, text=label, width=32).grid(
            row=row, column=0, sticky="w", padx=8, pady=4)
        if readonly:
            w = ttk.Combobox(parent, textvariable=var, state="readonly", width=width)
            if on_change:
                w.bind("<<ComboboxSelected>>", lambda _evt: on_change())
        else:
            w = ttk.Entry(parent, textvariable=var, width=width)
        w.grid(row=row, column=1, sticky="ew", padx=8, pady=4)
        return w

    # -- Project / .ini / task chain --------------------------------------
    def _refresh_projects(self) -> None:
        projects = list_projects()
        rels = [project_relpath(p) for p in projects]
        self._project_paths = {project_relpath(p): p for p in projects}
        # Legacy "Run existing .ini" tab has been retired — combos are
        # None.  We still maintain the list of projects in self._project_paths
        # because Compose-tab plot launchers may want to enumerate them.
        if self.project_combo is not None:
            self.project_combo["values"] = rels
            if rels and self.project_var.get() not in rels:
                self.project_var.set(rels[0])
            self._on_project_change()
        self._append(f"Found {len(rels)} project(s) in projects/.", "info")

    def _on_project_change(self) -> None:
        # Combo widgets removed when legacy tab was retired — no-op here.
        if self.ini_combo is None:
            return
        rel = self.project_var.get()
        d = getattr(self, "_project_paths", {}).get(rel)
        rows = list_inis_for_project(d) if d else []
        # rows is [(display, raw), ...]. The combobox shows the display name;
        # we keep a {display: raw} map for resolution.
        displays = [display for (display, _raw) in rows]
        self._ini_display_to_raw = {display: raw for (display, raw) in rows}
        self.ini_combo["values"] = displays
        if displays and self.ini_var.get() not in displays:
            self.ini_var.set(displays[0])
        self._on_ini_change()

    def _on_ini_change(self) -> None:
        # No-op when the legacy tab isn't rendered (combos are None).
        if self.task_combo is None:
            return
        rel = self.project_var.get()
        d = getattr(self, "_project_paths", {}).get(rel)
        if not d:
            self.task_combo["values"] = []
            self.task_var.set("")
            return
        display = self.ini_var.get()
        ini = getattr(self, "_ini_display_to_raw", {}).get(display, display)
        if not ini:
            self.task_combo["values"] = []
            self.task_var.set("")
            return
        tasks = list_tasks_in_ini(d / ini)
        self.task_combo["values"] = tasks
        if tasks and self.task_var.get() not in tasks:
            self.task_var.set(tasks[0])
        # Surface a warning if the user has selected a legacy .ini.
        if "(legacy format)" in display:
            self._append(
                f"⚠  {ini} uses the legacy SubTaskName syntax. The current CAP\n"
                "   loader expects Subtask<N>:TaskName=… — the run will likely\n"
                "   fail with UnknownClassException. Pick a 'RunAna*' file instead.\n",
                "warn"
            )

