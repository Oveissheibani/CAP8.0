    # =================================================================
    #  N × M Subsample grid runner (single-CPU, sequential)
    # =================================================================
    def _launch_subsample_grid(self, *, name: str, outdir: str, n_evt: int,
                                kind, energy: float, idA: int, idB: int,
                                base_seed: int,
                                choices: list, run_derived: bool, run_bf: bool,
                                n_rows: int, n_cols: int) -> None:
        """Validate, compose the FIRST .ini for sanity, then spawn the
        long-running worker thread that drives the N×M grid + two-phase
        aggregation."""
        cap_bin = REPO / "bin" / "CAP"
        if not cap_bin.is_file():
            messagebox.showerror("run-cap",
                "bin/CAP not found. Build CAP first via ./install --gui.")
            return

        n_total = n_rows * n_cols
        # Confirm with the user — large grids are expensive (~1 min/job).
        eta_minutes = n_total * 1.0   # very rough: ~60 s per 1000-event chain
        if not messagebox.askyesno(
            "run-cap",
            f"Subsample grid: {n_rows} × {n_cols} = {n_total} jobs "
            f"× {n_evt} events each.\n\n"
            f"Approximate wall-clock (sequential, single CPU): "
            f"~{eta_minutes:.0f} min for 1000 events / job (scales linearly).\n\n"
            f"Output: histos/{outdir}/raw_i_j/, then sub_i/, then final/.\n\n"
            f"Proceed?"
        ):
            return

        env = os.environ.copy()
        env.setdefault("CAP_ROOT_PATH", str(REPO))
        env["CAP_PROJECTS_PATH"] = str(REPO / "projects")
        for k in ("DYLD_LIBRARY_PATH", "LD_LIBRARY_PATH"):
            v = env.get(k, "")
            our = str(REPO / "lib")
            if our not in v.split(":"):
                env[k] = our + (":" + v if v else "")

        self._append(f"\n=== launching subsample grid: "
                     f"{n_rows}×{n_cols} = {n_total} jobs ===\n", "ok")
        self.run_btn.config(state=tk.DISABLED)
        self.stop_btn.config(state=tk.NORMAL)
        # Initialise stats panel for the grid run.
        import time as _time
        self._stats_start_time   = _time.time()
        self._stats_stage_start  = _time.time()
        self._current_outdir     = REPO / "histos" / outdir
        self._current_stage_name = f"grid 0/{n_total}"
        self.stats_files_var.set("0")
        self.stats_ini_var.set(f"{name}.ini  (×{n_total})")

        threading.Thread(
            target=self._run_subsample_grid_worker,
            args=(name, outdir, n_evt, kind, energy, idA, idB, base_seed,
                  choices, run_derived, run_bf, n_rows, n_cols, env),
            daemon=True,
        ).start()

    def _run_subsample_grid_worker(self, name, outdir, n_evt, kind, energy,
                                    idA, idB, base_seed, choices,
                                    run_derived, run_bf,
                                    n_rows, n_cols, env) -> None:
        """Sequentially run N×M chain runs, then aggregate.  Each job:
          - Re-render the .ini with seed = base_seed + i*n_cols + j
          - Output dir: <outdir>/raw_{i}_{j}/
          - Run the bin/CAP chain (Stage 1 + optional 2 + 3)
          - On completion advance the progress counter
        Then two phases of aggregation via subsample_aggregator.
        """
        import time
        n_total = n_rows * n_cols
        cap_bin = REPO / "bin" / "CAP"
        completed = 0
        failed: list[str] = []
        grid_t0 = time.time()
        self._chain_cancel = False

        for i in range(n_rows):
            for j in range(n_cols):
                if self._chain_cancel:
                    break

                this_seed   = base_seed + i * n_cols + j
                this_outdir = f"{outdir}/raw_{i}_{j}"

                # Compose a per-job Job (same params, different seed).
                job = Job(
                    name=f"{name}_{i}_{j}",
                    output_dir=this_outdir,
                    n_events=n_evt,
                    n_events_report=max(1, n_evt // 10),
                    generator=Generator(kind=kind, energy=energy,
                                        idA=idA, idB=idB, seed=this_seed),
                    particle_filters=default_particle_filters(),
                    event_filters=default_event_filters(),
                    analyses=choices,
                    binning=Binning.default(),
                    run_derived=run_derived,
                    run_bf=run_bf,
                )
                ini_path = REPO / "analyses" / "projects" / f"{name}_{i}_{j}.ini"
                try:
                    write_ini(job, ini_path)
                except Exception as exc:
                    self.root.after(0, lambda e=exc: self._append(
                        f"!!! could not write per-job .ini: {e}\n", "error"))
                    failed.append(f"raw_{i}_{j}")
                    continue

                # Pre-create the output dir.  IMPORTANT: leave the env
                # vars at REPO/histos.  bin/CAP joins env-var path with
                # the outdir argument we pass on the command line —
                # setting the env var to the per-job dir AND passing
                # the per-job dir as the arg produces doubled paths
                # like histos/demo_run/raw_0_0/demo_run/raw_0_0/.
                export_dir = REPO / "histos" / this_outdir
                export_dir.mkdir(parents=True, exist_ok=True)
                env["CAP_HISTOS_IMPORT_PATH"] = str(REPO / "histos")
                env["CAP_HISTOS_EXPORT_PATH"] = str(REPO / "histos")

                # Build the per-stage chain.
                stages: list[tuple[str, str]] = [("RunAnalysis", "stage 1")]
                if run_derived: stages.append(("RunDerived", "stage 2"))
                if run_bf:      stages.append(("RunBf",      "stage 3"))
                cmd_chain = [([str(cap_bin), task,
                               str(ini_path.parent), ini_path.name, this_outdir],
                              label) for (task, label) in stages]

                idx = i * n_cols + j + 1
                stage_t0 = time.time()
                self._stats_stage_start  = stage_t0
                self._current_stage_name = f"grid {idx}/{n_total}  raw_{i}_{j}"
                self.root.after(0, lambda i=i, j=j, idx=idx, n=n_total:
                                self.status_var.set(
                                    f"Subsample grid {idx}/{n}: raw_{i}_{j} …"))
                self.root.after(0, lambda i=i, j=j, s=this_seed: self._append(
                    f"\n● raw_{i}_{j}  (seed={s})\n", "ok"))

                # Run the chain (blocking — stays in this worker thread).
                rc = 0
                for cmd, label in cmd_chain:
                    if self._chain_cancel:
                        rc = 130
                        break
                    self.log.line("INFO", f"raw_{i}_{j} {label}: "
                                          f"{' '.join(cmd)}")
                    try:
                        rc = self._spawn_streaming(cmd, env, stage_t0)
                    except Exception as exc:
                        self.log.line("ERROR", f"raw_{i}_{j} {label}: {exc}")
                        rc = 1
                    finally:
                        with self.proc_lock:
                            self.proc = None
                    if rc != 0:
                        break

                # Clean up per-job .ini.
                try: ini_path.unlink()
                except OSError: pass

                if rc == 0:
                    completed += 1
                else:
                    failed.append(f"raw_{i}_{j}")
                    self.root.after(0, lambda i=i, j=j, r=rc: self._append(
                        f"!!! raw_{i}_{j} exit={r} — continuing with the rest\n",
                        "error"))
            if self._chain_cancel:
                break

        elapsed = time.time() - grid_t0
        self.root.after(0, lambda c=completed, n=n_total, e=elapsed:
                        self._append(
                            f"\n=== grid done: {c}/{n} successful "
                            f"({len(failed)} failed)  total {e/60:.1f} min ===\n",
                            "ok" if not failed else "warn"))

        if self._chain_cancel:
            self.root.after(0, lambda: self._on_run_done(130))
            return

        # Decoupled design: the grid runner only produces raw_i_j/ dirs.
        # Aggregation is a separate manual step performed from the
        # "Subsample" tab — that lets the user pick what to aggregate
        # and how (hierarchical / row-only / flat).
        self.root.after(0, lambda: self._append(
            f"\n=== grid finished — raw_i_j/ dirs are under "
            f"histos/{outdir}/.  Use the Subsample tab to aggregate. ===\n",
            "ok"))
        self.root.after(0, lambda: self._on_run_done(0))

