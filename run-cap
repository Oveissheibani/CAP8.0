    def _open_full_builder(self) -> None:
        prog = REPO / "analyses" / "builder" / "build-ini-gui"
        if prog.exists():
            try:
                subprocess.Popen([str(prog)], cwd=str(REPO))
            except OSError as exc:
                messagebox.showerror("run-cap", f"Could not launch: {exc}")

    def _compose_and_run(self) -> None:
        """Compose a Job from the Compose tab, write it under
        analyses/projects/<name>.ini, and execute it."""
        if not _BUILDER_OK:
            messagebox.showerror("run-cap", "Builder unavailable; see startup log.")
            return
        try:
            name    = self.compose_name_var.get().strip() or "my_run"
            outdir  = self.compose_outdir_var.get().strip() or name
            n_evt   = max(1, int(self.compose_nevents_var.get() or 1))
            kind    = GeneratorKind(self.compose_gen_var.get())
            energy  = float(self.compose_energy_var.get() or 13000)
            idA     = int(self.compose_idA_var.get() or 2212)
            idB     = int(self.compose_idB_var.get() or 2212)
            seed    = int(self.compose_seed_var.get() or 12345)
            n_rows  = max(1, int(self.compose_grid_n_var.get() or 1))
            n_cols  = max(1, int(self.compose_grid_m_var.get() or 1))
        except (ValueError, KeyError) as exc:
            messagebox.showerror("run-cap", f"Invalid input: {exc}")
            return

        choices = [AnalysisChoice[k] for k, v in self.compose_choice_vars.items() if v.get()]
        if not choices:
            messagebox.showerror("run-cap",
                "Pick at least one analysis (Global / Single / Pair / …).")
            return

        # ---- Generator=Herwig is silently routed through the file-based
        # HepMC3 path.  Reason: the embedded ThePEG/Herwig in-process
        # event loop is non-deterministically unstable on macOS clang
        # (~50% crash rate inside ThePEG::MEBase::diagram on the 2nd
        # shoot()).  Standalone `Herwig run` is rock-solid.  We spawn
        # it, get a .hepmc file, and feed it to HepMC3EventReader —
        # which is already proven.  See LETTER_TO_HERWIG_AGENT.md for
        # the full diagnosis.  The embedded code stays in the repo as
        # an experimental option but isn't used by default.
        # Note: we preserve the *original* kind name for the output
        # folder so user files still land under histos/Herwig/...
        original_kind = kind
        if kind == GeneratorKind.HERWIG:
            hepmc_path = self._herwig_to_hepmc(n_evt)
            if hepmc_path is None:
                return     # cancelled / generation failed; user already saw a message
            kind = GeneratorKind.HEPMC3
            self.compose_hepmc3_file_var.set(str(hepmc_path))

        run_derived = bool(self.compose_run_derived_var.get())
        run_bf      = bool(self.compose_run_bf_var.get())
        # BF reads derived histograms; auto-imply.
        if run_bf:
            run_derived = True

        # Branch: subsample grid mode if N>1 or M>1.
        # Output layout is now:
        #   histos/<GeneratorName>/<KeepProfile>/<Stage>/<user_outdir>/
        # — generator folder isolates Pythia / Herwig / HepMC3 outputs;
        # keep-profile folder isolates different particle-selection runs
        # (default = "final", "+g" for photons added, "all_status" for
        # no status filter, etc.); stage folder isolates per-stage BF
        # (final_hadrons / intermediate_hadrons / partons / leptons).
        # Use original_kind so a Herwig run redirected through HepMC3
        # still lands under histos/Herwig/.
        keep_slug = _keep_profile_folder(
            final_only   = self.compose_keep_final_only_var.get(),
            quarks       = self.compose_keep_quarks_var.get(),
            neutrinos    = self.compose_keep_neutrinos_var.get(),
            photons      = self.compose_keep_photons_var.get(),
            gauge_bosons = self.compose_keep_gauge_bosons_var.get(),
        )
        stage_key = self.compose_stage_var.get().strip() or "final_hadrons"
        # Resolve the stage's filter set + KeepStatuses spec.  Falls
        # back to final_hadrons if the user picked an unknown key.
        stage_filters_fn, stage_status_spec = STAGE_FILTER_SETS.get(
            stage_key, STAGE_FILTER_SETS["final_hadrons"])
        outdir_prefixed = (
            f"{_generator_folder(original_kind)}/{keep_slug}/{stage_key}/{outdir}"
        )

        if n_rows > 1 or n_cols > 1:
            self._launch_subsample_grid(
                name=name, outdir=outdir_prefixed, n_evt=n_evt,
                kind=kind, energy=energy, idA=idA, idB=idB,
                base_seed=seed, choices=choices,
                run_derived=run_derived, run_bf=run_bf,
                n_rows=n_rows, n_cols=n_cols,
            )
            return
        job = Job(
            name=name,
            output_dir=outdir_prefixed,
            n_events=n_evt,
            n_events_report=max(1, n_evt // 10),
            generator=Generator(
                kind=kind, energy=energy,
                idA=idA, idB=idB, seed=seed,
                # Universal particle-keep flags — apply to Pythia,
                # Herwig, and HepMC3 reader uniformly.
                keep_final_only   = self.compose_keep_final_only_var.get(),
                keep_quarks       = self.compose_keep_quarks_var.get(),
                keep_neutrinos    = self.compose_keep_neutrinos_var.get(),
                keep_photons      = self.compose_keep_photons_var.get(),
                keep_gauge_bosons = self.compose_keep_gauge_bosons_var.get(),
                # BF-per-stage: KeepStatuses spec for the chosen stage.
                # Empty falls back to keep_final_only behaviour.
                keep_statuses     = stage_status_spec,
                hepmc3_input_file=self.compose_hepmc3_file_var.get().strip(),
                herwig_run_file=(
                    self.compose_herwig_run_var.get().strip()
                    or (str(REPO / "histos" / "_herwig_scratch" / "LHC.run")
                        if (REPO / "histos" / "_herwig_scratch" / "LHC.run").is_file()
                        else "")
                ),
                herwig_lhapdf_data_path=self.compose_herwig_lhapdf_var.get().strip(),
                herwig_plugin_path=self.compose_herwig_plugin_var.get().strip(),
                # Generator-config extras (preset + panel + custom string)
                pythia_preset_name    = self._pythia_cfg_state["preset"],
                pythia_extra_options  = collect_pythia_strings(
                    self._pythia_cfg_state["preset"],
                    self._pythia_cfg_state["panels"],
                    self._pythia_cfg_state.get("numeric", {}),
                    self._pythia_cfg_state["custom"],
                    self._pythia_cfg_state.get("stable", []),
                    ctau_max_mm=(self._pythia_cfg_state.get("ctau_value")
                                 if self._pythia_cfg_state.get("ctau_enable")
                                 else None)),
                herwig_preset_name    = self._herwig_cfg_state["preset"],
                herwig_extra_in_lines = collect_herwig_lines(
                    self._herwig_cfg_state["preset"],
                    self._herwig_cfg_state["panels"],
                    self._herwig_cfg_state.get("numeric", {}),
                    self._herwig_cfg_state["custom"],
                    self._herwig_cfg_state.get("stable", []),
                    ctau_max_mm=(self._herwig_cfg_state.get("ctau_value")
                                 if self._herwig_cfg_state.get("ctau_enable")
                                 else None)),
            ),
            # Use the stage-specific particle filter set so the analyzer
            # sees the right species for this stage of the cascade.
            particle_filters=stage_filters_fn(),
            event_filters=default_event_filters(),
            analyses=choices,
            binning=Binning.default(),
            run_derived=run_derived,
            run_bf=run_bf,
        )
        # Cache the herwig user-extras list so _herwig_inject_hepmc_and_read
        # can splice them into the scratch deck right before saverun.
        self._herwig_extra_lines = list(job.generator.herwig_extra_in_lines)

        ini_path = REPO / "analyses" / "projects" / f"{name}.ini"
        try:
            write_ini(job, ini_path)
        except Exception as exc:
            messagebox.showerror("run-cap", f"Could not write .ini: {exc}")
            return

        self._append(f"\n✓ Wrote {ini_path}\n", "ok")
        self.log.line("INFO", f"composed {ini_path}")

        # Now invoke bin/CAP <Task> <project_dir> <ini_filename> <output_dir>
        cap_bin = REPO / "bin" / "CAP"
        if not cap_bin.is_file():
            messagebox.showerror("run-cap",
                "bin/CAP not found. Build CAP first (./install --gui).")
            return

        env = os.environ.copy()
        env.setdefault("CAP_ROOT_PATH", str(REPO))
        env["CAP_PROJECTS_PATH"] = str(REPO / "projects")
        env.setdefault("CAP_HISTOS_IMPORT_PATH", str(REPO / "histos"))
        env.setdefault("CAP_HISTOS_EXPORT_PATH", str(REPO / "histos"))
        for k in ("DYLD_LIBRARY_PATH", "LD_LIBRARY_PATH"):
            v = env.get(k, "")
            our = str(REPO / "lib")
            if our not in v.split(":"):
                env[k] = our + (":" + v if v else "")

        # ROOT's TFile won't auto-create parent directories — ensure
        # histos/<outdir_prefixed>/ exists or the run will crash at the
        # very end of finalize() when ManagedObjects::exportObject()
        # opens the output .root file.  Use outdir_prefixed (which
        # includes the generator-folder prefix like 'Herwig/...') so
        # outputs land in the right subtree.
        export_dir = REPO / "histos" / outdir_prefixed
        export_dir.mkdir(parents=True, exist_ok=True)
        self._append(f"  → output directory: {export_dir}\n", "info")

        # Build the chain of bin/CAP invocations: RunAnalysis is
        # always first; RunDerived runs second if requested; RunBf
        # runs third (and implies RunDerived).  Each stage uses the
        # SAME .ini file, picking off its own top-level task block.
        stages = [("RunAnalysis", "main analysis (events → histograms)")]
        if run_derived:
            stages.append(("RunDerived",
                           "derived histograms (Single / Pair / Pair3D / Global)"))
        if run_bf:
            stages.append(("RunBf",
                           "balance functions from pair histograms"))

        cmd_chain = [
            ([str(cap_bin), task,
              str(ini_path.parent), ini_path.name, outdir_prefixed],
             label)
            for (task, label) in stages
        ]

        for cmd, label in cmd_chain:
            self._append(f"\n● {label}\n", "ok")
            self._append(f"$ {' '.join(shlex.quote(c) for c in cmd)}\n", "info")
