    def _save_perf_snapshot(self) -> None:
        """Write the current chart history to disk as
            histos/_perf_snapshots/<TS>/timeseries.csv
            histos/_perf_snapshots/<TS>/cpu.ps   mem.ps   files.ps   evps.ps
            histos/_perf_snapshots/<TS>/stages.txt
        Optionally combines the .ps files into one PDF if `ps2pdf` is on
        the user's PATH (Mac with Ghostscript / TeX install)."""
        import csv, datetime, shutil, subprocess as sp
        ts = datetime.datetime.now().strftime("%Y%m%dT%H%M%S")
        out = REPO / "histos" / "_perf_snapshots" / ts
        try:
            out.mkdir(parents=True, exist_ok=True)
        except OSError as exc:
            if self._perf_status_var is not None:
                self._perf_status_var.set(f"Cannot mkdir {out}: {exc}")
            return

        # 1. Write the time-series CSV.
        csv_path = out / "timeseries.csv"
        try:
            with csv_path.open("w", newline="") as fh:
                w = csv.writer(fh)
                w.writerow(["elapsed_s", "cpu_pct", "rss_mib",
                            "n_root_files", "events_per_sec"])
                for s in list(self._stats_history):
                    # tolerate legacy 3-tuple history
                    if len(s) >= 5: row = list(s[:5])
                    else:           row = list(s) + [0.0] * (5 - len(s))
                    w.writerow(row)
        except OSError as exc:
            if self._perf_status_var is not None:
                self._perf_status_var.set(f"CSV write failed: {exc}")
            return

        # 2. Stage markers as plain text.
        try:
            (out / "stages.txt").write_text(
                "\n".join(f"{t:.2f}\t{name}\t{kind}"
                          for t, name, kind in self._stage_markers) + "\n")
        except OSError:
            pass

        # 3. PostScript per chart (Tk's built-in vector export).
        ps_files = []
        for name, cv in self._chart_canvases.items():
            ps_path = out / f"{name}.ps"
            try:
                cv.postscript(file=str(ps_path), colormode="color")
                ps_files.append(ps_path)
            except Exception:
                pass

        # 4. Try to combine into one PDF via ps2pdf if available.
        pdf_path = None
        ps2pdf = shutil.which("ps2pdf")
        if ps2pdf and ps_files:
            try:
                pdf_parts = []
                for ps in ps_files:
                    p = out / (ps.stem + ".pdf")
                    sp.run([ps2pdf, str(ps), str(p)],
                           check=True, timeout=20)
                    pdf_parts.append(p)
                # Stitch with `pdftk` if present, else leave per-chart PDFs.
                pdftk = shutil.which("pdftk")
                if pdftk and pdf_parts:
                    pdf_path = out / "snapshot.pdf"
                    sp.run([pdftk, *map(str, pdf_parts),
                            "cat", "output", str(pdf_path)],
                           check=True, timeout=20)
            except Exception:
                pass

        msg = f"Saved snapshot → {out.relative_to(REPO)}"
        if pdf_path:
            msg += f"   (PDF: {pdf_path.name})"
        else:
            msg += f"   ({len(ps_files)} PostScript files + CSV)"
        if self._perf_status_var is not None:
            self._perf_status_var.set(msg)
        try:
            self._append(f"\n📸 {msg}\n", "ok")
        except Exception:
            pass

    # -- Live perf chart redraw -------------------------------------------
    def _redraw_chart(self) -> None:
        """Re-render the 4 rolling charts (CPU / RAM / files / events-per-sec)
        from self._stats_history.  Pure Tk drawing primitives, no extra deps.
        Stage transitions are drawn as vertical dotted lines + light shaded
        regions.  No-op if the perf window is closed."""
        if (self._perf_window is None
                or not self._perf_window.winfo_exists()
                or not self._chart_canvases):
            return
        try:
            hist = list(self._stats_history)
            if not hist:
                return

            # Migrate any legacy 3-tuple entries (elapsed, cpu, rss) to
            # 5-tuples so the rest of this function can index uniformly.
            normalized = []
            for s in hist:
                if len(s) >= 5:
                    normalized.append(s[:5])
                else:
                    normalized.append(tuple(s) + (0.0,) * (5 - len(s)))
            hist = normalized

            t0 = hist[0][0]
            tn = hist[-1][0]
            span = tn - t0 if tn > t0 else 1.0

            chart_specs = [
                ("cpu",    1, self._chart_cpu_color,
                 "CPU",  "%",   "cpu"),
                ("mem",    2, self._chart_mem_color,
                 "RAM",  "MiB", "mem"),
                ("files",  3, self._chart_files_color,
                 "Files",".root", "count"),
                ("evps",   4, self._chart_evps_color,
                 "Throughput","ev/s","rate"),
            ]

            for name, idx, color, label, unit, scale_kind in chart_specs:
                canvas = self._chart_canvases.get(name)
                if canvas is None:
                    continue
                w = canvas.winfo_width()  or 440
                h = canvas.winfo_height() or 220
                pad_l, pad_r, pad_t, pad_b = 56, 12, 22, 22
                px_w = max(1, w - pad_l - pad_r)
                px_h = max(1, h - pad_t - pad_b)

                canvas.delete("all")

                values = [s[idx] for s in hist]
                vmax = max(values) if values else 0.0
                # Per-axis "nice" max picker.
                if scale_kind == "cpu":
                    plot_max = max(100.0,
                                   ((int(vmax) // 100) + 1) * 100.0)
                elif scale_kind == "mem":
                    if   vmax < 64:    step = 16
                    elif vmax < 256:   step = 64
                    elif vmax < 1024:  step = 256
                    else:              step = 1024
                    plot_max = max(step, ((int(vmax) // step) + 1) * step)
                elif scale_kind == "count":
                    plot_max = max(10.0, ((int(vmax) // 5) + 1) * 5.0)
                else:                       # "rate"
                    if   vmax < 10:    step = 2
                    elif vmax < 100:   step = 25
                    elif vmax < 1000:  step = 100
                    else:              step = 1000
                    plot_max = max(step, ((int(vmax) // step) + 1) * step)

                # ---- Build stage runs (begin_t, end_t, name) for the
                # vertical-line annotations below.  We deliberately do
                # NOT shade the background — keeps the plot clean.
                stage_runs = []
                stack = []
                for ev in self._stage_markers:
                    et, en, kind = ev
                    if kind == "begin":
                        stack.append((et, en))
                    elif kind == "end" and stack:
                        bt, bn = stack.pop()
                        stage_runs.append((bt, et, bn))
                for bt, bn in stack:
                    stage_runs.append((bt, tn, bn))

                # ---- Frame + horizontal grid + Y labels
                canvas.create_rectangle(pad_l, pad_t, w - pad_r, h - pad_b,
                                        outline=self._chart_axis_color)
                for frac in (0.25, 0.50, 0.75):
                    y = pad_t + (1.0 - frac) * px_h
                    canvas.create_line(pad_l, y, w - pad_r, y,
                                       fill=self._chart_grid_color, dash=(1, 3))
                    canvas.create_text(pad_l - 4, y, anchor="e",
                                       fill=self._chart_label_fill,
                                       font=("TkDefaultFont", 8),
                                       text=f"{plot_max*frac:.0f}")
                canvas.create_text(pad_l - 4, h - pad_b, anchor="e",
                                   fill=self._chart_label_fill,
                                   font=("TkDefaultFont", 8), text="0")
                canvas.create_text(pad_l - 4, pad_t, anchor="e",
                                   fill=self._chart_label_fill,
                                   font=("TkDefaultFont", 8),
                                   text=f"{plot_max:.0f}")

                # ---- Stage vertical lines + name labels
                for bt, et, sname in stage_runs:
                    x = pad_l + ((bt - t0) / span) * px_w
                    canvas.create_line(x, pad_t, x, h - pad_b,
                                       fill=self._chart_axis_color,
                                       dash=(2, 3))
                    canvas.create_text(x + 3, pad_t + 1, anchor="nw",
                                       fill=self._chart_label_fill,
                                       font=("TkDefaultFont", 7),
                                       text=sname)

                # ---- Polyline of samples (line only — no area fill)
                n = len(values)
                if n >= 2:
                    coords = []
                    for i, v in enumerate(values):
                        x = pad_l + ((hist[i][0] - t0) / span) * px_w
                        y = pad_t + (1.0 - min(v, plot_max) / plot_max) * px_h
                        coords += [x, y]
                    canvas.create_line(*coords, fill=color, width=2,
                                       smooth=False)

                # ---- Top-left legend: current + peak + average
                cur  = values[-1]
                peak = vmax
                avg  = sum(values) / len(values)
                canvas.create_text(pad_l + 6, pad_t + 4, anchor="nw",
                                   fill=color,
                                   font=("TkDefaultFont", 10, "bold"),
                                   text=label)
                canvas.create_text(pad_l + 6, pad_t + 18, anchor="nw",
                                   fill=self._chart_label_fill,
                                   font=("TkDefaultFont", 9),
                                   text=(f"now {cur:>7.1f} {unit}   "
                                         f"peak {peak:>7.1f}   "
                                         f"avg {avg:>7.1f}"))

                # ---- X-axis "window" annotation
                if span >= 60:
                    spanstr = f"{int(span//60):d}m{int(span%60):02d}s"
                else:
                    spanstr = f"{span:.0f}s"
                canvas.create_text(w - pad_r, h - 4, anchor="se",
                                   fill=self._chart_label_fill,
                                   font=("TkDefaultFont", 7),
                                   text=f"window: {spanstr}  ({n} samples)")
        except Exception:
            # Chart is best-effort — never crash the GUI from here.
            pass

    def _on_close(self) -> None:
        # Cancel any in-flight chain so the worker thread stops looping
        # to the next stage; SIGTERM the current subprocess.  Without
        # this an orphaned bin/CAP keeps running after the GUI closes.
        self._chain_cancel = True
        with self.proc_lock:
            if self.proc:
                try:
                    self.proc.terminate()
                except OSError:
                    pass
        self.log.line("INFO", "GUI closed by user")
        self.log.close(0)
        self.root.destroy()

    def run(self) -> None:
        self.root.mainloop()


def main() -> None:
    try:
        gui = RunCapGUI()
        gui.run()
    except tk.TclError as exc:
        sys.stderr.write(
            "\nCould not initialise the Tk display layer:\n"
            f"  {exc}\n\n"
            "If you're on a server without a display, run CAP directly:\n"
            f"  source SetupCAP.sh\n"
            f"  ./bin/CAP <task> <project> <ini> <output>\n"
        )
        sys.exit(2)


if __name__ == "__main__":
    main()
