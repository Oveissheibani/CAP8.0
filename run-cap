        )
        return job

    def _wsu_generate(self) -> None:
        try:
            job = self._wsu_collect_job()
        except Exception as exc:
            messagebox.showerror("WSU", f"Could not assemble job: {exc}")
            return
        local_root = Path(self.wsu_local_outdir.get().strip()
                          or str(REPO / "Grid" / "WSU" / "auto"))
        local_root.mkdir(parents=True, exist_ok=True)
        try:
            written = wsu_write_bundle(job, local_root)
        except Exception as exc:
            messagebox.showerror("WSU", f"Bundle generation failed: {exc}")
            return
        self.wsu_status_var.set(
            f"✓ {len(written)} files in {local_root / job.name}")
        self._append(
            f"✓ WSU bundle written: {local_root / job.name}/  "
            f"({len(written)} files)\n", "ok")
        for p in written:
            self._append(f"    {p.name}\n")
        self.log.line("INFO", f"WSU bundle written: {local_root / job.name}")

    def _wsu_open_bundle(self) -> None:
        local_root = Path(self.wsu_local_outdir.get().strip()
                          or str(REPO / "Grid" / "WSU" / "auto"))
        target = local_root / (self.wsu_name_var.get().strip() or "run01")
        if not target.is_dir():
            messagebox.showinfo("WSU",
                f"No bundle here yet:\n{target}\n\n"
                f"Click ▶ Generate scripts first.")
            return
        self._open_path(target)

    def _refresh_subsample_sources(self) -> None:
        """Populate the source dropdown with subdirectories that look
        aggregatable.  Three layouts coexist transparently:
          1. Generator + Keep-profile (NEWEST):
             histos/<Generator>/<KeepProfile>/<name>/raw_i_j/...
             Shown as "Pythia/final/<name>", "Herwig/final+g/<name>", etc.
          2. Generator-prefixed (older):
             histos/<Generator>/<name>/raw_i_j/...
             Shown as "Pythia/<name>", "Herwig/<name>", etc.
          3. Flat (legacy):
             histos/<name>/...
             Shown as just "<name>".
        We disambiguate by checking whether the depth-2 children look
        like keep-profile slugs (start with 'final' or 'all_status') or
        like raw_i_j subdirs."""
        histos = REPO / "histos"
        candidates: list[str] = []
        # Known generator folders we recurse into.
        gen_folders = {"Pythia", "Herwig", "HepMC3", "Therminator",
                       "Glauber", "Basic", "EPOS", "PHSD", "Misc"}
        if histos.is_dir():
            for sub in sorted(histos.iterdir()):
                if not sub.is_dir():
                    continue
                if sub.name in gen_folders:
                    for child in sorted(sub.iterdir()):
                        if not child.is_dir():
                            continue
                        is_keep = (child.name.startswith("final") or
                                   child.name.startswith("all_status"))
                        if is_keep:
                            # NEW layout: <Generator>/<KeepProfile>/<run>/
                            for run in sorted(child.iterdir()):
                                if not run.is_dir(): continue
                                if any(c.is_dir() for c in run.iterdir()):
                                    candidates.append(
                                        f"{sub.name}/{child.name}/{run.name}")
                        else:
                            # OLDER layout: <Generator>/<run>/
                            if any(c.is_dir() for c in child.iterdir()):
                                candidates.append(f"{sub.name}/{child.name}")
                else:
                    # Flat / legacy.
                    if any(c.is_dir() for c in sub.iterdir()):
                        candidates.append(sub.name)
        self.subsample_source_combo["values"] = candidates
        if candidates and (not self.subsample_source_var.get()
                           or self.subsample_source_var.get() not in candidates):
            self.subsample_source_var.set(candidates[0])
        self._on_subsample_source_change()

    def _on_subsample_source_change(self) -> None:
        """Detect what's in the chosen source and update the info label."""
        import re
        src = self.subsample_source_var.get().strip()
        if not src:
            self.subsample_detect_var.set("(no folder selected)")
            return
        src_path = REPO / "histos" / src
        if not src_path.is_dir():
            self.subsample_detect_var.set(f"folder does not exist: {src_path}")
            return

        rows: set[int] = set()
        cols: set[int] = set()
        all_subs: list[str] = []
        for c in src_path.iterdir():
            if not c.is_dir():
                continue
            all_subs.append(c.name)
            m = re.match(r"raw_(\d+)_(\d+)", c.name)
            if m:
                rows.add(int(m.group(1)))
                cols.add(int(m.group(2)))

        if rows and cols:
            n = max(rows) + 1
            mc = max(cols) + 1
            present = sum(
                1 for c in src_path.iterdir() if c.is_dir()
                and re.match(r"raw_\d+_\d+", c.name))
            self.subsample_detect_var.set(
                f"Hierarchical layout detected: "
                f"{n} rows × {mc} cols  ({present}/{n*mc} raw_i_j/ dirs present)")
        else:
            preview = ", ".join(sorted(all_subs)[:6])
            more = "…" if len(all_subs) > 6 else ""
            self.subsample_detect_var.set(
                f"Flat layout: {len(all_subs)} subdirectories  "
                f"({preview}{more})"
                if all_subs else "no subdirectories under this folder")

    def _run_subsample_action(self) -> None:
        """User clicked 'Subsample now' — validate, then dispatch to a
        worker thread (the aggregator is fast for small grids but can
        chew through GBs for large ones, so don't block the UI)."""
        src = self.subsample_source_var.get().strip()
        if not src:
            messagebox.showerror("run-cap", "Pick a source folder first.")
            return
        src_path = REPO / "histos" / src
        if not src_path.is_dir():
            messagebox.showerror("run-cap", f"Source does not exist: {src_path}")
            return
        mode    = self.subsample_mode_var.get()
        outname = self.subsample_outname_var.get().strip() or "final"

        self.subsample_btn.config(state=tk.DISABLED)
        self.subsample_status_var.set("running …")

        threading.Thread(
            target=self._subsample_action_worker,
            args=(src_path, mode, outname),
            daemon=True).start()

    def _subsample_action_worker(self, src_path: Path, mode: str,
                                  outname: str) -> None:
        """Background worker that runs the aggregator and writes results."""
        import re
        try:
            sys.path.insert(0, str(REPO / "analyses" / "builder"))
            from subsample_aggregator import aggregate, aggregate_grid
        except Exception as exc:
            self.root.after(0, lambda e=exc: self._append(
                f"!!! could not import subsample_aggregator: {e}\n", "error"))
            self.root.after(0, lambda: self.subsample_btn.config(state=tk.NORMAL))
            self.root.after(0, lambda: self.subsample_status_var.set("import failed"))
            return

        def progress(msg):
            self.root.after(0, lambda m=msg: self._append(m + "\n"))

        try:
            if mode == "hierarchical":
                rows: set[int] = set()
                cols: set[int] = set()
                for c in src_path.iterdir():
                    if not c.is_dir(): continue
                    m = re.match(r"raw_(\d+)_(\d+)", c.name)
                    if m:
                        rows.add(int(m.group(1)))
                        cols.add(int(m.group(2)))
                if not rows or not cols:
                    raise RuntimeError(
                        "no raw_i_j/ dirs found — Hierarchical mode "
                        "needs that naming pattern.")
                n = max(rows) + 1
                mc = max(cols) + 1
                self.root.after(0, lambda n=n, m=mc, p=src_path: self._append(
                    f"\n=== Subsample (hierarchical {n}×{m}) — {p} ===\n", "ok"))
                aggregate_grid(src_path, n, mc, progress=progress)
                # Rename "final" if user wants a different output name.
                if outname != "final" and (src_path / "final").is_dir():
                    target = src_path / outname
                    if target.exists():
                        progress(f"  warning: {target} exists, leaving final/ as-is")
                    else:
                        (src_path / "final").rename(target)
                        progress(f"  renamed final/ → {outname}/")

            elif mode == "rows":
                rows: set[int] = set()
                cols: set[int] = set()
                for c in src_path.iterdir():
                    if not c.is_dir(): continue
                    m = re.match(r"raw_(\d+)_(\d+)", c.name)
                    if m:
                        rows.add(int(m.group(1)))
                        cols.add(int(m.group(2)))
                if not rows or not cols:
                    raise RuntimeError(
                        "no raw_i_j/ dirs found — Row-only mode "
                        "needs that naming pattern.")
                n  = max(rows) + 1
                mc = max(cols) + 1
                self.root.after(0, lambda n=n, m=mc, p=src_path: self._append(
                    f"\n=== Subsample (row-only, {n} rows of up to {m}) — {p} ===\n",
                    "ok"))
                for i in range(n):
                    row_inputs = [src_path / f"raw_{i}_{j}" for j in range(mc)]
                    present = [d for d in row_inputs if d.is_dir()]
                    if not present:
                        progress(f"  row {i}: no raw dirs found, skipping")
                        continue
                    out_dir = src_path / f"sub_{i}"
                    progress(f"\n  row {i}: {len(present)} dirs → sub_{i}/")
                    aggregate(present, out_dir, progress=progress)

            elif mode == "flat":
                # Combine every direct subdirectory (excluding any that
                # look like aggregator outputs from a previous run).
                inputs = [c for c in src_path.iterdir()
                          if c.is_dir()
                          and c.name not in (outname, "final")
                          and not c.name.startswith("sub_")
                          and any(c.glob("*.root"))]
                if not inputs:
                    raise RuntimeError(
                        "no subdirectories with .root files found.")
                out_dir = src_path / outname
                self.root.after(0, lambda p=src_path, n=len(inputs), o=outname:
                                self._append(
                                    f"\n=== Subsample (flat) — "
                                    f"{n} dirs in {p} → {o}/ ===\n", "ok"))
                aggregate(inputs, out_dir, progress=progress)
            else:
                raise RuntimeError(f"unknown mode: {mode}")

            self.root.after(0, lambda: self.subsample_status_var.set("✓ done"))
            self.root.after(0, lambda: self._append(
                "\n=== aggregation complete ===\n", "ok"))
        except Exception as exc:
            self.root.after(0, lambda e=exc: self._append(
                f"!!! aggregation failed: {e}\n", "error"))
            self.root.after(0, lambda: self.subsample_status_var.set("✗ failed"))
        finally:
            self.root.after(0, lambda: self.subsample_btn.config(state=tk.NORMAL))
            # Refresh the source list so a new "final/" or "sub_*/"
            # appears next time the user opens the dropdown.
            self.root.after(0, self._refresh_subsample_sources)

