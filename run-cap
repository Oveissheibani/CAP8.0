    def _wsu_collect_job(self) -> "WSUJob":
        """Snapshot the panel's tk.Var values into a WSUJob.  Pulls the
        Pythia/Herwig steering blobs from the existing per-generator
        config state (so the user's preset / toggles / numerics /
        stable-particles / custom strings are baked into the bundle)."""
        try:
            n_tasks = max(1, int(self.wsu_n_tasks.get() or "1"))
        except ValueError:
            n_tasks = 50
        try:
            evt = max(1, int(self.wsu_evt_per_task.get() or "10000"))
        except ValueError:
            evt = 10000
        try:
            seed_off = int(self.wsu_seed_offset.get() or "1000")
        except ValueError:
            seed_off = 1000

        # Compose the steering files using the same code path as
        # _compose_and_run.  This keeps grid runs bit-identical to local.
        py_cmnd = collect_pythia_strings(
            self._pythia_cfg_state["preset"],
            self._pythia_cfg_state["panels"],
            self._pythia_cfg_state.get("numeric", {}),
            self._pythia_cfg_state["custom"],
            self._pythia_cfg_state.get("stable", []),
            ctau_max_mm=(self._pythia_cfg_state.get("ctau_value")
                         if self._pythia_cfg_state.get("ctau_enable")
                         else None))
        hw_in   = collect_herwig_lines(
            self._herwig_cfg_state["preset"],
            self._herwig_cfg_state["panels"],
            self._herwig_cfg_state.get("numeric", {}),
            self._herwig_cfg_state["custom"],
            self._herwig_cfg_state.get("stable", []),
            ctau_max_mm=(self._herwig_cfg_state.get("ctau_value")
                         if self._herwig_cfg_state.get("ctau_enable")
                         else None))

        # Pull the analyzer subtask choices + RunDerived/RunBf flags
        # straight off the Compose tab so the grid run mirrors the
        # local workflow exactly.
        analyses_enabled = {k: bool(v.get())
                            for k, v in self.compose_choice_vars.items()}
        run_derived = bool(self.compose_run_derived_var.get())
        run_bf      = bool(self.compose_run_bf_var.get())

        job = WSUJob(
            name=self.wsu_name_var.get().strip() or "run01",
            user_home=self.wsu_home_var.get().strip() or WSU_DEFAULT_HOME,
            partition=self.wsu_partition_var.get().strip() or WSU_DEFAULT_PARTITION,
            mail=self.wsu_mail_var.get().strip() or WSU_DEFAULT_MAIL,
            enable_pythia=bool(self.wsu_enable_pythia.get()),
            enable_herwig=bool(self.wsu_enable_herwig.get()),
            enable_hepmc3_reader_only=bool(self.wsu_enable_hepmc3.get()),
            enable_epos=bool(self.wsu_enable_epos.get()),
            install_mode_pythia=self.wsu_im_pythia.get() or "link",
            install_mode_herwig=self.wsu_im_herwig.get() or "link",
            install_mode_lhapdf=self.wsu_im_lhapdf.get() or "link",
            # Merge:  module defaults  ←  user-typed values (non-empty wins).
