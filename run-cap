            pythia_cmnd_lines=py_cmnd,
            herwig_in_lines=hw_in,
            output_dir=self.wsu_remote_outdir.get().strip() or "$HOME/cap_runs",
            run_analysis=any(analyses_enabled.values()),
            run_derived=run_derived,
            run_bf=run_bf,
