    def _open_output(self) -> None:
        """Open Finder/file-explorer at the GENERATOR-LEVEL output dir
        so the user can browse across all keep-profiles + all runs for
        the currently-selected generator.

        Path resolution:
          1. If the Compose tab is set → histos/<Generator>/  (preferred,
             matches what a freshly-clicked Run would write to).
          2. Else if the Run-existing-ini output_var is filled → that path
             rooted under histos/.
          3. Else fall back to histos/  itself.
        """
        target: Path
        kind_str = ""
        try:
            kind_str = self.compose_gen_var.get().strip()
        except Exception:
            pass
        if kind_str:
            try:
                gen_folder = _generator_folder(GeneratorKind(kind_str))
            except Exception:
                gen_folder = "Misc"
            target = REPO / "histos" / gen_folder
        else:
            v = self.output_var.get().strip()
            target = REPO / "histos" / (v or "")
            if not v:
                target = REPO / "histos"
        target.mkdir(parents=True, exist_ok=True)
        self._open_path(target)

    def _launch_plot_browser(self) -> None:
        """Open cap-plot pointed at the most relevant output sub-folder.
        Priority order:
          1. Compose-tab output (if filled) — the user's current job.
          2. Run-existing-ini output_var (legacy).
          3. The most recently modified histos/<subdir>/ on disk.
          4. histos/ itself.
        That way clicking 📊 Browse plots after a fresh run lands on the
        .root files that just got written, not on a stale 'test' folder."""
        cap_plot = REPO / "cap-plot"
        if not cap_plot.is_file():
            messagebox.showerror("run-cap", f"cap-plot not found at {cap_plot}.")
            return

        candidates: list[Path] = []
        # 0. After a subsample-grid run, the most useful destination
        #    is the aggregated final/ folder under the compose outdir.
        compose_var = getattr(self, "compose_outdir_var", None)
        if compose_var is not None:
            v = compose_var.get().strip()
            if v:
                candidates.append(REPO / "histos" / v / "final")
                candidates.append(REPO / "histos" / v)
        # 2. Run-existing-ini tab field.
        v = self.output_var.get().strip()
        if v:
            candidates.append(REPO / "histos" / v / "final")
            candidates.append(REPO / "histos" / v)
        # 3. Most recent non-empty subfolder in histos/.  Now recurses
        #    into known generator folders (histos/Pythia/<name>/...,
        #    histos/Herwig/<name>/...) since outputs are prefixed.
        histos_root = REPO / "histos"
        gen_folders = {"Pythia", "Herwig", "HepMC3", "Therminator",
                       "Glauber", "Basic", "EPOS", "PHSD", "Misc"}
        if histos_root.is_dir():
            scan_dirs: list[Path] = []
            for p in histos_root.iterdir():
                if not p.is_dir():
                    continue
                if p.name in gen_folders:
                    scan_dirs.extend(q for q in p.iterdir() if q.is_dir())
                else:
                    scan_dirs.append(p)
            # Prefer dirs that already have a final/ aggregation, then
            # any dir with .root files at top level.
            with_final = [d / "final" for d in scan_dirs
                          if (d / "final").is_dir()
                          and any((d / "final").glob("*.root"))]
            with_root  = [d for d in scan_dirs
                          if any(d.glob("*.root"))]
            ranked = with_final + with_root
            if ranked:
                ranked.sort(key=lambda p: p.stat().st_mtime, reverse=True)
                candidates.append(ranked[0])
        # 4. Last resort.
        candidates.append(histos_root)

        out = next((p for p in candidates if p.is_dir()
                    and any(p.glob("*.root"))), candidates[-1])
        out.mkdir(parents=True, exist_ok=True)
        self._append(f"\n📊 Plot browser opening at: {out}\n", "info")
        # Inherit our env so PyROOT picks up the same ROOT/lib paths.
        env = os.environ.copy()
        for k in ("DYLD_LIBRARY_PATH", "LD_LIBRARY_PATH"):
            v = env.get(k, "")
            our = str(REPO / "lib")
            if our not in v.split(":"):
                env[k] = our + (":" + v if v else "")
        try:
            subprocess.Popen([sys.executable, str(cap_plot), str(out)],
                             env=env)
            self.log.line("INFO", f"launched cap-plot at {out}")
        except Exception as exc:
            messagebox.showerror("run-cap", f"Could not launch cap-plot: {exc}")

    def _run_smoketest(self) -> None:
        """Run src/Macros/SmokeTest.C — a minimal Pythia→histograms test that
        bypasses the missing CAP task classes. Proves the build is alive."""
        macro = REPO / "src" / "Macros" / "SmokeTest.C"
        if not macro.exists():
            messagebox.showerror("run-cap", f"Smoke test macro not found at {macro}.")
            return
        if not (REPO / "lib").is_dir():
            messagebox.showerror("run-cap",
                "lib/ directory missing — build CAP first via ./install --gui.")
            return

        # Find root binary.
        root_bin = "root"   # rely on PATH
        cmd = [root_bin, "-b", "-q", str(macro)]

        env = os.environ.copy()
        # Make sure ROOT can find our libs.
        for k in ("DYLD_LIBRARY_PATH", "LD_LIBRARY_PATH"):
            v = env.get(k, "")
            our = str(REPO / "lib")
            if our not in v.split(":"):
                env[k] = our + (":" + v if v else "")

        self._append(f"\n$ {' '.join(cmd)}\n", "info")
        self.log.line("INFO", f"smoketest: {' '.join(cmd)}")
        self.run_btn.config(state=tk.DISABLED)
        self.stop_btn.config(state=tk.NORMAL)
        self.status_var.set("Running smoke test (Pythia → histograms) …")

        threading.Thread(target=self._run_worker,
                         args=(cmd, env, ""), daemon=True).start()

    def _open_path(self, p: Path) -> None:
