        self.stats_ini_var.set(ini_path.name)
        self.stats_files_var.set("0")
        threading.Thread(
            target=self._run_chain_worker,
            args=(cmd_chain, env, ""),
            daemon=True).start()
        return  # skip the original single-cmd path below
