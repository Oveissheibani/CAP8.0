    def _open_generator_config_window(self, *, kind_name, state, presets,
                                       bool_toggles, numeric_knobs,
                                       stable_kind, custom_label,
                                       validator):
        """Generic Toplevel builder shared by Pythia + Herwig.

        Renders four sections inside a vertically scrollable canvas:
            (1) Preset dropdown + live preview of preset readString lines
            (2) Boolean toggles (checkbuttons), grouped by category
            (3) Numeric knobs (input boxes), grouped by category
            (4) Custom raw strings textarea + validation output

        Numeric knobs use ttk.Entry widgets pre-populated from
        state["numeric"] (or empty if first time).  The 'default' field
        from each knob spec is shown as a hint label next to the entry.
        Empty entries do not emit any line at all (handled in
        generator_presets._emit_numeric).
        """
        win = tk.Toplevel(self.root)
        win.title(f"CAP — {kind_name} configuration")
        win.geometry("820x780")

        # ---- Outer scroll wrapper -----------------------------------------
        # Toplevel itself needs to follow the theme (Tk does NOT inherit
        # ttk.Style for Toplevel bg).
        win.configure(background=_theme.current()["bg"])
        _theme.register(win, "default")
        outer = ttk.Frame(win); outer.pack(fill=tk.BOTH, expand=True)
        canvas = tk.Canvas(outer, highlightthickness=0)
        _theme.register(canvas, "canvas")
        vbar   = ttk.Scrollbar(outer, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=vbar.set)
        vbar.pack(side=tk.RIGHT, fill=tk.Y)
        canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        body = ttk.Frame(canvas)
        canvas_window = canvas.create_window((0, 0), window=body, anchor="nw")
        def _on_body_cfg(_evt):
            canvas.configure(scrollregion=canvas.bbox("all"))
            canvas.itemconfig(canvas_window, width=canvas.winfo_width())
        body.bind("<Configure>", _on_body_cfg)
        def _wheel(evt):
            canvas.yview_scroll(int(-evt.delta / 120 or (-1 if evt.num == 4 else 1)), "units")
        canvas.bind_all("<MouseWheel>", _wheel)
        canvas.bind_all("<Button-4>", _wheel)
        canvas.bind_all("<Button-5>", _wheel)
        def _unbind_wheel():
            canvas.unbind_all("<MouseWheel>")
            canvas.unbind_all("<Button-4>")
            canvas.unbind_all("<Button-5>")
        win.bind("<Destroy>", lambda _e: _unbind_wheel())

        # ---- Header description ----
        ttk.Label(body,
            text=(f"Pick a {kind_name} tuned set, optionally toggle the "
                  f"specialized panel switches, fill in any numeric knobs "
                  f"you want to override, and add any extra raw strings. "
                  f"All choices are written into the .ini at ▶ Run time "
                  f"and applied to {kind_name} via its native "
                  f"configuration channel."),
            foreground="#444", wraplength=780, justify="left"
            ).pack(fill=tk.X, padx=10, pady=(8, 4))

        # ---- Preset dropdown ----
        preset_frame = ttk.LabelFrame(body, text="Tuned set / preset")
        preset_frame.pack(fill=tk.X, padx=10, pady=4)
        preset_row = ttk.Frame(preset_frame); preset_row.pack(fill=tk.X)
        preset_var = tk.StringVar(value=state["preset"])
        preset_cb = ttk.Combobox(preset_row, textvariable=preset_var,
                                 values=list(presets.keys()),
                                 state="readonly", width=46)
        preset_cb.pack(side=tk.LEFT, padx=8, pady=6)

        # Live preview of the strings the chosen preset emits.
        preview = tk.Text(preset_row, height=5, wrap=tk.NONE,
                         font=("Menlo", 10) if sys.platform == "darwin"
                         else ("Monospace", 9))
        preview.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=8, pady=6)
        _theme.register(preview, "preview")

        def _update_preview(*_):
            preview.delete("1.0", tk.END)
            for ln in presets.get(preset_var.get(), []):
                preview.insert(tk.END, ln + "\n")
        preset_cb.bind("<<ComboboxSelected>>", _update_preview)
        _update_preview()

        # ---- Boolean toggles, grouped by category -------------------------
        bool_outer = ttk.LabelFrame(
            body, text=f"On/off switches  ({kind_name} bool toggles)")
        bool_outer.pack(fill=tk.X, padx=10, pady=4)
        by_cat_bool: dict[str, list] = {}
        for key, spec in bool_toggles.items():
            cat = spec.get("category", "Misc")
            by_cat_bool.setdefault(cat, []).append((key, spec.get("label", key)))
        panel_vars: dict = {}
        for cat in by_cat_bool:
            sub = ttk.LabelFrame(bool_outer, text=cat)
            sub.pack(fill=tk.X, padx=8, pady=(4, 2))
            col = 0; row = 0
            for key, lbl in by_cat_bool[cat]:
                v = tk.BooleanVar(value=state["panels"].get(key, False))
                panel_vars[key] = v
                ttk.Checkbutton(sub, text=lbl, variable=v
                                ).grid(row=row, column=col, sticky="w",
                                       padx=8, pady=1)
                col = (col + 1) % 2  # 2 cols — labels are wide
                if col == 0:
                    row += 1

        # ---- Numeric knobs, grouped by category ---------------------------
        num_outer = ttk.LabelFrame(
            body, text=f"Numeric parameters  ({kind_name} input boxes — leave blank to skip)")
        num_outer.pack(fill=tk.X, padx=10, pady=4)
        by_cat_num: dict[str, list] = {}
        for key, spec in numeric_knobs.items():
            cat = spec.get("category", "Misc")
            by_cat_num.setdefault(cat, []).append((key, spec))
        numeric_vars: dict[str, tk.StringVar] = {}
        for cat, items in by_cat_num.items():
            sub = ttk.LabelFrame(num_outer, text=cat)
            sub.pack(fill=tk.X, padx=8, pady=(4, 2))
            for r, (key, spec) in enumerate(items):
                ttk.Label(sub, text=spec.get("label", key)
                          ).grid(row=r, column=0, sticky="w",
                                 padx=(8, 4), pady=2)
                v = tk.StringVar(value=state.get("numeric", {}).get(key, ""))
                numeric_vars[key] = v
                ent = ttk.Entry(sub, textvariable=v, width=12)
                ent.grid(row=r, column=1, sticky="w", padx=(0, 4), pady=2)
                # Hint label showing the recommended default
                ttk.Label(sub, text=f"(default: {spec.get('default', '—')})",
                          foreground="#888"
                          ).grid(row=r, column=2, sticky="w", padx=4, pady=2)
            sub.columnconfigure(0, weight=1)

        # ---- Lifetime cut (cτ) section ---------------------------------
        # Single global threshold; particles whose proper cτ exceeds the
        # value are not decayed.  Pythia: 'ParticleDecays:limitTau0 = on'
        # + 'ParticleDecays:tau0Max = <mm>'.  Herwig:
        # 'set /Herwig/Decays/DecayHandler:MaxLifeTime <mm>*mm'.
        ctau_outer = ttk.LabelFrame(
            body, text=f"Lifetime cut (cτ_max) — {kind_name}")
        ctau_outer.pack(fill=tk.X, padx=10, pady=4)
