                ttk.Label(top, image=self._logo_img).pack(side=tk.LEFT, padx=(0, 10))
            except Exception:
                pass
        ttk.Label(top, text="CAP setup", font=("TkDefaultFont", 14, "bold")).pack(side=tk.LEFT)
        ttk.Button(top, text="Rescan", command=self._rescan).pack(side=tk.RIGHT)

