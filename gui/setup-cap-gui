        self.log = GuiLogger("gui")
        self.log.line("INFO", "GUI started")

        self.detection: dict = {"root": [], "pythia": [], "fastjet": []}
        self.queue: queue.Queue = queue.Queue()

        self.root = tk.Tk()
        self.root.title("CAP — interactive setup")
        self.root.geometry("960x720")
        self._build_ui()
        self.root.protocol("WM_DELETE_WINDOW", self._on_close)
        self._poll_queue()
        self._rescan()

