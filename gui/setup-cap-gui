#!/usr/bin/env python3
"""
setup-cap-gui — graphical installer for the Correlation Analysis Package.

Companion to ./setup-cap (the CLI installer). Same detection logic underneath
(invokes `setup-cap --json`), same .cap-config output, same logs.

Layout:
    +--------------------------------------------------------------+
    | CAP setup                                       [ rescan ]   |
    | ROOT      [ /opt/homebrew/Cellar/root/6.32.04         ▾ ]   |
    | Pythia 8  [ ./pythia8317                              ▾ ]   |
    | FastJet   [ ./fastjet-3.4.3 (build now)               ▾ ]   |
    |                                                              |
    | [ Save config ]  [ Configure & Build ]  [ Run sample job ]   |
    |--------------------------------------------------------------|
    | Live log:                                                    |
    | [ scrolling text widget tailing logs/last-*.log ]            |
    +--------------------------------------------------------------+

Requires: Python 3.8+ and Tkinter (standard library on macOS, most Linux).
On Debian/Ubuntu:    apt install python3-tk
On RHEL/CentOS/WSU:  yum install python3-tkinter

Logs are written under <repo>/logs/ exactly like the CLI installer, so any
crash/build failure is preserved for inspection.
"""

from __future__ import annotations

import json
import os
import queue
import shlex
import subprocess
import sys
import threading
import tkinter as tk
from datetime import datetime, timezone
from pathlib import Path
from tkinter import messagebox, ttk

REPO = Path(__file__).resolve().parent.parent
LOGS = REPO / "logs"
LOGS.mkdir(exist_ok=True)


# ---------------------------------------------------------------------------
#  Logging — mirrors scripts/cap-logging.sh format so we can grep across both
# ---------------------------------------------------------------------------
class GuiLogger:
    """Writes a timestamped log file and exposes a thread-safe writeline()."""

    def __init__(self, component: str = "gui") -> None:
        ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        self.path = LOGS / f"{component}-{ts}.log"
        self.lock = threading.Lock()
        self._open = open(self.path, "w", encoding="utf-8", buffering=1)
        self._open.write(f"# CAP {component} log (GUI)\n")
        self._open.write(f"# Started   : {datetime.now(timezone.utc).isoformat()}\n")
        self._open.write(f"# CWD       : {os.getcwd()}\n")
        self._open.write(f"# Platform  : {sys.platform} {os.uname().machine if hasattr(os, 'uname') else ''}\n")
        self._open.write(f"# Python    : {sys.version.split()[0]}\n")
        self._open.write("#====================================================================\n\n")

        # Maintain a "last-<component>.log" symlink for easy tailing.
        last = LOGS / f"last-{component}.log"
        try:
            if last.is_symlink() or last.exists():
                last.unlink()
            last.symlink_to(self.path.name)
        except OSError:
            pass

    def line(self, level: str, message: str) -> None:
        ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%fZ")[:-3] + "Z"
        with self.lock:
            self._open.write(f"[{ts}] [{level}] {message}\n")

    def close(self, exit_code: int = 0) -> None:
        with self.lock:
            self._open.write("\n#====================================================================\n")
            self._open.write(f"# Finished  : {datetime.now(timezone.utc).isoformat()}\n")
            self._open.write(f"# Exit code : {exit_code}\n")
            self._open.close()


# ---------------------------------------------------------------------------
#  Subprocess helpers
# ---------------------------------------------------------------------------
def run_streaming(cmd: list[str], log: GuiLogger, sink: queue.Queue, cwd: Path | None = None) -> int:
    """Run a command, sending each output line to the sink queue and the log."""
    log.line("INFO", f"$ {' '.join(shlex.quote(c) for c in cmd)}")
    sink.put(("info", f"$ {' '.join(shlex.quote(c) for c in cmd)}"))
    try:
        proc = subprocess.Popen(
            cmd,
            cwd=str(cwd) if cwd else None,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
        )
    except FileNotFoundError as exc:
        log.line("ERROR", str(exc))
        sink.put(("error", str(exc)))
        return 127

    assert proc.stdout is not None
    for line in proc.stdout:
        line = line.rstrip()
        log.line("DEBUG", line)
        sink.put(("line", line))
    proc.wait()
    sink.put(("info", f"   exit code: {proc.returncode}"))
    log.line("INFO" if proc.returncode == 0 else "ERROR", f"exit code {proc.returncode}")
    return proc.returncode


def detect_dependencies(log: GuiLogger,
                         hw_prefix: str | None = None) -> dict:
    """Call `setup-cap --json` and return the parsed result.

    If `hw_prefix` is supplied, it's exported as HW_PREFIX so the shell
    detector picks up the FastJet (and other HEP libs) bundled inside
    the HERWIG install — the bundled libfastjet appears as a "herwig"
    candidate alongside Homebrew/CVMFS/etc."""
    log.line("INFO", "Running setup-cap --json")
    env = os.environ.copy()
    if hw_prefix:
        env["HW_PREFIX"] = hw_prefix
        log.line("INFO", f"  with HW_PREFIX={hw_prefix}")
    res = subprocess.run(
        [str(REPO / "setup-cap"), "--json"],
        capture_output=True,
        text=True,
        cwd=str(REPO),
        env=env,
    )
    if res.returncode != 0:
        log.line("ERROR", f"setup-cap --json failed: {res.stderr}")
        return {"root": [], "pythia": [], "fastjet": []}
    try:
        return json.loads(res.stdout)
    except json.JSONDecodeError as exc:
        log.line("ERROR", f"Could not parse JSON from setup-cap: {exc}\nstdout was: {res.stdout}")
        return {"root": [], "pythia": [], "fastjet": []}


