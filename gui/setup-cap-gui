    def _dep_row(self, parent: ttk.LabelFrame, row: int, label: str,
                 var: tk.StringVar) -> ttk.Combobox:
        ttk.Label(parent, text=label, width=10).grid(row=row, column=0, sticky="w", padx=8, pady=6)
        combo = ttk.Combobox(parent, textvariable=var, state="readonly", width=80)
        combo.grid(row=row, column=1, sticky="ew", padx=8, pady=6)
        return combo

    def _pick_hw_prefix(self) -> None:
        """Browse for the HERWIG install root (the dir with bin/Herwig)."""
        from tkinter import filedialog
        cur = self.hw_prefix_var.get().strip()
        initial = cur if cur and Path(cur).is_dir() else "/Users"
        path = filedialog.askdirectory(
            title="Select HERWIG install root (directory containing bin/Herwig)",
            initialdir=initial)
        if path:
            self.hw_prefix_var.set(path)
            # _on_hw_prefix_change will fire via trace_add → re-detect.

    def _on_hw_prefix_change(self) -> None:
        """Trace callback — debounce-free re-detection when the user
        edits HW_PREFIX, so the bundled FastJet appears in the dropdown
        without manual Rescan."""
        # Cancel any pending re-detect and schedule a fresh one in
        # 800 ms so we don't spam setup-cap during typing.
        if hasattr(self, "_hw_rescan_after_id") and self._hw_rescan_after_id:
            try: self.root.after_cancel(self._hw_rescan_after_id)
            except tk.TclError: pass
        self._hw_rescan_after_id = self.root.after(800, self._rescan)

    def _use_herwig_fastjet(self) -> None:
        """Select the HERWIG-bundled FastJet entry in the FastJet
        dropdown, if one was detected.  No-op otherwise (Rescan first)."""
        items = self.detection.get("fastjet", [])
        for it in items:
            if it.get("kind") == "herwig":
                self.fastjet_var.set(self._format_option(it))
                self.enable_fastjet_var.set(True)
                self._append_log(
                    f"Selected HERWIG-bundled FastJet: {it.get('path')}",
                    "ok")
                return
        self._append_log(
            "No HERWIG-bundled FastJet detected.  Set HW_PREFIX and click Rescan.",
            "error")

    # -- Helpers ----------------------------------------------------------
    def _format_option(self, item: dict) -> str:
        ver = f" ({item['version']})" if item.get("version") else ""
        return f"[{item['kind']}] {item['source']:<14} {item['path']}{ver}"

    def _rescan(self) -> None:
        self._append_log("Rescanning…", "info")
        # Pass HW_PREFIX (if set) so detect_fastjet sees the
        # HERWIG-bundled FastJet as a candidate.
        hw_prefix = ""
        if hasattr(self, "hw_prefix_var"):
            hw_prefix = self.hw_prefix_var.get().strip()
        self.detection = detect_dependencies(self.log, hw_prefix=hw_prefix or None)
        self._populate_combo(self.root_combo, self.root_var,
                             self.detection.get("root", []),
                             include_skip=False)
        self._populate_combo(self.pythia_combo, self.pythia_var,
                             self.detection.get("pythia", []),
                             include_skip=True,
                             extra_label=self.INSTALL_PYTHIA_LABEL)
        self._populate_combo(self.fastjet_combo, self.fastjet_var,
                             self.detection.get("fastjet", []),
                             include_skip=True,
                             extra_label=self.INSTALL_FASTJET_LABEL,
                             default_to_skip=True)
        n = sum(len(v) for v in self.detection.values())
        self.status_var.set(f"Detected {n} candidate installation(s) across all dependencies.")
        self._append_log(f"Detection complete: ROOT={len(self.detection.get('root', []))}, "
                         f"Pythia={len(self.detection.get('pythia', []))}, "
                         f"FastJet={len(self.detection.get('fastjet', []))}", "info")

    def _populate_combo(self, combo: ttk.Combobox, var: tk.StringVar,
                        items: list, *, include_skip: bool,
                        extra_label: str | None = None,
                        default_to_skip: bool = False) -> None:
        previous = var.get()    # may be empty on first call
        values = [self._format_option(item) for item in items]
        if extra_label:
            values.append(extra_label)
        if include_skip:
            values.append(self.SKIP_LABEL)
        combo["values"] = values

        # Preserve the previous user selection across rescans if it's still
        # valid, otherwise apply the default.  default_to_skip=True means
        # we land on "— skip / disable —" instead of the first detection
        # (used for FastJet so users have to consciously opt-in to it).
        if previous and previous in values:
            var.set(previous)
        elif default_to_skip and include_skip:
            var.set(self.SKIP_LABEL)
        elif values:
            var.set(values[0])
        else:
            var.set(self.SKIP_LABEL if include_skip else "")

    def _resolve_choice(self, var: tk.StringVar, kind: str) -> tuple[str, str | None]:
        """Return (action, path).
        action ∈ {"path", "skip", "install"}."""
        chosen = var.get()
        self.log.line("DEBUG", f"_resolve_choice kind={kind} chosen={chosen!r}")

        if chosen == self.SKIP_LABEL or not chosen:
            self.log.line("INFO", f"  → resolved as SKIP")
            return ("skip", None)
        if chosen == self.INSTALL_PYTHIA_LABEL:
            self.log.line("INFO", f"  → resolved as INSTALL pythia")
            return ("install", "pythia")
        if chosen == self.INSTALL_FASTJET_LABEL:
            self.log.line("INFO", f"  → resolved as INSTALL fastjet")
            return ("install", "fastjet")

        # Detected entries — match against the formatted string first; fall
        # back to substring/path match so a tiny formatting drift never
        # silently turns into "skip" (the bug we just hit).
        items = self.detection.get(kind, [])
        for item in items:
            if self._format_option(item) == chosen:
                self.log.line("INFO", f"  → resolved as PATH {item['path']} (exact format match)")
                return ("path", item["path"])
        for item in items:
            if item["path"] and item["path"] in chosen:
                self.log.line("WARN",
                              f"  → resolved as PATH {item['path']} (fuzzy match — "
                              f"format mismatch was {chosen!r})")
                return ("path", item["path"])

        self.log.line("ERROR",
                      f"  → NOTHING matched for {kind}: chosen={chosen!r}, "
                      f"detected={[i['path'] for i in items]} — falling back to SKIP")
        return ("skip", None)

    # -- Actions ----------------------------------------------------------
    def _save_config(self) -> None:
        self._append_log("Saving .cap-config…", "info")
        try:
            with self._open_install_dest() as dest:
                pass  # populated in _gather_paths below
        except Exception as exc:
            self._append_log(f"save failed: {exc}", "error")
            return
        self._gather_paths_and_write_config(allow_install=True)

    def _open_install_dest(self):
        # Helper context manager so save_config can swallow errors uniformly.
        from contextlib import nullcontext
        return nullcontext()

    def _gather_paths_and_write_config(self, allow_install: bool) -> dict:
        root_action,    root_arg    = self._resolve_choice(self.root_var,    "root")
        pythia_action,  pythia_arg  = self._resolve_choice(self.pythia_var,  "pythia")
        fastjet_action, fastjet_arg = self._resolve_choice(self.fastjet_var, "fastjet")
        if root_action != "path":
            messagebox.showerror("CAP setup", "ROOT is required — please pick a ROOT installation.")
            return {}

        # NOTE: The Jets module is currently broken upstream code (see
        # JETS_KNOWN_ISSUES.md) and will not be built even if FastJet is
        # selected. Picking a FastJet just makes the library/headers
        # available for future use; we don't auto-enable any Pythia link
        # for it. When somebody finishes repairing Jets, restore the
        # Pythia auto-attach logic that used to live here.

        paths = {
            "ROOTSYS": root_arg,
            "CAP_PYTHIA8_PATH": None,
            "CAP_FASTJET_PATH": None,
        }

        # Run installs synchronously (with progress in the log pane).
        if pythia_action == "install":
            if not allow_install:
                self._append_log("Pythia install requested but allow_install=False", "error")
            else:
                rc = self._run_threaded(["./setup-cap", "--install", "pythia"],
                                        label="Install Pythia 8")
                if rc != 0:
                    return {}
                # The install returns the destination path on stdout, but to keep
                # things simple we just rely on the stamped pythia8XYZ folder
                # appearing in the repo root.
                guesses = sorted(REPO.glob("pythia8[0-9]*"), reverse=True)
                if guesses:
                    paths["CAP_PYTHIA8_PATH"] = str(guesses[0])
        elif pythia_action == "path":
            paths["CAP_PYTHIA8_PATH"] = pythia_arg

        if fastjet_action == "install":
            if not allow_install:
                self._append_log("FastJet install requested but allow_install=False", "error")
            else:
                rc = self._run_threaded(["./setup-cap", "--install", "fastjet"],
                                        label="Build vendored FastJet")
                if rc != 0:
                    return {}
                guess = next(iter(REPO.glob("fastjet-*/install")), None)
                if guess:
                    paths["CAP_FASTJET_PATH"] = str(guess)
        elif fastjet_action == "path":
            paths["CAP_FASTJET_PATH"] = fastjet_arg

        # Write .cap-config in the same format the CLI uses.
        cfg = REPO / ".cap-config"
        with cfg.open("w") as fh:
            fh.write(f"# CAP dependency choices saved by setup-cap-gui on "
                     f"{datetime.now(timezone.utc).isoformat()}\n")
            fh.write(f'export ROOTSYS="{paths["ROOTSYS"]}"\n')
            if paths["CAP_PYTHIA8_PATH"]:
                fh.write(f'export CAP_PYTHIA8_PATH="{paths["CAP_PYTHIA8_PATH"]}"\n')
                fh.write(f'export CAP_CMAKE_FLAGS_PYTHIA="-DCAP_ENABLE_PYTHIA=ON '
                         f'-DCAP_PYTHIA8_PATH={paths["CAP_PYTHIA8_PATH"]}"\n')
            else:
                fh.write('export CAP_CMAKE_FLAGS_PYTHIA="-DCAP_ENABLE_PYTHIA=OFF"\n')
            # Jets is OFF by default — only flip ON when the user ticked
            # the "Enable Jets module" checkbox AND a FastJet path exists.
            jets_on = self.enable_jets_var.get() and bool(paths["CAP_FASTJET_PATH"])
            if paths["CAP_FASTJET_PATH"]:
                fh.write(f'export CAP_FASTJET_PATH="{paths["CAP_FASTJET_PATH"]}"\n')
            if jets_on:
                fh.write(f'export CAP_CMAKE_FLAGS_JETS="-DCAP_ENABLE_JETS=ON '
                         f'-DCAP_FASTJET_PATH={paths["CAP_FASTJET_PATH"]}"\n')
            elif paths["CAP_FASTJET_PATH"]:
                fh.write(f'export CAP_CMAKE_FLAGS_JETS="-DCAP_ENABLE_JETS=OFF '
                         f'-DCAP_FASTJET_PATH={paths["CAP_FASTJET_PATH"]}"\n')
            else:
                fh.write('export CAP_CMAKE_FLAGS_JETS="-DCAP_ENABLE_JETS=OFF"\n')

        self._append_log(f"Saved .cap-config:\n{cfg.read_text()}", "ok")
        self.status_var.set(".cap-config written.")
        return paths

    def _configure_and_build(self) -> None:
        # Re-detect first — picks up any brew/conda installs done since the
        # GUI launched so the user's recent decisions are reflected.
        self._append_log("Re-scanning dependencies before build…", "info")
        self._rescan()
        paths = self._gather_paths_and_write_config(allow_install=True)
        if not paths:
            return
        self.build_btn.config(state=tk.DISABLED)
        threading.Thread(target=self._configure_and_build_worker,
                         args=(paths,), daemon=True).start()

    def _configure_and_build_worker(self, paths: dict) -> None:
        env = os.environ.copy()
        env["ROOTSYS"] = paths["ROOTSYS"]
        if paths.get("CAP_PYTHIA8_PATH"):
            env["CAP_PYTHIA8_PATH"] = paths["CAP_PYTHIA8_PATH"]
        if paths.get("CAP_FASTJET_PATH"):
            env["CAP_FASTJET_PATH"] = paths["CAP_FASTJET_PATH"]

        # Wipe a previous build/ directory so a stale CMakeCache or partial
        # objects from an earlier failed run don't poison this attempt.
        build_dir = REPO / "build"
        if build_dir.exists():
            self._append_log(f"Removing previous build directory: {build_dir}", "info")
            self.log.line("INFO", f"rm -rf {build_dir}")
            try:
                import shutil
                shutil.rmtree(build_dir)
            except OSError as exc:
                self._append_log(f"Could not delete {build_dir}: {exc}", "error")
                self.queue.put(("status", "Could not delete previous build directory."))
                self.queue.put(("enable_build", None))
                return

        cmake_flags = []
        if paths.get("CAP_PYTHIA8_PATH"):
            cmake_flags += ["-DCAP_ENABLE_PYTHIA=ON",
                            f"-DCAP_PYTHIA8_PATH={paths['CAP_PYTHIA8_PATH']}"]
        else:
            cmake_flags.append("-DCAP_ENABLE_PYTHIA=OFF")
        # Jets is OFF by default — see JETS_KNOWN_ISSUES.md.  Only flip ON
        # when the user ticked the "Enable Jets module" checkbox AND a
        # valid FastJet path was found.  Setting CAP_FASTJET_PATH alone
        # just primes find_package(FastJet) so headers are discoverable.
        jets_on = bool(self.enable_jets_var.get()) and bool(paths.get("CAP_FASTJET_PATH"))
        cmake_flags.append("-DCAP_ENABLE_JETS=" + ("ON" if jets_on else "OFF"))
        if paths.get("CAP_FASTJET_PATH"):
            cmake_flags.append(f"-DCAP_FASTJET_PATH={paths['CAP_FASTJET_PATH']}")

        # ------------------------------------------------------------------
        # HERWIG 7 + HEP stack flags — mirror the checkboxes user ticked.
        # CAP_HERWIG_PATH points the find module at the install; HW_PREFIX
        # is also exported into the build env so herwig-config / thepeg-
        # config are findable on PATH if the user sourced herwig-env.sh.
        # ------------------------------------------------------------------
        hw_prefix = self.hw_prefix_var.get().strip()
        hw_on     = bool(self.enable_herwig_var.get())
        hepmc3_on = bool(self.enable_hepmc3_var.get()) or hw_on    # Herwig implies HepMC3
        lhapdf_on = bool(self.enable_lhapdf_var.get()) or hw_on    # Herwig implies LHAPDF
        fastjet_on= bool(self.enable_fastjet_var.get())
        yoda_on   = bool(self.enable_yoda_var.get())
        rivet_on  = bool(self.enable_rivet_var.get())

        cmake_flags.append("-DCAP_ENABLE_HEPMC3=" + ("ON" if hepmc3_on else "OFF"))
        cmake_flags.append("-DCAP_ENABLE_LHAPDF=" + ("ON" if lhapdf_on else "OFF"))
        cmake_flags.append("-DCAP_ENABLE_FASTJET=" + ("ON" if fastjet_on else "OFF"))
        cmake_flags.append("-DCAP_ENABLE_YODA=" + ("ON" if yoda_on else "OFF"))
        cmake_flags.append("-DCAP_ENABLE_RIVET=" + ("ON" if rivet_on else "OFF"))
        cmake_flags.append("-DCAP_ENABLE_HERWIG=" + ("ON" if hw_on else "OFF"))
        if hw_prefix and (hw_on or hepmc3_on or lhapdf_on or yoda_on or rivet_on):
            # FindHerwig.cmake / FindHepMC3.cmake / FindLHAPDF.cmake /
            # FindYODA.cmake / FindRivet.cmake all honour these hints.
            cmake_flags.append(f"-DCAP_HERWIG_PATH={hw_prefix}")
            cmake_flags.append(f"-DCAP_HEPMC3_PATH={hw_prefix}")
            cmake_flags.append(f"-DCAP_LHAPDF_PATH={hw_prefix}")
            cmake_flags.append(f"-DCAP_YODA_PATH={hw_prefix}")
            cmake_flags.append(f"-DCAP_RIVET_PATH={hw_prefix}")
            env["HW_PREFIX"] = hw_prefix
            # Make the *-config helpers discoverable by find_program.
            env["PATH"] = f"{hw_prefix}/bin:" + env.get("PATH", "")

        # Configure
        cmds = [
            (["cmake", "-S", str(REPO), "-B", str(REPO / "build")] + cmake_flags, "cmake configure"),
            (["cmake", "--build", str(REPO / "build"), "-j"], "cmake build"),
            (["cmake", "--install", str(REPO / "build")], "cmake install"),
        ]
        for cmd, label in cmds:
            self._append_log(f"---- {label} ----", "info")
            rc = self._run_streaming_with_env(cmd, env)
            if rc != 0:
                self._append_log(f"{label} FAILED (exit {rc}). See {self.log.path}", "error")
                self.queue.put(("status", f"{label} failed."))
                self.queue.put(("enable_build", None))
                return

        # Post-install sanity & auto-relocate. Older builds (or builds done
        # with a stale CMakeCache) installed bin/ and lib/ ONE LEVEL ABOVE
        # the repo root because of a CMake path-math bug. If we detect that
        # state, move the directories into the repo so things work without
        # the user having to know.
        self._post_install_verify()

        self.queue.put(("status", "Build & install OK ✅"))
        self.queue.put(("append", ("Build complete — try the sample job.", "ok")))
        self.queue.put(("enable_sample", None))
        self.queue.put(("enable_build", None))

    def _post_install_verify(self) -> None:
        """Make sure bin/ and lib/ ended up inside the repo. If a previous
        build (or a botched CMake config) put them in REPO.parent, move them
        into REPO. Reports everything to the log."""
        import shutil

        expected_bin = REPO / "bin"
        expected_lib = REPO / "lib"
        misplaced_bin = REPO.parent / "bin"
        misplaced_lib = REPO.parent / "lib"

        moved_anything = False

        for misplaced, expected, label in (
            (misplaced_bin, expected_bin, "bin"),
            (misplaced_lib, expected_lib, "lib"),
        ):
            # Only act if misplaced exists, expected does not, AND misplaced
            # contains files we just installed.
            if not misplaced.exists():
                continue
            if expected.exists():
                # If both exist, merge contents from misplaced into expected
                # then delete the misplaced dir.
                self._append_log(
                    f"Found {label}/ in BOTH {misplaced} and {expected} — merging.", "info"
                )
                for item in misplaced.iterdir():
                    target = expected / item.name
                    try:
                        if target.exists():
                            if target.is_dir():
                                shutil.rmtree(target)
                            else:
                                target.unlink()
                        shutil.move(str(item), str(target))
                    except OSError as exc:
                        self._append_log(f"  could not move {item}: {exc}", "error")
                try:
                    misplaced.rmdir()
                except OSError:
                    pass
                moved_anything = True
            else:
                self._append_log(
                    f"Relocating misplaced {label}/ from {misplaced} → {expected}",
                    "info"
                )
                try:
                    shutil.move(str(misplaced), str(expected))
                    moved_anything = True
                except OSError as exc:
                    self._append_log(f"  move failed: {exc}", "error")

        # Confirm CAP binary is present where SetupCAP.sh expects it.
        if (expected_bin / "CAP").is_file():
            self._append_log(f"✓ {expected_bin}/CAP is in place", "ok")
        else:
            self._append_log(
                f"⚠ {expected_bin}/CAP NOT FOUND after install — something is wrong.",
                "error"
            )
        if any(expected_lib.glob("libCAPPythia*")) if expected_lib.exists() else False:
            self._append_log(f"✓ {expected_lib}/libCAPPythia.* is in place", "ok")

        if moved_anything:
            self._append_log(
                "Auto-relocated install artifacts into the repo. "
                "Future builds will land here directly — this fix is permanent.",
                "info"
            )

    def _run_streaming_with_env(self, cmd: list[str], env: dict) -> int:
        proc = subprocess.Popen(cmd, env=env, cwd=str(REPO),
                                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                                text=True, bufsize=1)
        assert proc.stdout is not None
        for line in proc.stdout:
            self.queue.put(("line", line.rstrip()))
            self.log.line("DEBUG", line.rstrip())
        proc.wait()
        return proc.returncode

    def _run_threaded(self, cmd: list[str], label: str) -> int:
        """Synchronous-from-caller, but log lines stream into the GUI."""
        self._append_log(f"---- {label} ----", "info")
        result_box = {"rc": None}
        done = threading.Event()

        def runner():
            try:
                result_box["rc"] = self._run_streaming_with_env(cmd, os.environ.copy())
            finally:
                done.set()

        threading.Thread(target=runner, daemon=True).start()
        while not done.is_set():
            self.root.update()
        return result_box["rc"]

    def _run_sample(self) -> None:
        # Hand control to run-cap, the dedicated runner GUI. It can pick any
        # project / task / output rather than the hardcoded Pythia smoke test.
        runner = REPO / "run-cap"
        if not runner.exists():
            self._append_log("run-cap script not found.", "error")
            return
        self._append_log("Launching run-cap …", "info")
        try:
            subprocess.Popen([str(runner)], cwd=str(REPO))
        except OSError as exc:
            self._append_log(f"Could not launch run-cap: {exc}", "error")

    def _open_logs(self) -> None:
        if sys.platform == "darwin":
            subprocess.Popen(["open", str(LOGS)])
        elif sys.platform.startswith("linux"):
            subprocess.Popen(["xdg-open", str(LOGS)])
        else:
            messagebox.showinfo("Logs", f"Logs are at: {LOGS}")

    # -- Async-safe log pump ---------------------------------------------
    def _append_log(self, text: str, tag: str = "") -> None:
        self.queue.put(("append", (text + "\n", tag)))

    def _poll_queue(self) -> None:
        try:
            while True:
                kind, payload = self.queue.get_nowait()
                if kind == "line":
                    self.log_widget.insert(tk.END, payload + "\n")
                    self.log_widget.see(tk.END)
                elif kind == "append":
                    msg, tag = payload
                    if tag:
                        self.log_widget.insert(tk.END, msg, tag)
                    else:
                        self.log_widget.insert(tk.END, msg)
                    self.log_widget.see(tk.END)
                elif kind == "status":
                    self.status_var.set(payload)
                elif kind == "enable_build":
                    self.build_btn.config(state=tk.NORMAL)
                elif kind == "enable_sample":
                    self.sample_btn.config(state=tk.NORMAL)
                elif kind == "error":
                    self._append_log(payload, "error")
        except queue.Empty:
            pass
        self.root.after(80, self._poll_queue)

    def _on_close(self) -> None:
        self.log.line("INFO", "GUI closed by user.")
        self.log.close(0)
        self.root.destroy()

    def run(self) -> None:
        self.root.mainloop()


def main() -> None:
    try:
        gui = CapSetupGUI()
        gui.run()
    except tk.TclError as exc:
        # Common cause: no DISPLAY (running over plain SSH).
        sys.stderr.write(
            "\nCould not initialise the Tk display layer:\n"
            f"  {exc}\n\n"
            "Possible fixes:\n"
            "  • If you're on a headless server: use ./setup-cap (CLI mode) instead.\n"
            "  • If you're SSHed into a server: re-connect with `ssh -X` so X11 forwarding works.\n"
            "  • On Debian/Ubuntu without Tk:  apt install python3-tk\n"
            "  • On RHEL/CentOS/WSU without Tk: yum install python3-tkinter\n\n")
        sys.exit(2)


if __name__ == "__main__":
    main()
