# ---------------------------------------------------------------------------
#  Reusable list-of-rows widget for particle / event filters
# ---------------------------------------------------------------------------
class FilterList(ttk.Frame):
    """A grid of editable rows + Add/Remove buttons."""

    def __init__(self, parent, columns, get_state, set_state):
        super().__init__(parent)
        self.columns = columns          # list of (label, key, width) tuples
        self.get_state = get_state      # () -> list[dict]
        self.set_state = set_state      # (list[dict]) -> None
        self._rows: list[dict] = []
        self._build()

    def _build(self):
        # Header
        for c, (label, _key, _w) in enumerate(self.columns):
            ttk.Label(self, text=label, font=("TkDefaultFont", 10, "bold")
                      ).grid(row=0, column=c, padx=4, pady=2, sticky="w")
        ttk.Label(self, text="").grid(row=0, column=len(self.columns))

        self.body = ttk.Frame(self)
        self.body.grid(row=1, column=0, columnspan=len(self.columns) + 1, sticky="nsew")
        for c in range(len(self.columns)):
            self.body.columnconfigure(c, weight=1)

        btns = ttk.Frame(self)
        btns.grid(row=2, column=0, columnspan=len(self.columns) + 1, sticky="w", pady=4)
        ttk.Button(btns, text="+ Add row", command=self._add_blank).pack(side=tk.LEFT, padx=2)
        ttk.Button(btns, text="Reset to defaults", command=self._reset).pack(side=tk.LEFT, padx=2)

        self.rebuild_from_state()

    def rebuild_from_state(self):
        for child in self.body.winfo_children():
            child.destroy()
        self._rows.clear()
        for row_idx, item in enumerate(self.get_state()):
            self._add_row(row_idx, item)

    def _add_row(self, row_idx: int, item: dict):
        widgets = {}
        for c, (_label, key, w) in enumerate(self.columns):
            v = tk.StringVar(value=str(item.get(key, "") or ""))
            e = ttk.Entry(self.body, textvariable=v, width=w)
            e.grid(row=row_idx, column=c, padx=2, pady=1, sticky="ew")
            widgets[key] = v
        btn = ttk.Button(self.body, text="✕", width=2,
                         command=lambda i=row_idx: self._remove_row(i))
        btn.grid(row=row_idx, column=len(self.columns), padx=2)
        self._rows.append({"widgets": widgets, "button": btn})

    def _add_blank(self):
        state = self.collect()
        state.append({key: "" for (_l, key, _w) in self.columns})
        self.set_state(state)
        self.rebuild_from_state()

    def _remove_row(self, idx: int):
        state = self.collect()
        if 0 <= idx < len(state):
            state.pop(idx)
            self.set_state(state)
            self.rebuild_from_state()

    def _reset(self):
        # Caller's set_state is allowed to choose what 'default' means;
        # just trigger a refresh.
        self.set_state([])
        self.rebuild_from_state()

    def collect(self) -> list[dict]:
        rows = []
        for r in self._rows:
            rows.append({key: var.get().strip() for key, var in r["widgets"].items()})
        return rows


