    # ----- Scrollable-tab helper ----------------------------------------
    def _make_scrollable_tab(self, nb, label, padding=10):
        """Add a tab to *nb* whose body is a scrollable inner frame.
        Returns the inner frame so callers can pack/grid as if it were
        a normal ttk.Frame.  Both V- and H-scrollbars are present;
        the inner frame stretches to canvas width when the canvas is
        wider than the content (otherwise content keeps its natural
        size and you can scroll horizontally)."""
        outer = ttk.Frame(nb, padding=0)
        nb.add(outer, text=label)
        outer.rowconfigure(0, weight=1)
        outer.columnconfigure(0, weight=1)
        canvas = tk.Canvas(outer, highlightthickness=0)
        vbar = ttk.Scrollbar(outer, orient=tk.VERTICAL,   command=canvas.yview)
        hbar = ttk.Scrollbar(outer, orient=tk.HORIZONTAL, command=canvas.xview)
        canvas.configure(yscrollcommand=vbar.set, xscrollcommand=hbar.set)
        canvas.grid(row=0, column=0, sticky="nsew")
        vbar.grid(row=0, column=1, sticky="ns")
        hbar.grid(row=1, column=0, sticky="ew")

        inner = ttk.Frame(canvas, padding=padding)
        win   = canvas.create_window((0, 0), window=inner, anchor="nw")

        def _on_inner(_evt):
            canvas.configure(scrollregion=canvas.bbox("all"))
        def _on_canvas(evt):
            inner.update_idletasks()
            inner_w = inner.winfo_reqwidth()
            canvas.itemconfigure(
                win, width=evt.width if evt.width > inner_w else inner_w)
        inner.bind("<Configure>", _on_inner)
        canvas.bind("<Configure>", _on_canvas)

        # Mouse-wheel: vertical = wheel, horizontal = Shift+wheel.
        def _on_wheel(evt):
            shift = bool(getattr(evt, "state", 0) & 0x0001)
            target = canvas.xview_scroll if shift else canvas.yview_scroll
            if evt.num == 4:  target(-3, "units")
            elif evt.num == 5: target( 3, "units")
            elif hasattr(evt, "delta") and evt.delta:
                step = -evt.delta // (120 if abs(evt.delta) >= 120 else 1)
                target(step, "units")
        def _bind(_e):
            canvas.bind_all("<MouseWheel>",       _on_wheel)
            canvas.bind_all("<Shift-MouseWheel>", _on_wheel)
            canvas.bind_all("<Button-4>",         _on_wheel)
            canvas.bind_all("<Button-5>",         _on_wheel)
        def _unbind(_e):
            for ev in ("<MouseWheel>", "<Shift-MouseWheel>",
                       "<Button-4>", "<Button-5>"):
                canvas.unbind_all(ev)
        canvas.bind("<Enter>", _bind)
        canvas.bind("<Leave>", _unbind)
        return inner

    def _build_generator_config_subpanel(self, parent, *, kind_name, state,
                                          presets, bool_toggles,
                                          numeric_knobs, start_row):
        """Append four sub-sections to the per-kind LabelFrame:
            (1) preset dropdown + live preview
            (2) on/off toggles, grouped by category
            (3) numeric input boxes, grouped by category
            (4) custom raw strings textarea
        Mirrors the run-cap config window so the .ini built here behaves
        identically when re-run."""
        # ---- Preset row ----
        row = start_row
        ttk.Label(parent, text=f"{kind_name} preset",
                  font=("TkDefaultFont", 10, "bold")).grid(
            row=row, column=0, sticky="w", pady=(8, 2), padx=8)
        preset_var = tk.StringVar(value=state["preset"])
        cb = ttk.Combobox(parent, textvariable=preset_var,
                          values=list(presets.keys()),
                          state="readonly", width=44)
        cb.grid(row=row, column=1, sticky="w", pady=(8, 2))
        state["_preset_var"] = preset_var
        row += 1

        # Live preview of preset lines.
        preview = tk.Text(parent, height=4, wrap=tk.NONE,
                          font=("Menlo", 9), background="#0e1116",
                          foreground="#c9d1d9")
        preview.grid(row=row, column=0, columnspan=2, sticky="we",
                     padx=8, pady=2)
        def _update_preview(*_):
            preview.delete("1.0", tk.END)
            for ln in presets.get(preset_var.get(), []):
                preview.insert(tk.END, ln + "\n")
        cb.bind("<<ComboboxSelected>>", _update_preview)
        _update_preview()
        row += 1

        # ---- Boolean toggles, grouped by category ----
        by_cat_bool: dict[str, list] = {}
        for key, spec in bool_toggles.items():
            cat = spec.get("category", "Misc")
            by_cat_bool.setdefault(cat, []).append(
                (key, spec.get("label", key)))
        ttk.Label(parent, text=f"{kind_name} on/off switches  (override the preset)",
                  font=("TkDefaultFont", 10, "bold")).grid(
            row=row, column=0, sticky="w", pady=(6, 2), padx=8)
        row += 1
        panel_vars: dict = {}
        for cat in by_cat_bool:
            sub = ttk.LabelFrame(parent, text=cat)
            sub.grid(row=row, column=0, columnspan=2, sticky="we",
                     padx=8, pady=2)
            col = 0; subrow = 0
            for key, lbl in by_cat_bool[cat]:
                v = tk.BooleanVar(value=state["panels"].get(key, False))
                panel_vars[key] = v
                ttk.Checkbutton(sub, text=lbl, variable=v
                                ).grid(row=subrow, column=col, sticky="w",
                                       padx=8, pady=1)
                col = (col + 1) % 2
                if col == 0:
                    subrow += 1
            row += 1
        state["_panel_vars"] = panel_vars

        # ---- Numeric input boxes, grouped by category ----
        by_cat_num: dict[str, list] = {}
        for key, spec in numeric_knobs.items():
            cat = spec.get("category", "Misc")
            by_cat_num.setdefault(cat, []).append((key, spec))
        ttk.Label(parent,
                  text=f"{kind_name} numeric parameters  (input boxes — leave blank to skip)",
                  font=("TkDefaultFont", 10, "bold")).grid(
            row=row, column=0, sticky="w", pady=(6, 2), padx=8)
        row += 1
        numeric_vars: dict[str, tk.StringVar] = {}
        for cat, items in by_cat_num.items():
            sub = ttk.LabelFrame(parent, text=cat)
            sub.grid(row=row, column=0, columnspan=2, sticky="we",
                     padx=8, pady=2)
            for r, (key, spec) in enumerate(items):
                ttk.Label(sub, text=spec.get("label", key),
