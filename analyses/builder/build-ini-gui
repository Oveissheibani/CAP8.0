    # -- Sync between Job <-> form --------------------------------------
    def _sync_form_from_job(self):
        j = self.job
        self.name_var.set(j.name)
        self.outdir_var.set(j.output_dir)
        self.nevents_var.set(str(j.n_events))
        self.nreport_var.set(str(j.n_events_report))

        self.gen_kind_var.set(j.generator.kind.value)
        # Reload all known generator-var fields from the job — covers
        # Pythia/Herwig/HepMC3/Therminator/Glauber/EPOS/PHSD all at once.
        for key, var in self.gen_vars.items():
            val = getattr(j.generator, key, None)
            if isinstance(var, tk.BooleanVar):
                var.set(bool(val))
            else:
                var.set(str(val) if val is not None else "")
        # Reapply the show/hide of kind-specific frames.
        try:
            self._show_relevant_gen_kind_frame()
        except Exception:
            pass
        # Restore Pythia/Herwig preset+toggle+custom state from the Job.
        # The Job stores the preset NAME and the resolved extra lines —
        # we can faithfully restore the preset; toggle state would need
        # round-tripping through the lines, so we leave toggles off and
        # the user re-ticks if desired.  Custom string is empty on load
        # because there's no way to distinguish "user-typed" from
        # "preset-derived" inside extra_options.
        try:
            if j.generator.pythia_preset_name and self._pythia_cfg_state.get("_preset_var"):
                self._pythia_cfg_state["_preset_var"].set(j.generator.pythia_preset_name)
                self._pythia_cfg_state["preset"] = j.generator.pythia_preset_name
            if j.generator.herwig_preset_name and self._herwig_cfg_state.get("_preset_var"):
                self._herwig_cfg_state["_preset_var"].set(j.generator.herwig_preset_name)
                self._herwig_cfg_state["preset"] = j.generator.herwig_preset_name
        except Exception:
            pass

        self._particle_state.clear()
        self._particle_state.extend(self._pf_to_dict(pf) for pf in j.particle_filters)
        self.particle_list.rebuild_from_state()

        self._event_state.clear()
        self._event_state.extend(self._ef_to_dict(ef) for ef in j.event_filters)
        self.event_list.rebuild_from_state()

        for choice, v in self.analysis_vars.items():
            v.set(choice in j.analyses)

        for key, axis in [
            ("n", j.binning.n), ("pt", j.binning.pt), ("eta", j.binning.eta),
            ("y", j.binning.y), ("phi", j.binning.phi),
            ("qinv", j.binning.qinv),
            ("delta_ps", j.binning.delta_ps), ("delta_po", j.binning.delta_po),
            ("delta_pl", j.binning.delta_pl),
        ]:
            n, lo, hi = self.bin_vars[key]
            n.set(str(axis.nbins)); lo.set(str(axis.min)); hi.set(str(axis.max))

    def _form_to_job(self) -> Job:
        # Pull each tab back into a Job object.
        try:
            n_events = int(self.nevents_var.get())
            n_report = int(self.nreport_var.get())
        except ValueError:
            raise ValueError("Number of events and report frequency must be integers.")

        gen = Generator(kind=GeneratorKind(self.gen_kind_var.get()))
        for key, var in self.gen_vars.items():
            if isinstance(var, tk.BooleanVar):
                setattr(gen, key, bool(var.get()))
            else:
                cur = getattr(gen, key, None)
                raw = var.get().strip()
                if raw == "":
                    continue
                if isinstance(cur, int):
                    setattr(gen, key, int(raw))
                elif isinstance(cur, float):
                    setattr(gen, key, float(raw))
                else:
                    setattr(gen, key, raw)

        # Snapshot the Pythia/Herwig sub-panel state and emit
        # preset+toggle+custom into Generator.{pythia,herwig}_*.
        try:
            self._snapshot_gen_cfg_states()
            gen.pythia_preset_name    = self._pythia_cfg_state["preset"]
            gen.pythia_extra_options  = collect_pythia_strings(
                self._pythia_cfg_state["preset"],
                self._pythia_cfg_state["panels"],
                self._pythia_cfg_state.get("numeric", {}),
                self._pythia_cfg_state["custom"],
                self._pythia_cfg_state.get("stable", []),
                ctau_max_mm=(self._pythia_cfg_state.get("ctau_value")
                             if self._pythia_cfg_state.get("ctau_enable")
                             else None))
            gen.herwig_preset_name    = self._herwig_cfg_state["preset"]
            gen.herwig_extra_in_lines = collect_herwig_lines(
                self._herwig_cfg_state["preset"],
                self._herwig_cfg_state["panels"],
                self._herwig_cfg_state.get("numeric", {}),
                self._herwig_cfg_state["custom"],
                self._herwig_cfg_state.get("stable", []),
                ctau_max_mm=(self._herwig_cfg_state.get("ctau_value")
                             if self._herwig_cfg_state.get("ctau_enable")
                             else None))
        except Exception:
            # Subpanel not built (older code path) — skip silently.
            pass

        # Particle and event filters — read from the FilterList widgets.
        self._particle_state[:] = self.particle_list.collect()
        pfs = [self._dict_to_pf(d) for d in self._particle_state if d.get("name", "").strip()]
        self._event_state[:] = self.event_list.collect()
        efs = [self._dict_to_ef(d) for d in self._event_state if d.get("name", "").strip()]
        if not pfs:
            raise ValueError("Add at least one particle filter.")
        if not efs:
            raise ValueError("Add at least one event filter.")

        analyses = [c for c, v in self.analysis_vars.items() if v.get()]
        if not analyses:
            raise ValueError("Pick at least one analysis on the 'Analyses' tab.")

        # Binning
        def axis(key) -> Binning1D:
            n, lo, hi = self.bin_vars[key]
            return Binning1D(int(n.get()), float(lo.get()), float(hi.get()))
        binning = Binning(
            n=axis("n"), pt=axis("pt"), eta=axis("eta"), y=axis("y"), phi=axis("phi"),
            qinv=axis("qinv"),
            delta_ps=axis("delta_ps"), delta_po=axis("delta_po"), delta_pl=axis("delta_pl"),
        )

        return Job(
            name=self.name_var.get().strip() or "my_analysis",
            output_dir=self.outdir_var.get().strip() or "test",
            n_events=n_events, n_events_report=n_report,
            generator=gen,
            particle_filters=pfs, event_filters=efs,
            analyses=analyses, binning=binning,
        )

    # -- Actions ----------------------------------------------------------
    def _on_preset_change(self, _evt=None):
        chosen = self.preset_var.get()
        preset = PRESETS.get(chosen)
        if preset is None:
            return
        try:
            self.job = preset.build()
        except Exception as exc:
            messagebox.showerror("build-ini", f"Preset failed: {exc}")
            return
        self._sync_form_from_job()
        self.status_var.set(f"Loaded preset: {preset.name}")

    def _refresh_preview(self):
        try:
            job = self._form_to_job()
        except Exception as exc:
            messagebox.showerror("build-ini", str(exc))
            return
        self.job = job
        text = render_ini(job)
        self.preview.configure(state=tk.NORMAL)
        self.preview.delete("1.0", tk.END)
        self.preview.insert(tk.END, text)
        self.preview.configure(state=tk.DISABLED)
        self.status_var.set("Preview refreshed.")

    def _load_existing_ini(self) -> None:
        """Picker accepts both:
        * `.json` preset (saved by 💾 Save preset) — full GUI restore
        * `.ini`  legacy file — partial restore (a few obvious fields)

        For round-trippable state, save and load .json presets — the
        .ini is a one-way flattened export."""
        path = filedialog.askopenfilename(
            initialdir=str(OUT_DIR),
            filetypes=[("CAP preset", "*.json"),
                       ("CAP .ini",   "*.ini"),
                       ("All files",  "*.*")],
            title="Load preset (.json) or existing .ini")
        if not path:
            return
        if path.lower().endswith(".json"):
            self._load_preset_from(path)
            return
        try:
            text = Path(path).read_text(encoding="utf-8", errors="replace")
        except OSError as exc:
            messagebox.showerror("build-ini", f"Could not read {path}: {exc}")
            return

        # ---- Parse the obvious key=value pairs ----
        kv: dict[str, str] = {}
        for ln in text.splitlines():
            s = ln.strip()
            if not s or s.startswith("//") or s.startswith("#"):
                continue
            if "=" in s:
                k, v = s.split("=", 1)
                k = k.strip()
                v = v.strip().rstrip(";")
                # Last assignment wins (matches CAP's loader convention).
                kv[k] = v

        n_restored = 0
        # Top-level job basics
        for k_in, var in (("Name",       self.name_var),
                          ("OutputPath", self.outdir_var),
                          ("NEvents",    self.nevents_var),
                          ("ReportFreq", self.nreport_var)):
            if k_in in kv:
                var.set(kv[k_in])
                n_restored += 1

        # Generator kind — look for any 'GeneratorType=<X>' line.
        for k, v in kv.items():
            if k.endswith(":GeneratorType") or k == "GeneratorType":
                if v in (gk.value for gk in GeneratorKind):
                    self.gen_kind_var.set(v)
                    n_restored += 1
                    break

        # Subtasks → analyses checkboxes.  The composer emits
        # 'Subtask<N>:TaskName=Run<XYZ>Analyzer'; we map those back to
        # the AnalysisChoice enum if possible.
        choice_map = {
            "RunGlobalAnalysis":     AnalysisChoice.GLOBAL,
            "RunSingleAnalysis":     AnalysisChoice.SINGLE,
            "RunPairAnalysis":       AnalysisChoice.PAIR,
            "RunPair3DAnalysis":     AnalysisChoice.PAIR3D,
            "RunSpherocityAnalysis": AnalysisChoice.SPHEROCITY,
            "RunNuDynAnalysis":      AnalysisChoice.NUDYN,
            "RunPtPtAnalysis":       AnalysisChoice.PTPT,
        }
        chosen = set()
        for k, v in kv.items():
            if k.startswith("Subtask") and k.endswith(":TaskName"):
                if v in choice_map:
                    chosen.add(choice_map[v])
        # Apply to checkboxes.  self.analysis_vars is a dict[choice -> BooleanVar]
        if chosen and hasattr(self, "analysis_vars"):
            for ch, var in self.analysis_vars.items():
                var.set(ch in chosen)
            n_restored += len(chosen)

        # Pythia / Herwig preset NAMES (only present in newer .inis that
        # tagged them as comments).
        for ln in text.splitlines():
            s = ln.strip()
            if s.startswith("#! pythia_preset_name"):
                _, _, name = s.partition("=")
                if name.strip() and self._pythia_cfg_state.get("_preset_var"):
                    self._pythia_cfg_state["_preset_var"].set(name.strip())
                    n_restored += 1
            elif s.startswith("#! herwig_preset_name"):
                _, _, name = s.partition("=")
                if name.strip() and self._herwig_cfg_state.get("_preset_var"):
                    self._herwig_cfg_state["_preset_var"].set(name.strip())
                    n_restored += 1

        self._refresh_preview()
        self.status_var.set(
            f"Loaded {Path(path).name} — restored {n_restored} field(s).  "
            f"Generator-panel state (toggles/numerics/stable-particles/cτ) "
            f"was not in the file; tweak as needed.")

    # ====================================================================
    #  Preset save / load — captures the WHOLE build-ini-gui state
    # ====================================================================
    def _collect_buildini_state(self) -> dict:
        """Walk every visible tk.Var and the cfg dicts, return a
        JSON-serialisable preset.  Sections: common (Pythia/Herwig
        cfg), build_ini_gui (basics + generator + analyses + extras)."""
        import sys as _sys
        from pathlib import Path as _Path
        _sys.path.insert(0, str(_Path(__file__).resolve().parent))
        import cap_preset as _cp

        def _g(v, default=None):
            try: return v.get()
            except Exception: return default

        # Force a snapshot of the per-generator panels into the dicts.
        try: self._snapshot_gen_cfg_states()
        except Exception: pass

        bi = {
            "name":         _g(self.name_var, ""),
            "outdir":       _g(self.outdir_var, ""),
            "nevents":      _g(self.nevents_var, ""),
            "nreport":      _g(self.nreport_var, ""),
            "preset_name":  _g(self.preset_var, ""),
            "gen_kind":     _g(self.gen_kind_var, ""),
            # Per-kind generator vars (str/bool dropdowns)
            "gen_vars": {k: _g(v) for k, v in self.gen_vars.items()},
            # Analysis subtask checkboxes
            "analyses":     {ch.value: _g(v, False)
                             for ch, v in self.analysis_vars.items()},
        }
        return {
            "saved_by": "build-ini-gui",
            "common": {
                "pythia_cfg": _cp.cfg_to_json(self._pythia_cfg_state),
                "herwig_cfg": _cp.cfg_to_json(self._herwig_cfg_state),
            },
            "build_ini_gui": bi,
        }

    def _apply_buildini_state(self, state: dict) -> int:
        import sys as _sys
        from pathlib import Path as _Path
        _sys.path.insert(0, str(_Path(__file__).resolve().parent))
        import cap_preset as _cp

        n = 0
        bi = state.get("build_ini_gui", {}) if isinstance(state, dict) else {}

        def _s(var, key, transform=None):
            nonlocal n
            if key in bi and var is not None:
                val = bi[key]
                if transform is not None:
                    try: val = transform(val)
                    except Exception: return
                try: var.set(val); n += 1
                except Exception: pass

        _s(self.name_var,        "name")
        _s(self.outdir_var,      "outdir")
        _s(self.nevents_var,     "nevents")
        _s(self.nreport_var,     "nreport")
        _s(self.preset_var,      "preset_name")
        _s(self.gen_kind_var,    "gen_kind")

        # Generator vars (per-kind dropdowns)
        for k, var in self.gen_vars.items():
            if k in (bi.get("gen_vars") or {}):
                try: var.set(bi["gen_vars"][k]); n += 1
                except Exception: pass

        # Analyses checkboxes
        a_payload = bi.get("analyses") or {}
        for ch, var in self.analysis_vars.items():
            if ch.value in a_payload:
                try: var.set(bool(a_payload[ch.value])); n += 1
                except Exception: pass

        # Common: Pythia + Herwig cfg dicts
        common = state.get("common", {}) if isinstance(state, dict) else {}
        if "pythia_cfg" in common:
            _cp.cfg_from_json(common["pythia_cfg"], self._pythia_cfg_state)
        if "herwig_cfg" in common:
            _cp.cfg_from_json(common["herwig_cfg"], self._herwig_cfg_state)

        # Push the cfg dict values back into the live widgets
        for cfg in (self._pythia_cfg_state, self._herwig_cfg_state):
            pv = cfg.get("_preset_var")
            if pv is not None and "preset" in cfg:
                try: pv.set(cfg["preset"])
                except Exception: pass

        # Refresh the toggling widgets so the user sees the new layout
        try: self._show_relevant_gen_kind_frame()
        except Exception: pass
        return n

    def _save_preset(self) -> None:
        path = filedialog.asksaveasfilename(
            initialdir=str(OUT_DIR),
            initialfile="my_preset.json",
            defaultextension=".json",
            filetypes=[("CAP preset (JSON)", "*.json"),
                       ("All files", "*.*")],
            title="Save GUI state as preset")
        if not path:
            return
        import sys as _sys
        from pathlib import Path as _Path
        _sys.path.insert(0, str(_Path(__file__).resolve().parent))
        import cap_preset as _cp
        try:
            _cp.save_preset(self._collect_buildini_state(), path)
        except Exception as exc:
            messagebox.showerror("build-ini", f"Save preset failed: {exc}")
            return
        self.status_var.set(f"Preset saved → {path}")

    def _load_preset_from(self, path: str) -> None:
        import sys as _sys
        from pathlib import Path as _Path
        _sys.path.insert(0, str(_Path(__file__).resolve().parent))
        import cap_preset as _cp
        try:
            state = _cp.load_preset(path)
        except Exception as exc:
            messagebox.showerror("build-ini", f"Load preset failed: {exc}")
            return
        n = self._apply_buildini_state(state)
        self._refresh_preview()
        self.status_var.set(f"Preset loaded ({n} fields restored from "
                            f"{Path(path).name})")

    def _save(self) -> Path | None:
        try:
            job = self._form_to_job()
        except Exception as exc:
            messagebox.showerror("build-ini", str(exc))
            return None
        OUT_DIR.mkdir(parents=True, exist_ok=True)
        default = f"{job.name}.ini"
        path = filedialog.asksaveasfilename(
            initialdir=str(OUT_DIR),
            initialfile=default,
            defaultextension=".ini",
            filetypes=[("CAP .ini", "*.ini"), ("All files", "*.*")],
            title="Save .ini")
        if not path:
            return None
        out = write_ini(job, path)
        self.status_var.set(f"Wrote {out}")
        return out

    def _save_and_run(self):
        path = self._save()
        if not path:
            return
        runner = REPO / "run-cap"
        if not runner.exists():
            messagebox.showinfo("build-ini",
                f"Wrote {path}\nLaunch run-cap manually to execute it.")
            return
        try:
            import subprocess
            subprocess.Popen([str(runner)], cwd=str(REPO))
            self.status_var.set(f"Wrote {path} — run-cap launched.")
        except OSError as exc:
            messagebox.showwarning("build-ini", f"Could not launch run-cap: {exc}")

    def _on_close(self):
        self.root.destroy()

    def run(self):
        self.root.mainloop()


def main():
    try:
        gui = IniBuilderGUI()
        gui.run()
    except tk.TclError as exc:
        sys.stderr.write(
            "\nCould not initialise the Tk display layer:\n"
            f"  {exc}\n\n"
            "If you are on a headless server, you can still build .ini files\n"
            "from a Python REPL using cap_ini_builder.write_ini() directly.\n")
        sys.exit(2)


if __name__ == "__main__":
    main()
