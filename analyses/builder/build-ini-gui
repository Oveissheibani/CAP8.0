    def _snapshot_gen_cfg_states(self):
        """Pull the current dropdown / toggles / numeric boxes / stable
        / custom-textarea content back into the state dicts.  Called by
        _form_to_job."""
        for state in (getattr(self, "_pythia_cfg_state", None),
                      getattr(self, "_herwig_cfg_state", None)):
            if not state:
                continue
            pv = state.get("_preset_var")
            if pv is not None:
                state["preset"] = pv.get()
            panel_vars = state.get("_panel_vars") or {}
            state["panels"] = {k: v.get() for k, v in panel_vars.items()}
            num_vars = state.get("_numeric_vars") or {}
            state["numeric"] = {k: v.get() for k, v in num_vars.items()}
            # Stable particles: combine grid + extras textbox
            stable_vars = state.get("_stable_vars") or {}
            picked = [pdg for pdg, v in stable_vars.items() if v.get()]
            extras_widget = state.get("_stable_extras")
            if extras_widget is not None:
                for ln in extras_widget.get("1.0", tk.END).strip().splitlines():
                    tok = ln.strip().lstrip(",").strip()
                    if not tok or tok.startswith("#"): continue
                    try:
                        picked.append(int(tok))
                    except ValueError:
                        picked.append(tok)
            state["stable"] = picked
            # cτ cut
            ce = state.get("_ctau_enable_var")
            cv = state.get("_ctau_value_var")
            if ce is not None: state["ctau_enable"] = bool(ce.get())
            if cv is not None: state["ctau_value"]  = cv.get().strip()
            cw = state.get("_custom_widget")
            if cw is not None:
                state["custom"] = cw.get("1.0", tk.END).rstrip("\n")

